	column IsDiagnostico = NOT ISBLANK(JOBS_Produto[JOB]) && NOT ISBLANK(JOBS_Produto[DATA_CADASTRO]) && (CONTAINSSTRING(UPPER(COALESCE(JOBS_Produto[NOME_PRODUTO], "")), "DIAG") || CONTAINSSTRING(UPPER(COALESCE(JOBS_Produto[NOME_SUBPRODUTO], "")), "DIAG") || CONTAINSSTRING(UPPER(COALESCE(JOBS_Produto[MODELO_PRODUTO], "")), "DIAG") || CONTAINSSTRING(UPPER(COALESCE(JOBS_Produto[MODELO_NEGOCIO], "")), "DIAG"))
		dataType: boolean
		isHidden
		lineageTag: f4d1b64c-d8c5-4fde-9114-efed7667b053
		summarizeBy: none

	/// Rotulo governado para limitar o visual principal aos produtos da imagem da esteira TAX.
	column ProdutoImagemTax = SWITCH(TRUE(), JOBS_Produto[CODIGO_PRODUTO] = 138, "PRT", JOBS_Produto[CODIGO_PRODUTO] = 475 && JOBS_Produto[COD_SUBPRODUTO] IN { 476, 507 }, "FINTAX - QUALIFICADOS", JOBS_Produto[CODIGO_PRODUTO] = 366 && JOBS_Produto[COD_SUBPRODUTO] = 485, "PREVIDENCIÁRIO - ADMINISTRATIVO", JOBS_Produto[CODIGO_PRODUTO] = 366 && JOBS_Produto[COD_SUBPRODUTO] = 508, "PREVIDENCIÁRIO - QUALIFICADO", JOBS_Produto[CODIGO_PRODUTO] = 367, "TRANSAÇÃO TRIBUTÁRIA", JOBS_Produto[CODIGO_PRODUTO] = 368, "CONSULTORIA REFORMA TRIBUTÁRIA", JOBS_Produto[CODIGO_PRODUTO] = 224, "LEI DO BEM", JOBS_Produto[CODIGO_PRODUTO] = 369, "SUPLLY TAX", JOBS_Produto[CODIGO_PRODUTO] = 792, "FINEP", JOBS_Produto[CODIGO_PRODUTO] = 370, "LIQUIDAÇÃO CONTRATADA", JOBS_Produto[CODIGO_PRODUTO] = 29, "GPT - GESTÃO DO PASSIVO TRIBUTÁRIO", BLANK())
		dataType: string
		lineageTag: 0c743a7c-f790-41dd-89bc-b0c2f84cbb22
		summarizeBy: none

	/// Ordem de exibicao da lista de produtos da imagem TAX.
	column ProdutoImagemTaxOrdem = SWITCH(JOBS_Produto[ProdutoImagemTax], "PRT", 1, "FINTAX - QUALIFICADOS", 2, "PREVIDENCIÁRIO - ADMINISTRATIVO", 3, "PREVIDENCIÁRIO - QUALIFICADO", 4, "TRANSAÇÃO TRIBUTÁRIA", 5, "CONSULTORIA REFORMA TRIBUTÁRIA", 6, "LEI DO BEM", 7, "SUPLLY TAX", 8, "TAX LIFE", 9, "FINEP", 10, "LIQUIDAÇÃO CONTRATADA", 11, "GPT - GESTÃO DO PASSIVO TRIBUTÁRIO", 12, BLANK())
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 3a7d1fa4-8b52-4c09-8a7c-48e29669c39f
		summarizeBy: none

	/// Filtro base para produtos de diagnostico. Usado pelas medidas para evitar duplicacao de codigo.
	partition JOBS_Produto = m
		mode: import
		source =
				let
				    Fonte = Sql.Databases("192.168.2.34"),
				    STUDIO_FISCAL = Fonte{[Name="STUDIO_FISCAL"]}[Data],
				    dbo_vw_powerbi_jobs_produto_area = STUDIO_FISCAL{[Schema="dbo",Item="vw_powerbi_jobs_produto_area"]}[Data]
				in
				    dbo_vw_powerbi_jobs_produto_area

