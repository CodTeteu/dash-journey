/// Dimensao desconectada para o slicer de produtos TAX. Exibe somente os produtos da imagem enviada.
table DIM_PRODUTOS_IMAGEM_TAX
	lineageTag: 46d515d4-4dcb-4cc6-9442-3b437c796944

	column Ordem
		lineageTag: 041a6be0-4415-4d45-9940-20a4bba8eb2b
		isNameInferred
		sourceColumn: [Ordem]

	column ProdutoImagem
		lineageTag: b78bf746-a657-4b01-9877-a2f7d8c25689
		isNameInferred
		sourceColumn: [ProdutoImagem]
		sortByColumn: Ordem

	partition DIM_PRODUTOS_IMAGEM_TAX = calculated
		mode: import
		source =
				DATATABLE (
				    "Ordem", INTEGER,
				    "ProdutoImagem", STRING,
				    {
				        { 1, "PRT" },
				        { 2, "FINTAX - QUALIFICADOS" },
				        { 3, "PREVIDENCIÁRIO - ADMINISTRATIVO" },
				        { 4, "PREVIDENCIÁRIO - QUALIFICADO" },
				        { 5, "TRANSAÇÃO TRIBUTÁRIA" },
				        { 6, "CONSULTORIA REFORMA TRIBUTÁRIA" },
				        { 7, "LEI DO BEM" },
				        { 8, "SUPLLY TAX" },
				        { 9, "TAX LIFE" },
				        { 10, "FINEP" },
				        { 11, "LIQUIDAÇÃO CONTRATADA" },
				        { 12, "GPT - GESTÃO DO PASSIVO TRIBUTÁRIO" }
				    }
				)

