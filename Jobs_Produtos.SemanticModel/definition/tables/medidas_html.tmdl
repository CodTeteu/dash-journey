						    vCSS & vHTML
			```
		displayFolder: 11 | Documentação
		lineageTag: f12039a5-a0eb-4967-9a5c-c2c27638806e

	measure HTML_DETALHAMENTO_DIAGNOSTICO_JOURNEY_SEM_ESPACO_OCIOSO = ```
			
			VAR vLimiteLinhas = 750
			VAR vIntFormat = "#,##0"
			VAR vPctFormat = "0.0%"
			
			VAR _css =
			"
			<style>
			:root{
			    --bg:#080b10;
			    --panel:rgba(14,18,24,.965);
			    --panel-2:#0e1218;
			    --border:rgba(213,174,119,.16);
			    --border-soft:rgba(255,255,255,.055);
			    --gold:#F4D9A9;
			    --gold-2:#D5AE77;
			    --teal:#8BE0D1;
			    --text:#ffffff;
			    --text-2:#AEB9C4;
			    --text-3:#6E7A86;
			    --green:#4ade80;
			    --red:#FFB0A8;
			    --warn:#F4D9A9;
			    --hover:rgba(213,174,119,.08);
			    --font:'Segoe UI',system-ui,sans-serif;
			}
			html,body{
			    margin:0;
			    padding:0;
			    width:100vw;
			    height:100vh;
			    background:var(--bg);
			    font-family:var(--font);
			    color:var(--text);
			    overflow:hidden;
			}
			*{box-sizing:border-box}
			.painel{
			    height:calc(100vh - 20px);
			    margin:10px;
			    padding:24px;
			    display:flex;
			    flex-direction:column;
			    border-radius:18px;
			    border:1px solid var(--border);
			    background:
			        radial-gradient(circle at 0% 0%,rgba(213,174,119,.16),transparent 28%),
			        radial-gradient(circle at 92% 4%,rgba(139,224,209,.10),transparent 28%),
			        linear-gradient(180deg,#101923 0%,#0B1219 100%);
			    box-shadow:0 18px 48px rgba(0,0,0,.48),inset 0 1px 0 rgba(255,255,255,.05);
			}
			.cabecalho{
			    display:flex;
			    justify-content:space-between;
			    align-items:center;
			    gap:18px;
			    flex-shrink:0;
			    padding-bottom:15px;
			    margin-bottom:14px;
			    border-bottom:1px solid var(--border);
			}
			.cabecalho-esquerda{
			    display:flex;
			    align-items:center;
			    gap:16px;
			    min-width:0;
			}
			.btn-voltar,.btn-copiar{
			    display:flex;
			    align-items:center;
			    justify-content:center;
			    gap:7px;
			    min-height:38px;
			    border-radius:10px;
			    padding:9px 15px;
			    border:1px solid var(--border);
			    background:rgba(213,174,119,.08);
			    color:var(--gold);
			    cursor:pointer;
			    font-family:var(--font);
			    font-size:13.8px;
			    font-weight:950;
			    letter-spacing:.08em;
			    text-transform:uppercase;
			    white-space:nowrap;
			    transition:all .2s ease;
			}
			.btn-voltar:hover,.btn-copiar:hover{
			    background:rgba(213,174,119,.15);
			    border-color:var(--gold-2);
			    color:#fff;
			    box-shadow:0 0 16px rgba(213,174,119,.16);
			}
			.titulo{
			    display:flex;
			    align-items:center;
			    gap:11px;
			    color:var(--gold);
			    font-size:30px;
			    font-weight:950;
			    letter-spacing:.10em;
			    text-transform:uppercase;
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.titulo:before{
			    content:'';
			    display:inline-block;
			    width:7px;
			    height:28px;
			    border-radius:6px;
			    background:linear-gradient(180deg,var(--gold),var(--gold-2),var(--teal));
			    box-shadow:0 0 18px rgba(213,174,119,.22);
			}
			.controles{
			    display:flex;
			    align-items:center;
			    justify-content:flex-end;
			    gap:12px;
			    flex-shrink:0;
			}
			.busca-global{
			    width:370px;
			    border-radius:10px;
			    border:1px solid var(--border);
			    outline:none;
			    background:rgba(213,174,119,.055);
			    color:#fff;
			    font-family:var(--font);
			    font-size:15.6px;
			    padding:13px 18px;
			    transition:all .25s ease;
			}
			.busca-global:focus{
			    width:430px;
			    border-color:var(--gold-2);
			    background:rgba(213,174,119,.09);
			    box-shadow:0 0 0 3px rgba(213,174,119,.06);
			}
			.resumo{
			    display:grid;
			    grid-template-columns:repeat(6,1fr);
			    gap:10px;
			    flex-shrink:0;
			    margin-bottom:13px;
			}
			.kpi{
			    min-height:92px;
			    position:relative;
			    overflow:hidden;
			    border-radius:15px;
			    border:1px solid rgba(255,255,255,.09);
			    background:linear-gradient(155deg,rgba(18,28,37,.96),rgba(11,18,25,.94));
			    padding:14px 13px 12px;
			    box-shadow:0 14px 26px rgba(0,0,0,.20),inset 0 1px 0 rgba(255,255,255,.05);
			}
			.kpi.primary{
			    border-color:rgba(213,174,119,.38);
			    background:linear-gradient(155deg,rgba(213,174,119,.18),rgba(18,28,37,.96) 34%,rgba(11,18,25,.96));
			}
			.kpi:before{
			    content:'';
			    position:absolute;
			    left:13px;
			    top:0;
			    width:42px;
			    height:4px;
			    border-radius:0 0 9px 9px;
			    background:linear-gradient(90deg,var(--gold),var(--teal));
			}
			.kpi-label{
			    display:block;
			    color:var(--text-2);
			    font-size:10.8px;
			    font-weight:950;
			    letter-spacing:.08em;
			    text-transform:uppercase;
			    margin-bottom:7px;
			}
			.kpi-value{
			    display:block;
			    color:var(--gold);
			    font-size:28.8px;
			    font-weight:950;
			    line-height:1.05;
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.kpi-note{
			    display:block;
			    color:var(--text-3);
			    font-size:13px;
			    font-weight:850;
			    margin-top:6px;
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.table-wrapper{
			    flex:1 1 auto;
			    min-height:0;
			    overflow-y:auto;
			    overflow-x:hidden;
			    padding-right:8px;
			    position:relative;
			}
			.table-wrapper::-webkit-scrollbar{width:8px;height:0}
			.table-wrapper::-webkit-scrollbar-track{background:rgba(255,255,255,.025);border-radius:999px}
			.table-wrapper::-webkit-scrollbar-thumb{background:rgba(213,174,119,.38);border-radius:999px}
			.table-wrapper::-webkit-scrollbar-thumb:hover{background:rgba(213,174,119,.62)}
			.tabela{
			    width:100%;
			    min-width:0;
			    max-width:100%;
			    table-layout:fixed;
			    border-collapse:collapse;
			}
			.tabela th{
			    position:sticky;
			    top:0;
			    z-index:5;
			    padding:12px 8px;
			    background:#0e1218;
			    color:var(--gold-2);
			    border-bottom:1px solid rgba(213,174,119,.28);
			    box-shadow:0 1px 0 var(--border);
			    text-align:left;
			    font-size:11.7px;
			    font-weight:950;
			    text-transform:uppercase;
			    letter-spacing:.09em;
			}
			.tabela td{
			    padding:12px 8px;
			    color:#fff;
			    border-bottom:1px solid var(--border-soft);
			    font-size:14px;
			    line-height:1.32;
			    vertical-align:middle;
			    transition:background .18s ease;
			}
			.tabela tr:hover td{background:var(--hover)}
			.tabela tr:hover td:first-child{
			    border-left:3px solid var(--gold-2);
			    padding-left:9px;
			    color:var(--gold);
			}
			.col-filter{
			    width:100%;
			    margin-top:7px;
			    padding:7px 8px;
			    border-radius:6px;
			    border:1px solid var(--border);
			    background:rgba(0,0,0,.28);
			    color:#fff;
			    outline:none;
			    font-family:var(--font);
			    font-size:11.8px;
			    font-weight:700;
			}
			.col-filter:focus{
			    border-color:var(--gold-2);
			    background:rgba(213,174,119,.08);
			}
			.col-filter::placeholder{color:var(--text-3)}
			.td-job{
			    display:flex;
			    align-items:center;
			    gap:10px;
			    font-weight:950;
			    color:#F8EFE1;
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.td-job-text{
			    min-width:0;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.td-cliente,.td-produto,.td-ops{
			    max-width:310px;
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.td-cnpj{
			    white-space:nowrap;
			    color:#DCE5EE;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.chip{
			    display:inline-flex;
			    align-items:center;
			    justify-content:center;
			    border-radius:999px;
			    padding:5px 8px;
			    font-size:11.9px;
			    font-weight:950;
			    letter-spacing:.04em;
			    text-transform:uppercase;
			    white-space:nowrap;
			    border:1px solid rgba(255,255,255,.10);
			    background:rgba(255,255,255,.045);
			    color:var(--text-2);
			}
			.chip-check,.chip-priorizar{
			    color:var(--red);
			    border-color:rgba(255,176,168,.32);
			    background:rgba(217,93,93,.10);
			}
			.chip-oper,.chip-acompanhar{
			    color:var(--gold);
			    border-color:rgba(213,174,119,.34);
			    background:rgba(213,174,119,.10);
			}
			.chip-proc,.chip-ok{
			    color:var(--teal);
			    border-color:rgba(139,224,209,.34);
			    background:rgba(139,224,209,.09);
			}
			.chip-fim{
			    color:var(--green);
			    border-color:rgba(74,222,128,.34);
			    background:rgba(74,222,128,.08);
			}
			.num{
			    text-align:center;
			    font-weight:950;
			    color:var(--gold);
			}
			.date-cell{
			    text-align:center;
			    color:#DCE5EE;
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.days{
			    text-align:center;
			    font-weight:950;
			    color:var(--gold);
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			
			.expand-btn{
			    user-select:none;
			    width:24px;
			    height:24px;
			    display:inline-flex;
			    align-items:center;
			    justify-content:center;
			    border-radius:10px;
			    border:1px solid rgba(213,174,119,.34);
			    background:rgba(213,174,119,.08);
			    color:var(--gold);
			    font-size:12px;
			    font-weight:950;
			    cursor:pointer;
			    transition:all .18s ease;
			}
			.expand-btn:hover{
			    background:rgba(213,174,119,.16);
			    border-color:var(--gold-2);
			    box-shadow:0 0 14px rgba(213,174,119,.16);
			}
			.expand-btn.open{
			    color:#081018;
			    background:linear-gradient(135deg,var(--gold),var(--gold-2),var(--teal));
			    border-color:rgba(244,217,169,.72);
			    transform:rotate(90deg);
			}
			.linha-detalhe[data-expanded='1'] td{
			    background:rgba(213,174,119,.055);
			}
			.linha-extra{
			    display:none;
			}
			.linha-extra td{
			    padding:0!important;
			    background:rgba(4,8,12,.58)!important;
			    border-bottom:1px solid rgba(213,174,119,.18)!important;
			}
			.job-extra-panel{
			    padding:18px 20px 20px 64px;
			    border-left:3px solid rgba(213,174,119,.42);
			    background:
			        radial-gradient(circle at 0% 0%,rgba(213,174,119,.10),transparent 30%),
			        linear-gradient(180deg,rgba(12,20,28,.92),rgba(6,11,16,.96));
			}
			.job-extra-top{
			    display:flex;
			    align-items:flex-start;
			    justify-content:space-between;
			    flex-wrap:wrap;
			    gap:14px;
			    margin-bottom:14px;
			}
			.job-extra-title{
			    color:var(--gold);
			    font-size:18px;
			    font-weight:950;
			    letter-spacing:.04em;
			    text-transform:uppercase;
			}
			.job-extra-subtitle{
			    margin-top:5px;
			    color:var(--text-2);
			    font-size:13.5px;
			    font-weight:850;
			    line-height:1.35;
			}
			.job-extra-kpis{
			    display:flex;
			    gap:8px;
			    flex-wrap:wrap;
			    justify-content:flex-start;
			}
			.extra-pill{
			    display:inline-flex;
			    align-items:center;
			    gap:5px;
			    padding:7px 10px;
			    border-radius:999px;
			    border:1px solid rgba(255,255,255,.10);
			    background:rgba(255,255,255,.045);
			    color:var(--text-2);
			    font-size:12px;
			    font-weight:900;
			    white-space:nowrap;
			}
			.extra-pill strong{
			    color:var(--gold);
			    font-weight:950;
			}
			.extra-pill.good{
			    color:var(--teal);
			    border-color:rgba(139,224,209,.30);
			    background:rgba(139,224,209,.08);
			}
			.extra-pill.warn{
			    color:var(--gold);
			    border-color:rgba(213,174,119,.30);
			    background:rgba(213,174,119,.08);
			}
			.extra-grid{
			    display:grid;
			    grid-template-columns:repeat(4,minmax(130px,1fr));
			    gap:10px;
			    margin-bottom:12px;
			}
			.extra-card{
			    min-width:0;
			    border:1px solid rgba(255,255,255,.08);
			    background:rgba(255,255,255,.035);
			    border-radius:14px;
			    padding:12px 12px;
			}
			.extra-card span{
			    display:block;
			    color:var(--text-3);
			    font-size:11px;
			    font-weight:950;
			    letter-spacing:.07em;
			    text-transform:uppercase;
			    margin-bottom:6px;
			}
			.extra-card b{
			    display:block;
			    color:#F0F5FA;
			    font-size:14px;
			    font-weight:900;
			    white-space:nowrap;
			    overflow:hidden;
			    text-overflow:ellipsis;
			}
			.extra-section{
			    border:1px solid rgba(255,255,255,.08);
			    background:rgba(255,255,255,.025);
			    border-radius:14px;
			    padding:12px;
			    margin-top:10px;
			}
			.extra-section-title{
			    color:var(--gold-2);
			    font-size:12px;
			    font-weight:950;
			    letter-spacing:.08em;
			    text-transform:uppercase;
			    margin-bottom:10px;
			}
			.extra-chip-wrap{
			    display:flex;
			    gap:8px;
			    flex-wrap:wrap;
			}
			.area-detail-chip,.detail-opp{
			    display:inline-flex;
			    align-items:center;
			    gap:7px;
			    padding:7px 10px;
			    border-radius:999px;
			    border:1px solid rgba(255,255,255,.10);
			    background:rgba(255,255,255,.045);
			    color:#DCE5EE;
			    font-size:12px;
			    font-weight:850;
			}
			.detail-opp.passed{
			    color:var(--teal);
			    border-color:rgba(139,224,209,.30);
			    background:rgba(139,224,209,.08);
			}
			.detail-opp.open{
			    color:var(--gold);
			    border-color:rgba(213,174,119,.26);
			    background:rgba(213,174,119,.07);
			}
			.detail-opp em{
			    color:var(--text-3);
			    font-style:normal;
			    font-size:10.5px;
			    font-weight:950;
			    text-transform:uppercase;
			}
			.job-extra-search{
			    display:none;
			}
			
			.tabela tfoot td{
			    position:sticky;
			    bottom:-1px;
			    z-index:5;
			    background:#0e1218;
			    border-top:2px solid var(--gold-2);
			    border-bottom:none;
			    color:var(--gold);
			    font-size:15px;
			    font-weight:950;
			    letter-spacing:.06em;
			    text-transform:uppercase;
			}
			.count-destaque{
			    display:inline-flex;
			    align-items:center;
			    justify-content:center;
			    min-width:44px;
			    margin-left:8px;
			    padding:5px 10px;
			    border-radius:8px;
			    border:1px solid var(--gold-2);
			    background:rgba(213,174,119,.18);
			    color:#fff;
			    font-size:20px;
			    font-weight:950;
			}
			.empty{
			    text-align:center;
			    padding:46px!important;
			    color:var(--text-3)!important;
			    font-size:17.5px!important;
			}
			
			@media(max-width:1500px){
			    .tabela th{font-size:10.5px;padding:10px 6px}
			    .tabela td{font-size:12.8px;padding:10px 6px}
			    .chip{font-size:9.6px;padding:4px 6px}
			    .col-filter{font-size:10.5px;padding:6px 6px}
			    .td-cliente,.td-produto,.td-ops{max-width:100%}
			    .extra-grid{grid-template-columns:repeat(2,minmax(130px,1fr))}
			}
			
			</style>
			"
			
			VAR _js =
			"
			<script>
			function safeText(selector,row){
			    var el=row.querySelector(selector);
			    return el ? el.textContent.toLowerCase() : '';
			}
			
			function filtrarTabela(){
			    var qG=document.getElementById('buscaGlobal').value.toLowerCase();
			    var qJ=document.getElementById('buscaColJob').value.toLowerCase();
			    var qE=document.getElementById('buscaColEtapa').value.toLowerCase();
			    var qC=document.getElementById('buscaColCliente').value.toLowerCase();
			    var qP=document.getElementById('buscaColProduto').value.toLowerCase();
			    var rows=document.querySelectorAll('.linha-detalhe');
			    var count=0;
			    for(var i=0;i<rows.length;i++){
			        var detail=rows[i].nextElementSibling;
			        var detailText=(detail && detail.classList.contains('linha-extra')) ? detail.textContent.toLowerCase() : '';
			        var tJ=safeText('.td-job',rows[i]);
			        var tE=safeText('.td-etapa',rows[i]);
			        var tA=safeText('.td-acao',rows[i]);
			        var tC=safeText('.td-cliente',rows[i]);
			        var tCNPJ=safeText('.td-cnpj',rows[i]);
			        var tP=safeText('.td-produto',rows[i]);
			        var tOps=safeText('.td-ops',rows[i]);
			        var matchG=(qG===''||tJ.indexOf(qG)>-1||tE.indexOf(qG)>-1||tA.indexOf(qG)>-1||tC.indexOf(qG)>-1||tCNPJ.indexOf(qG)>-1||tP.indexOf(qG)>-1||tOps.indexOf(qG)>-1||detailText.indexOf(qG)>-1);
			        var matchCols=(tJ.indexOf(qJ)>-1&&tE.indexOf(qE)>-1&&tC.indexOf(qC)>-1&&tP.indexOf(qP)>-1);
			        if(matchG&&matchCols){
			            rows[i].style.display='';
			            if(detail && detail.classList.contains('linha-extra')){
			                detail.style.display=(rows[i].dataset.expanded==='1')?'table-row':'none';
			            }
			            count++;
			        }else{
			            rows[i].style.display='none';
			            if(detail && detail.classList.contains('linha-extra')){detail.style.display='none';}
			        }
			    }
			    var countEl=document.getElementById('totalJobsCount');
			    if(countEl){countEl.textContent=count;}
			}
			function toggleJob(btn){
			    var row=btn.closest('tr');
			    if(!row){return;}
			    var detail=row.nextElementSibling;
			    if(!detail || !detail.classList.contains('linha-extra')){return;}
			    var open=row.dataset.expanded==='1';
			    row.dataset.expanded=open?'0':'1';
			    btn.classList.toggle('open',!open);
			    detail.style.display=open?'none':'table-row';
			}
			setTimeout(filtrarTabela,100);
			function copiarTabela(){
			    var btn=document.getElementById('btnCopiar');
			    var originalText=btn.innerHTML;
			    btn.innerHTML='&#8982; Copiando...';
			    var textToCopy='';
			    var ths=document.querySelectorAll('.tabela thead th');
			    for(var i=0;i<ths.length;i++){
			        var span=ths[i].querySelector('span');
			        var thText=span?span.textContent.trim():ths[i].textContent.trim();
			        textToCopy+=thText+(i===ths.length-1?'\n':'\t');
			    }
			    var rows=document.querySelectorAll('.linha-detalhe');
			    var copiedCount=0;
			    for(var r=0;r<rows.length;r++){
			        if(rows[r].style.display!=='none'){
			            var tds=rows[r].querySelectorAll('td');
			            for(var j=0;j<tds.length;j++){
			                var cellText=tds[j].textContent.trim().replace(/\s+/g,' '); if(j===0){cellText=cellText.replace(/^▶\s*/, '');} textToCopy+=cellText+(j===tds.length-1?'\n':'\t');
			            }
			            copiedCount++;
			        }
			    }
			    try{
			        var textArea=document.createElement('textarea');
			        textArea.value=textToCopy;
			        textArea.style.position='fixed';
			        textArea.style.opacity='0';
			        document.body.appendChild(textArea);
			        textArea.focus();
			        textArea.select();
			        var successful=document.execCommand('copy');
			        document.body.removeChild(textArea);
			        if(successful){
			            btn.innerHTML='&#10004; Copiado ('+copiedCount+' linhas)';
			            btn.style.borderColor='var(--green)';
			            btn.style.color='var(--green)';
			            setTimeout(function(){
			                btn.innerHTML=originalText;
			                btn.style.borderColor='var(--border)';
			                btn.style.color='var(--gold)';
			            },3000);
			        }else{throw new Error('copy failed');}
			    }catch(err){
			        btn.innerHTML='&#10060; Erro ao copiar';
			        setTimeout(function(){btn.innerHTML=originalText;},3000);
			    }
			}
			</script>
			"
			
			VAR _base = 'JOBS_Produto'
			
			VAR _jobsStage =
			    ADDCOLUMNS (
			        SUMMARIZE ( _base, 'JOBS_Produto'[JOB] ),
			        "__Stage",
			            VAR vJobKey = 'JOBS_Produto'[JOB]
			            VAR vJobRows =
			                SELECTCOLUMNS (
			                    FILTER ( _base, 'JOBS_Produto'[JOB] = vJobKey ),
			                    "@S",
			                        VAR vArea = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
			                        RETURN
			                            SWITCH (
			                                TRUE (),
			                                vArea = "CHECKLIST", 1,
			                                vArea = "OPERAÇÃO", 2,
			                                vArea = "OPERACAO", 2,
			                                vArea = "PROCURAÇÃO ELETRÔNICA", 3,
			                                vArea = "PROCURACAO ELETRONICA", 3,
			                                vArea = "FIM", 4,
			                                0
			                            )
			                )
			            VAR vMaxAll = MAXX ( vJobRows, [@S] )
			            VAR vMaxOpen = MAXX ( FILTER ( vJobRows, [@S] < 4 ), [@S] )
			            RETURN
			                IF ( vMaxAll = 4 && ISBLANK ( vMaxOpen ), 4, COALESCE ( vMaxOpen, 0 ) )
			    )
			
			VAR _jobsBase =
			    ADDCOLUMNS (
			        _jobsStage,
			
			        "__Cliente",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                COALESCE (
			                    MAXX (
			                        FILTER ( _base, 'JOBS_Produto'[JOB] = _job && NOT ISBLANK ( 'JOBS_Produto'[NOME_CLIENTE] ) ),
			                        'JOBS_Produto'[NOME_CLIENTE]
			                    ),
			                    "Sem cliente"
			                ),
			
			        "__CNPJ",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                COALESCE (
			                    MAXX (
			                        FILTER ( _base, 'JOBS_Produto'[JOB] = _job && NOT ISBLANK ( 'JOBS_Produto'[CNPJ_CLIENTE] ) ),
			                        'JOBS_Produto'[CNPJ_CLIENTE] & ""
			                    ),
			                    "Sem CNPJ"
			                ),
			
			        "__Produto",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                COALESCE (
			                    MAXX (
			                        FILTER ( _base, 'JOBS_Produto'[JOB] = _job && NOT ISBLANK ( 'JOBS_Produto'[NOME_PRODUTO] ) ),
			                        'JOBS_Produto'[NOME_PRODUTO]
			                    ),
			                    "Sem produto"
			                ),
			
			        "__Subproduto",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                COALESCE (
			                    MAXX (
			                        FILTER ( _base, 'JOBS_Produto'[JOB] = _job && NOT ISBLANK ( 'JOBS_Produto'[NOME_SUBPRODUTO] ) ),
			                        'JOBS_Produto'[NOME_SUBPRODUTO]
			                    ),
			                    "Sem subproduto"
			                ),
			
			        "__DataCadastro",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                MINX ( FILTER ( _base, 'JOBS_Produto'[JOB] = _job ), 'JOBS_Produto'[DATA_CADASTRO] ),
			
			        "__UltimoMovimento",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                MAXX (
			                    FILTER ( _base, 'JOBS_Produto'[JOB] = _job ),
			                    COALESCE ( 'JOBS_Produto'[TRIBUTO_DATA_ENTRADA], 'JOBS_Produto'[DATA_CADASTRO] )
			                ),
			
			        "__Dias",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                MAXX ( FILTER ( _base, 'JOBS_Produto'[JOB] = _job ), 'JOBS_Produto'[DIAS] ),
			
			        "__StageSort", [__Stage],
			
			        "__EtapaAtual",
			            SWITCH (
			                [__Stage],
			                1, "Checklist",
			                2, "Operação",
			                3, "Procuração",
			                4, "Fim",
			                "Sem etapa"
			            ),
			
			        "__Status",
			            IF ( [__Stage] = 4, "Finalizado", "Ativo" ),
			
			        "__Acao",
			            SWITCH (
			                [__Stage],
			                4, "Finalizado",
			                1, "Priorizar avanço",
			                2, "Acompanhar operação",
			                3, "Acompanhar procuração",
			                "Verificar base"
			            ),
			
			        "__OportDisp",
			            VAR _job = 'JOBS_Produto'[JOB]
			            RETURN
			                COUNTROWS (
			                    SUMMARIZE (
			                        FILTER ( _base, 'JOBS_Produto'[JOB] = _job && NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] ) ),
			                        'JOBS_Produto'[NOME_TRIBUTO]
			                    )
			                ),
			
			        "__OportPass",
			            VAR _job = 'JOBS_Produto'[JOB]
			            VAR _jobRows =
			                FILTER (
			                    _base,
			                    'JOBS_Produto'[JOB] = _job
			                        && NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] )
			                        && (
			                            VAR _areaPass = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
			                            RETURN
			                                _areaPass IN {
			                                    "OPERAÇÃO",
			                                    "OPERACAO",
			                                    "PROCURAÇÃO ELETRÔNICA",
			                                    "PROCURACAO ELETRONICA",
			                                    "FIM"
			                                }
			                        )
			                )
			            RETURN
			                COUNTROWS ( SUMMARIZE ( _jobRows, 'JOBS_Produto'[NOME_TRIBUTO] ) ),
			
			        "__OportunidadesLista",
			            VAR _job = 'JOBS_Produto'[JOB]
			            VAR _jobRows = FILTER ( _base, 'JOBS_Produto'[JOB] = _job )
			            VAR _topOps =
			                TOPN (
			                    5,
			                    ADDCOLUMNS (
			                        SUMMARIZE (
			                            FILTER ( _jobRows, NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] ) ),
			                            'JOBS_Produto'[NOME_TRIBUTO]
			                        ),
			                        "__Passou",
			                            VAR _trib = 'JOBS_Produto'[NOME_TRIBUTO]
			                            RETURN
			                                COUNTROWS (
			                                    FILTER (
			                                        _jobRows,
			                                        COALESCE ( 'JOBS_Produto'[NOME_TRIBUTO], "" ) = COALESCE ( _trib, "" )
			                                            && (
			                                                VAR _areaPass = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
			                                                RETURN
			                                                    _areaPass IN {
			                                                        "OPERAÇÃO",
			                                                        "OPERACAO",
			                                                        "PROCURAÇÃO ELETRÔNICA",
			                                                        "PROCURACAO ELETRONICA",
			                                                        "FIM"
			                                                    }
			                                            )
			                                    )
			                                )
			                    ),
			                    [__Passou], DESC,
			                    'JOBS_Produto'[NOME_TRIBUTO], ASC
			                )
			            RETURN
			                COALESCE (
			                    CONCATENATEX (
			                        _topOps,
			                        'JOBS_Produto'[NOME_TRIBUTO] & IF ( [__Passou] > 0, " ✓", "" ),
			                        " · ",
			                        [__Passou], DESC
			                    ),
			                    "Sem oportunidades"
			                )
			    )
			
			VAR _totalJobs = COUNTROWS ( _jobsBase )
			VAR _jobsAtivos = COUNTROWS ( FILTER ( _jobsBase, [__Status] = "Ativo" ) )
			VAR _jobsFinalizados = COUNTROWS ( FILTER ( _jobsBase, [__Status] = "Finalizado" ) )
			VAR _jobsPassaram = COUNTROWS ( FILTER ( _jobsBase, [__StageSort] >= 2 ) )
			VAR _pctPassaram = DIVIDE ( _jobsPassaram, _totalJobs , 0 )
			VAR _oportDispTotal =
			    COUNTROWS (
			        SUMMARIZE (
			            FILTER ( _base, NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] ) ),
			            'JOBS_Produto'[NOME_TRIBUTO]
			        )
			    )
			VAR _oportPassTotal =
			    COUNTROWS (
			        SUMMARIZE (
			            FILTER (
			                _base,
			                NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] )
			                    && (
			                        VAR _areaPass = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
			                        RETURN
			                            _areaPass IN {
			                                "OPERAÇÃO",
			                                "OPERACAO",
			                                "PROCURAÇÃO ELETRÔNICA",
			                                "PROCURACAO ELETRONICA",
			                                "FIM"
			                            }
			                    )
			            ),
			            'JOBS_Produto'[NOME_TRIBUTO]
			        )
			    )
			
			VAR _jobsDetalhe =
			    TOPN (
			        vLimiteLinhas,
			        _jobsBase,
			        [__Status], ASC,
			        [__StageSort], ASC,
			        [__Dias], DESC,
			        [__DataCadastro], DESC,
			        'JOBS_Produto'[JOB], ASC
			    )
			
			VAR _qtdListada = COUNTROWS ( _jobsDetalhe )
			
			VAR _opcoesProduto =
			    CONCATENATEX (
			        SUMMARIZE ( _base, 'JOBS_Produto'[NOME_PRODUTO] ),
			        "<option value='" & SUBSTITUTE ( COALESCE ( 'JOBS_Produto'[NOME_PRODUTO], "" ), "'", "&#39;" ) & "'></option>",
			        "",
			        'JOBS_Produto'[NOME_PRODUTO], ASC
			    )
			
			VAR _opcoesEtapa =
			    "<option value='Checklist'></option>"
			        & "<option value='Operação'></option>"
			        & "<option value='Procuração'></option>"
			        & "<option value='Fim'></option>"
			        & "<option value='Sem etapa'></option>"
			
			VAR _linhas =
			    CONCATENATEX (
			        _jobsDetalhe,
			        VAR _stage = [__StageSort]
			        VAR _etapaClass =
			            SWITCH (
			                TRUE (),
			                _stage = 1, "chip-check",
			                _stage = 2, "chip-oper",
			                _stage = 3, "chip-proc",
			                _stage = 4, "chip-fim",
			                "chip"
			            )
			        VAR _acao = [__Acao]
			        VAR _acaoClass =
			            SWITCH (
			                TRUE (),
			                _acao = "Finalizado", "chip-fim",
			                _acao = "Priorizar avanço", "chip-priorizar",
			                _acao = "Acompanhar operação", "chip-acompanhar",
			                _acao = "Acompanhar procuração", "chip-ok",
			                "chip"
			            )
			        VAR _jobKey = 'JOBS_Produto'[JOB]
			        VAR _jobRows =
			            FILTER ( _base, 'JOBS_Produto'[JOB] = _jobKey )
			        VAR _qtdLinhas =
			            COUNTROWS ( _jobRows )
			        VAR _modeloProduto =
			            COALESCE (
			                MAXX (
			                    FILTER ( _jobRows, NOT ISBLANK ( 'JOBS_Produto'[MODELO_PRODUTO] ) ),
			                    'JOBS_Produto'[MODELO_PRODUTO]
			                ),
			                "Sem modelo produto"
			            )
			        VAR _modeloNegocio =
			            COALESCE (
			                MAXX (
			                    FILTER ( _jobRows, NOT ISBLANK ( 'JOBS_Produto'[MODELO_NEGOCIO] ) ),
			                    'JOBS_Produto'[MODELO_NEGOCIO]
			                ),
			                "Sem modelo negócio"
			            )
			        VAR _areasResumo =
			            CONCATENATEX (
			                ADDCOLUMNS (
			                    SUMMARIZE ( _jobRows, 'JOBS_Produto'[NOME_AREA] ),
			                    "__QtdArea",
			                        VAR _areaKey = 'JOBS_Produto'[NOME_AREA]
			                        RETURN
			                            COUNTROWS (
			                                FILTER (
			                                    _jobRows,
			                                    COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) = COALESCE ( _areaKey, "" )
			                                )
			                            )
			                ),
			                "<span class='area-detail-chip'>" & COALESCE ( 'JOBS_Produto'[NOME_AREA], "Sem área" ) & " · " & FORMAT ( [__QtdArea], vIntFormat ) & "</span>",
			                "",
			                [__QtdArea], DESC
			            )
			        VAR _opsDetalhe =
			            COALESCE (
			                CONCATENATEX (
			                    TOPN (
			                        6,
			                        ADDCOLUMNS (
			                            SUMMARIZE (
			                                FILTER ( _jobRows, NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] ) ),
			                                'JOBS_Produto'[NOME_TRIBUTO]
			                            ),
			                            "__Passou",
			                                VAR _trib = 'JOBS_Produto'[NOME_TRIBUTO]
			                                RETURN
			                                    COUNTROWS (
			                                        FILTER (
			                                            _jobRows,
			                                            COALESCE ( 'JOBS_Produto'[NOME_TRIBUTO], "" ) = COALESCE ( _trib, "" )
			                                                && (
			                                                    VAR _areaPass = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
			                                                    RETURN
			                                                        _areaPass IN {
			                                                            "OPERAÇÃO",
			                                                            "OPERACAO",
			                                                            "PROCURAÇÃO ELETRÔNICA",
			                                                            "PROCURACAO ELETRONICA",
			                                                            "FIM"
			                                                        }
			                                                )
			                                        )
			                                    )
			                        ),
			                        [__Passou], DESC,
			                        'JOBS_Produto'[NOME_TRIBUTO], ASC
			                    ),
			                    "<span class='detail-opp " & IF ( [__Passou] > 0, "passed", "open" ) & "'>"
			                        & 'JOBS_Produto'[NOME_TRIBUTO]
			                        & "<em>" & IF ( [__Passou] > 0, "passou", "disp." ) & "</em>"
			                    & "</span>",
			                    "",
			                    [__Passou], DESC
			                ),
			                "<span class='detail-opp open'>Sem oportunidades<em>disp.</em></span>"
			            )
			        RETURN
			            "<tr class='linha-detalhe' data-expanded='0'>"
			                & "<td class='td-job'><span class='expand-btn' onclick='toggleJob(this)' title='Expandir detalhes do job'>▶</span><span class='td-job-text'>" & 'JOBS_Produto'[JOB] & "</span></td>"
			                & "<td class='td-etapa'><span class='chip " & _etapaClass & "'>" & [__EtapaAtual] & "</span></td>"
			                & "<td class='td-acao'><span class='chip " & _acaoClass & "'>" & [__Acao] & "</span></td>"
			                & "<td class='td-cliente'>" & [__Cliente] & "</td>"
			                & "<td class='td-cnpj'>" & [__CNPJ] & "</td>"
			                & "<td class='td-produto'>" & [__Produto] & "<br><span style='color:var(--text-3);font-size:13px'>" & [__Subproduto] & "</span></td>"
			                & "<td class='td-ops'>" & [__OportunidadesLista] & "</td>"
			                & "<td class='num'>" & FORMAT ( [__OportDisp], vIntFormat ) & "</td>"
			                & "<td class='num'>" & FORMAT ( [__OportPass], vIntFormat ) & "</td>"
			                & "<td class='date-cell'>" & IF ( ISBLANK ( [__DataCadastro] ), "-", FORMAT ( [__DataCadastro], "dd/MM/yyyy" ) ) & "</td>"
			                & "<td class='date-cell'>" & IF ( ISBLANK ( [__UltimoMovimento] ), "-", FORMAT ( [__UltimoMovimento], "dd/MM/yyyy" ) ) & "</td>"
			                & "<td class='days'>" & FORMAT ( [__Dias], "#,##0" ) & "</td>"
			            & "</tr>"
			            & "<tr class='linha-extra'>"
			                & "<td colspan='12'>"
			                    & "<div class='job-extra-panel'>"
			                        & "<div class='job-extra-top'>"
			                            & "<div>"
			                                & "<div class='job-extra-title'>Job " & 'JOBS_Produto'[JOB] & " · " & [__Cliente] & "</div>"
			                                & "<div class='job-extra-subtitle'>CNPJ: " & [__CNPJ] & " · Produto: " & [__Produto] & " · Subproduto: " & [__Subproduto] & "</div>"
			                            & "</div>"
			                            & "<div class='job-extra-kpis'>"
			                                & "<span class='extra-pill warn'><strong>" & FORMAT ( _qtdLinhas, vIntFormat ) & "</strong> linhas</span>"
			                                & "<span class='extra-pill warn'><strong>" & FORMAT ( [__OportDisp], vIntFormat ) & "</strong> oportunidades</span>"
			                                & "<span class='extra-pill good'><strong>" & FORMAT ( [__OportPass], vIntFormat ) & "</strong> passaram</span>"
			                                & "<span class='extra-pill'><strong>" & FORMAT ( [__Dias], "#,##0" ) & "</strong> dias</span>"
			                            & "</div>"
			                        & "</div>"
			                        & "<div class='extra-grid'>"
			                            & "<div class='extra-card'><span>Etapa atual</span><b>" & [__EtapaAtual] & "</b></div>"
			                            & "<div class='extra-card'><span>Status</span><b>" & [__Status] & "</b></div>"
			                            & "<div class='extra-card'><span>Ação sugerida</span><b>" & [__Acao] & "</b></div>"
			                            & "<div class='extra-card'><span>Cadastro</span><b>" & IF ( ISBLANK ( [__DataCadastro] ), "-", FORMAT ( [__DataCadastro], "dd/MM/yyyy" ) ) & "</b></div>"
			                            & "<div class='extra-card'><span>Último movimento</span><b>" & IF ( ISBLANK ( [__UltimoMovimento] ), "-", FORMAT ( [__UltimoMovimento], "dd/MM/yyyy" ) ) & "</b></div>"
			                            & "<div class='extra-card'><span>Modelo produto</span><b>" & _modeloProduto & "</b></div>"
			                            & "<div class='extra-card'><span>Modelo negócio</span><b>" & _modeloNegocio & "</b></div>"
			                            & "<div class='extra-card'><span>Cliente</span><b>" & [__Cliente] & "</b></div>"
			                        & "</div>"
			                        & "<div class='extra-section'>"
			                            & "<div class='extra-section-title'>Distribuição de etapas dentro do job</div>"
			                            & "<div class='extra-chip-wrap'>" & _areasResumo & "</div>"
			                        & "</div>"
			                        & "<div class='extra-section'>"
			                            & "<div class='extra-section-title'>Oportunidades do job</div>"
			                            & "<div class='extra-chip-wrap'>" & _opsDetalhe & "</div>"
			                        & "</div>"
			& "</div>"
			                & "</td>"
			            & "</tr>",
			        "",
			        [__Status], ASC,
			        [__StageSort], ASC,
			        [__Dias], DESC,
			        [__DataCadastro], DESC
			    )
			
			VAR _avisoLimite =
			    IF (
			        _totalJobs > vLimiteLinhas,
			        " · exibindo " & FORMAT ( vLimiteLinhas, vIntFormat ) & " de " & FORMAT ( _totalJobs, vIntFormat ) & " jobs; use slicers para reduzir o recorte",
			        ""
			    )
			
			VAR _html =
			    "<html><head><meta charset='UTF-8'>" & _css & "</head><body>"
			        & "<div class='painel'>"
			            & "<div class='cabecalho'>"
			                & "<div class='cabecalho-esquerda'>"
			                    & "<button class='btn-voltar'>&#8592; Voltar</button>"
			                    & "<div class='titulo'>Detalhamento Diagnóstico - Journey</div>"
			                & "</div>"
			                & "<div class='controles'>"
			                    & "<input class='busca-global' id='buscaGlobal' type='text' placeholder='Busca nos jobs carregados: use slicers do Power BI para buscar na base completa...' oninput='filtrarTabela()'>"
			                    & "<button id='btnCopiar' class='btn-copiar' onclick='copiarTabela()' title='Copia a tabela filtrada para colar no Excel'>&#128203; Copiar tabela</button>"
			                & "</div>"
			            & "</div>"
			
			            & "<div class='resumo'>"
			                & "<div class='kpi primary'><span class='kpi-label'>Jobs listados</span><span class='kpi-value'>" & FORMAT ( _totalJobs, vIntFormat ) & "</span><span class='kpi-note'>Todo período" & _avisoLimite & "</span></div>"
			                & "<div class='kpi'><span class='kpi-label'>Ativos</span><span class='kpi-value'>" & FORMAT ( _jobsAtivos, vIntFormat ) & "</span><span class='kpi-note'>Ainda fora de FIM</span></div>"
			                & "<div class='kpi'><span class='kpi-label'>Finalizados</span><span class='kpi-value'>" & FORMAT ( _jobsFinalizados, vIntFormat ) & "</span><span class='kpi-note'>Todos em FIM</span></div>"
			                & "<div class='kpi'><span class='kpi-label'>Passaram etapa</span><span class='kpi-value'>" & FORMAT ( _jobsPassaram, vIntFormat ) & "</span><span class='kpi-note'>" & FORMAT ( _pctPassaram, vPctFormat ) & " da carteira</span></div>"
			                & "<div class='kpi'><span class='kpi-label'>Oport. disp.</span><span class='kpi-value'>" & FORMAT ( _oportDispTotal, vIntFormat ) & "</span><span class='kpi-note'>Distinto no período</span></div>"
			                & "<div class='kpi'><span class='kpi-label'>Oport. passaram</span><span class='kpi-value'>" & FORMAT ( _oportPassTotal, vIntFormat ) & "</span><span class='kpi-note'>Operação / Procuração / FIM</span></div>"
			            & "</div>"
			
			            & "<div class='table-wrapper'>"
			                & "<table class='tabela'>"
			                    & "<thead>"
			                        & "<tr>"
			                            & "<th style='width:9%'><div style='display:flex;flex-direction:column'><span>Job</span><input id='buscaColJob' class='col-filter' type='text' placeholder='Filtrar...' oninput='filtrarTabela()'></div></th>"
			                            & "<th style='width:8%'><div style='display:flex;flex-direction:column'><span>Etapa atual</span><input id='buscaColEtapa' class='col-filter' type='text' list='listaEtapas' placeholder='Buscar...' oninput='filtrarTabela()'><datalist id='listaEtapas'>" & _opcoesEtapa & "</datalist></div></th>"
			                            & "<th style='width:9%'><span>Ação sugerida</span></th>"
			                            & "<th style='width:15%'><div style='display:flex;flex-direction:column'><span>Cliente</span><input id='buscaColCliente' class='col-filter' type='text' placeholder='Filtrar...' oninput='filtrarTabela()'></div></th>"
			                            & "<th style='width:8%'><span>CNPJ</span></th>"
			                            & "<th style='width:14%'><div style='display:flex;flex-direction:column'><span>Produto / Subproduto</span><input id='buscaColProduto' class='col-filter' type='text' list='listaProdutos' placeholder='Filtrar...' oninput='filtrarTabela()'><datalist id='listaProdutos'>" & _opcoesProduto & "</datalist></div></th>"
			                            & "<th style='width:15%'><span>Oportunidades</span></th>"
			                            & "<th style='width:4%;text-align:center'><span>Disp.</span></th>"
			                            & "<th style='width:5%;text-align:center'><span>Passaram</span></th>"
			                            & "<th style='width:5%;text-align:center'><span>Cadastro</span></th>"
			                            & "<th style='width:5%;text-align:center'><span>Últ. mov.</span></th>"
			                            & "<th style='width:3%;text-align:center'><span>Dias</span></th>"
			                        & "</tr>"
			                    & "</thead>"
			                    & "<tbody id='tbodyDetalhe'>"
			                        & IF (
			                            ISBLANK ( _linhas ),
			                            "<tr><td colspan='12' class='empty'>Nenhum registro encontrado com os filtros atuais.</td></tr>",
			                            _linhas
			                        )
			                    & "</tbody>"
			                    & "<tfoot>"
			                        & "<tr>"
			                            & "<td colspan='12' style='text-align:right'>"
			                                & "Total visível após filtros: <span class='count-destaque' id='totalJobsCount'>0</span> de " & FORMAT ( _totalJobs, vIntFormat ) & " no período"
			                            & "</td>"
			                        & "</tr>"
			                    & "</tfoot>"
			                & "</table>"
			            & "</div>"
			        & "</div>"
			        & _js
			    & "</body></html>"
			
			RETURN
			    _html
			
			```
		displayFolder: 10 | HTML e Visual
		lineageTag: 7cc4cf4f-59eb-4360-8f7e-9a14c4534d03

	/// 01 BASE - Medidas fundamentais de contagem e periodo
	/// Contagem total de linhas da base de diagnostico no contexto atual.
	measure 'Diagnóstico | Registros' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS ( vBaseDiag )
			```
		displayFolder: 01 Base
		lineageTag: b0000101-d1ag-ba5e-b010-ba5e00000101

	/// Contagem distinta de jobs (JOB) na base de diagnostico no contexto atual.
	measure 'Diagnóstico | Jobs' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS ( SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[JOB] ) )
			```
		displayFolder: 01 Base
		lineageTag: b0000102-d1ag-ba5e-b010-ba5e00000102

	/// Contagem distinta de empresas (NOME_CLIENTE) na base de diagnostico.
	measure 'Diagnóstico | Empresas' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS (
				        SUMMARIZE (
				            FILTER ( vBaseDiag, NOT ISBLANK ( 'JOBS_Produto'[NOME_CLIENTE] ) ),
				            'JOBS_Produto'[NOME_CLIENTE]
				        )
				    )
			```
		displayFolder: 01 Base
		lineageTag: b0000103-d1ag-ba5e-b010-ba5e00000103

	/// Contagem distinta de CNPJs (CNPJ_CLIENTE) na base de diagnostico.
	measure 'Diagnóstico | CNPJs' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS (
				        SUMMARIZE (
				            FILTER ( vBaseDiag, NOT ISBLANK ( 'JOBS_Produto'[CNPJ_CLIENTE] ) ),
				            'JOBS_Produto'[CNPJ_CLIENTE]
				        )
				    )
			```
		displayFolder: 01 Base
		lineageTag: b0000104-d1ag-ba5e-b010-ba5e00000104

	/// Data mais antiga de cadastro na base de diagnostico no contexto atual.
	measure 'Diagnóstico | Período Inicial' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    MINX ( vBaseDiag, 'JOBS_Produto'[DATA_CADASTRO] )
			```
		displayFolder: 01 Base
		lineageTag: b0000105-d1ag-ba5e-b010-ba5e00000105

	/// Data mais recente de cadastro na base de diagnostico no contexto atual.
	measure 'Diagnóstico | Período Final' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    MAXX ( vBaseDiag, 'JOBS_Produto'[DATA_CADASTRO] )
			```
		displayFolder: 01 Base
		lineageTag: b0000106-d1ag-ba5e-b010-ba5e00000106

	/// Periodo formatado como texto (dd/mm/yyyy a dd/mm/yyyy).
	measure 'Diagnóstico | Período Texto' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				VAR vMinData = MINX ( vBaseDiag, 'JOBS_Produto'[DATA_CADASTRO] )
				VAR vMaxData = MAXX ( vBaseDiag, 'JOBS_Produto'[DATA_CADASTRO] )
				RETURN
				    IF (
				        ISBLANK ( vMinData ) || ISBLANK ( vMaxData ),
				        "Sem dados no periodo",
				        FORMAT ( vMinData, "dd/mm/yyyy" ) & " a " & FORMAT ( vMaxData, "dd/mm/yyyy" )
				    )
			```
		displayFolder: 01 Base
		lineageTag: b0000107-d1ag-ba5e-b010-ba5e00000107

	/// Data do ultimo movimento (TRIBUTO_DATA_ENTRADA) na base de diagnostico.
	measure 'Diagnóstico | Último Movimento' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    MAXX (
				        vBaseDiag,
				        COALESCE ( 'JOBS_Produto'[TRIBUTO_DATA_ENTRADA], 'JOBS_Produto'[DATA_CADASTRO] )
				    )
			```
		displayFolder: 01 Base
		lineageTag: b0000108-d1ag-ba5e-b010-ba5e00000108

	/// Indica se ha filtro ativo no calendario (slicer de data).
	measure 'Diagnóstico | Contexto Calendário' = ```
				VAR vHasCalendarFilter =
				    ISFILTERED ( 'dCalendar'[Date] )
				        || ISFILTERED ( 'dCalendar'[Year] )
				        || ISFILTERED ( 'dCalendar'[YearMonth] )
				        || ISFILTERED ( 'dCalendar'[YearMonthName] )
				        || ISFILTERED ( 'dCalendar'[QuarterName] )
				        || ISFILTERED ( 'dCalendar'[MonthName] )
				RETURN
				    IF ( vHasCalendarFilter, "Periodo filtrado pelo slicer", "Todo periodo" )
			```
		displayFolder: 01 Base
		lineageTag: b0000109-d1ag-ba5e-b010-ba5e00000109

	/// 02 STATUS JOBS - Medidas de status e etapa dos jobs
	/// Status detalhado dos jobs: tabela virtual com Stage e Status por job.
	/// Retorna 1 se houver jobs ativos, 0 caso contrario (medida auxiliar interna).
	measure 'Diagnóstico | Job Status Base' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS ( vBaseDiag )
			```
		displayFolder: 02 Status Jobs
		lineageTag: b0000200-d1ag-ba5e-b010-ba5e00000200

	/// Jobs ativos: possuem pelo menos uma linha fora de FIM.
	measure 'Diagnóstico | Jobs Ativos' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				VAR vJobStatusRaw =
				    ADDCOLUMNS (
				        SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[JOB] ),
				        "__OpenRows",
				            VAR vJobKey = 'JOBS_Produto'[JOB]
				            RETURN
				                COUNTROWS (
				                    FILTER (
				                        vBaseDiag,
				                        'JOBS_Produto'[JOB] = vJobKey
				                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) <> "FIM"
				                    )
				                ),
				        "__FimRows",
				            VAR vJobKey = 'JOBS_Produto'[JOB]
				            RETURN
				                COUNTROWS (
				                    FILTER (
				                        vBaseDiag,
				                        'JOBS_Produto'[JOB] = vJobKey
				                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) = "FIM"
				                    )
				                )
				    )
				VAR vJobStatus =
				    ADDCOLUMNS (
				        vJobStatusRaw,
				        "__Status",
				            IF (
				                [__OpenRows] = 0 && [__FimRows] > 0,
				                "Finalizado",
				                "Ativo"
				            )
				    )
				RETURN
				    COUNTROWS ( FILTER ( vJobStatus, [__Status] = "Ativo" ) )
			```
		displayFolder: 02 Status Jobs
		lineageTag: b0000201-d1ag-ba5e-b010-ba5e00000201

	/// Jobs finalizados: todas as linhas do job estao em FIM.
	measure 'Diagnóstico | Jobs Finalizados' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				VAR vJobStatusRaw =
				    ADDCOLUMNS (
				        SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[JOB] ),
				        "__OpenRows",
				            VAR vJobKey = 'JOBS_Produto'[JOB]
				            RETURN
				                COUNTROWS (
				                    FILTER (
				                        vBaseDiag,
				                        'JOBS_Produto'[JOB] = vJobKey
				                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) <> "FIM"
				                    )
				                ),
				        "__FimRows",
				            VAR vJobKey = 'JOBS_Produto'[JOB]
				            RETURN
				                COUNTROWS (
				                    FILTER (
				                        vBaseDiag,
				                        'JOBS_Produto'[JOB] = vJobKey
				                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) = "FIM"
				                    )
				                )
				    )
				VAR vJobStatus =
				    ADDCOLUMNS (
				        vJobStatusRaw,
				        "__Status",
				            IF (
				                [__OpenRows] = 0 && [__FimRows] > 0,
				                "Finalizado",
				                "Ativo"
				            )
				    )
				RETURN
				    COUNTROWS ( FILTER ( vJobStatus, [__Status] = "Finalizado" ) )
			```
		displayFolder: 02 Status Jobs
		lineageTag: b0000202-d1ag-ba5e-b010-ba5e00000202

	/// Jobs na etapa Checklist (etapa 1).
	measure 'Diagnóstico | Jobs Checklist' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				VAR vJobStatusRaw =
				    ADDCOLUMNS (
				        SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[JOB] ),
				        "__OpenRows",
				            VAR vJobKey = 'JOBS_Produto'[JOB]
				            RETURN
				                COUNTROWS (
				                    FILTER (
				                        vBaseDiag,
				                        'JOBS_Produto'[JOB] = vJobKey
				                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) <> "FIM"
				                    )
				                ),
				        "__FimRows",
				            VAR vJobKey = 'JOBS_Produto'[JOB]
				            RETURN
				                COUNTROWS (
				                    FILTER (
				                        vBaseDiag,
				                        'JOBS_Produto'[JOB] = vJobKey
				                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) = "FIM"
				                    )
				                ),
				        "__StageOpen",
				            VAR vJobKey = 'JOBS_Produto'[JOB]
				            RETURN
				                MAXX (
				                    FILTER (
				                        vBaseDiag,
				                        'JOBS_Produto'[JOB] = vJobKey
				                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) <> "FIM"
				                    ),
				                    VAR vArea = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
				                    RETURN
				                        SWITCH (
				                            TRUE (),
				                            vArea = "CHECKLIST", 1,
				                            vArea = "OPERAÇÃO", 2,
				                            vArea = "OPERACAO", 2,
				                            vArea = "PROCURAÇÃO ELETRÔNICA", 3,
				                            vArea = "PROCURACAO ELETRONICA", 3,
				                            0
				                        )
				                )
				    )
				VAR vJobStatus =
				    ADDCOLUMNS (
				        vJobStatusRaw,
				        "__Stage",
				            IF (
				                [__OpenRows] = 0 && [__FimRows] > 0,
				                4,
				                COALESCE ( [__StageOpen], 0 )
				            )
				    )
				RETURN
				    COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 1 ) )
			```
		displayFolder: 02 Status Jobs
		lineageTag: b0000203-d1ag-ba5e-b010-ba5e00000203

