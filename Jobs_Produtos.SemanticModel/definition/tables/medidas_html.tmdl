table medidas_html
	lineageTag: f371007f-daa0-4acf-919c-58dc35ff6b74

	/// Cabeçalho executivo da DRE Gerencial TAX.
	measure Titulo_Diagnostico_HTML_2026_Novo_Estilo_DOCUMENTACAO = ```
			
			VAR vYearFixed = YEAR ( TODAY () )
			VAR vDateFormat = "dd/mm/yyyy"
			
			VAR vBase2026 =
			    FILTER (
			        ALL ( 'JOBS_Produto' ),
			        NOT ISBLANK ( 'JOBS_Produto'[JOB] )
			            && YEAR ( 'JOBS_Produto'[DATA_CADASTRO] ) = vYearFixed
			            && CONTAINSSTRING (
			                UPPER ( COALESCE ( 'JOBS_Produto'[NOME_PRODUTO], "" ) ),
			                "DIAGN"
			            )
			    )
			
			VAR vCalendarFilterStart =
			    MIN ( dCalendar[Date] )
			
			VAR vCalendarFilterEnd =
			    MAX ( dCalendar[Date] )
			
			VAR vHasCalendarFilter =
			    ISFILTERED ( dCalendar[Date] )
			        || ISFILTERED ( dCalendar[YearMonth] )
			        || ISFILTERED ( dCalendar[MonthNumber] )
			        || ISFILTERED ( dCalendar[Quarter] )
			
			VAR vBaseContext =
			    FILTER (
			        vBase2026,
			        'JOBS_Produto'[DATA_CADASTRO]
			            >= IF (
			                vHasCalendarFilter,
			                vCalendarFilterStart,
			                DATE ( vYearFixed, 1, 1 )
			            )
			            && 'JOBS_Produto'[DATA_CADASTRO]
			                <= IF (
			                    vHasCalendarFilter,
			                    vCalendarFilterEnd,
			                    DATE ( vYearFixed, 12, 31 )
			                )
			    )
			
			VAR vMinData =
			    MINX ( vBaseContext, 'JOBS_Produto'[DATA_CADASTRO] )
			
			VAR vMaxData =
			    MAXX ( vBaseContext, 'JOBS_Produto'[DATA_CADASTRO] )
			
			VAR vUltimoMovimento =
			    MAXX ( vBaseContext, 'JOBS_Produto'[TRIBUTO_DATA_ENTRADA] )
			
			VAR vPeriodo =
			    IF (
			        ISBLANK ( vMinData ) || ISBLANK ( vMaxData ),
			        "Período não definido",
			        FORMAT ( vMinData, vDateFormat ) & " a " & FORMAT ( vMaxData, vDateFormat )
			    )
			
			VAR vUltimoMovimentoTxt =
			    IF (
			        ISBLANK ( vUltimoMovimento ),
			        "Sem data",
			        FORMAT ( vUltimoMovimento, vDateFormat )
			    )
			
			VAR vDataAtual =
			    FORMAT ( NOW (), "dd/mm/yyyy HH:mm" )
			
			VAR vCSS =
			"
			<style>
			    * {
			        margin: 0;
			        padding: 0;
			        box-sizing: border-box;
			    }
			
			    .diag-title-shell {
			        width: 1910px;
			        min-width: 1910px;
			        max-width: 1910px;
			        height: 165px;
			        min-height: 165px;
			        max-height: 165px;
			        overflow: hidden;
			        font-family: 'Segoe UI', Arial, sans-serif;
			        color: #E8EEF5;
			        border-radius: 18px;
			        border: 1px solid rgba(213,174,119,.36);
			        background:
			            radial-gradient(circle at 0% 0%, rgba(213,174,119,.22), transparent 33%),
			            radial-gradient(circle at 92% 18%, rgba(139,224,209,.13), transparent 28%),
			            linear-gradient(135deg, #060B10 0%, #0B141B 46%, #10201F 100%);
			        box-shadow:
			            0 16px 38px rgba(0,0,0,.50),
			            inset 0 1px 0 rgba(255,255,255,.05);
			        position: relative;
			    }
			
			    .diag-title-shell:before {
			        content: '';
			        position: absolute;
			        left: 0;
			        top: 0;
			        bottom: 0;
			        width: 8px;
			        background: linear-gradient(180deg,#F4D9A9,#D5AE77,#8BE0D1);
			        opacity: .92;
			    }
			
			    .diag-title-grid {
			        position: relative;
			        z-index: 2;
			        width: 100%;
			        height: 100%;
			        display: grid;
			        grid-template-columns: 150px minmax(0,1fr) 430px;
			        align-items: center;
			        gap: 24px;
			        padding: 18px 26px 18px 34px;
			    }
			
			    .brand-panel {
			        height: 100%;
			        min-width: 0;
			        display: flex;
			        align-items: center;
			        justify-content: center;
			    }
			
			    .logo-card {
			        width: 118px;
			        height: 82px;
			        border-radius: 16px;
			        display: flex;
			        align-items: center;
			        justify-content: center;
			        padding: 10px;
			        background:
			            radial-gradient(circle at 28% 12%, rgba(213,174,119,.18), transparent 36%),
			            #030506;
			        border: 1px solid rgba(213,174,119,.40);
			        box-shadow:
			            0 12px 24px rgba(0,0,0,.34),
			            inset 0 1px 0 rgba(255,255,255,.06);
			        overflow: hidden;
			    }
			
			    .logo-text {
			        width: 100%;
			        height: 100%;
			        display: flex;
			        align-items: center;
			        justify-content: center;
			        gap: 0;
			        color: #FFFFFF;
			        font-family: Georgia, 'Times New Roman', serif;
			        font-size: 13px;
			        font-weight: 700;
			        line-height: 1;
			        letter-spacing: -0.05em;
			        text-align: center;
			        white-space: nowrap;
			        overflow: hidden;
			    }
			
			    .logo-text .studio {
			        color: #D5AE77;
			        margin-left: 1px;
			    }
			
			    .center-panel {
			        min-width: 0;
			        height: 100%;
			        display: flex;
			        flex-direction: column;
			        align-items: center;
			        justify-content: center;
			        gap: 8px;
			        text-align: center;
			        position: relative;
			    }
			
			    .center-panel:before,
			    .center-panel:after {
			        content: '';
			        width: 88px;
			        height: 1px;
			        background: linear-gradient(
			            90deg,
			            transparent,
			            rgba(213,174,119,.65),
			            transparent
			        );
			    }
			
			    .title-kicker {
			        color: #8BE0D1;
			        font-size: 10px;
			        font-weight: 950;
			        letter-spacing: .22em;
			        text-transform: uppercase;
			        line-height: 1;
			        white-space: nowrap;
			    }
			
			    .main-title {
			        color: #FFFFFF;
			        font-size: 38px;
			        font-weight: 950;
			        letter-spacing: .09em;
			        text-transform: uppercase;
			        line-height: 1;
			        white-space: nowrap;
			        overflow: hidden;
			        text-overflow: ellipsis;
			        text-shadow: 0 4px 16px rgba(0,0,0,.72);
			    }
			
			    .main-title .gold {
			        color: #F4D9A9;
			    }
			
			    .subline {
			        max-width: 100%;
			        color: #D5AE77;
			        font-size: 11px;
			        font-weight: 950;
			        letter-spacing: .10em;
			        text-transform: uppercase;
			        white-space: nowrap;
			        overflow: hidden;
			        text-overflow: ellipsis;
			    }
			
			    .right-panel {
			        height: 100%;
			        display: grid;
			        grid-template-columns: 168px minmax(0,1fr) 68px;
			        align-items: center;
			        gap: 14px;
			        min-width: 0;
			    }
			
			    .doc-title-button {
			        position: relative;
			        min-height: 44px;
			        display: inline-flex;
			        align-items: center;
			        justify-content: center;
			        padding: 12px 17px;
			        border-radius: 14px;
			        color: #081018;
			        border: 1px solid rgba(244,217,169,.72);
			        background: linear-gradient(135deg,#F4D9A9 0%,#D5AE77 48%,#8BE0D1 100%);
			        box-shadow:
			            0 14px 28px rgba(213,174,119,.24),
			            0 0 0 1px rgba(255,255,255,.08) inset,
			            0 0 22px rgba(139,224,209,.18);
			        font-size: 11px;
			        font-weight: 950;
			        letter-spacing: .10em;
			        text-transform: uppercase;
			        white-space: nowrap;
			        overflow: hidden;
			    }
			
			    .doc-title-button:before {
			        content: 'i';
			        display: inline-flex;
			        align-items: center;
			        justify-content: center;
			        width: 21px;
			        height: 21px;
			        margin-right: 8px;
			        border-radius: 50%;
			        background: rgba(8,16,24,.18);
			        border: 1px solid rgba(8,16,24,.24);
			        color: #081018;
			        font-size: 12px;
			        font-weight: 950;
			        font-style: italic;
			        line-height: 1;
			    }
			
			    .doc-title-button:after {
			        content: '';
			        position: absolute;
			        inset: -1px;
			        border-radius: 14px;
			        background: linear-gradient(90deg, transparent, rgba(255,255,255,.45), transparent);
			        transform: translateX(-125%);
			        animation: shineDoc 3.8s ease-in-out infinite;
			    }
			
			    @keyframes shineDoc {
			        0% { transform: translateX(-125%); }
			        48% { transform: translateX(-125%); }
			        72% { transform: translateX(125%); }
			        100% { transform: translateX(125%); }
			    }
			
			    .update-box {
			        display: flex;
			        flex-direction: column;
			        align-items: flex-end;
			        justify-content: center;
			        gap: 10px;
			        min-width: 0;
			    }
			
			    .update-line {
			        display: flex;
			        flex-direction: column;
			        align-items: flex-end;
			        gap: 3px;
			        min-width: 0;
			    }
			
			    .update-label {
			        color: #F4D9A9;
			        font-size: 9px;
			        font-weight: 950;
			        letter-spacing: .08em;
			        text-transform: uppercase;
			        white-space: nowrap;
			    }
			
			    .update-value {
			        color: #E8EEF5;
			        font-size: 12px;
			        font-weight: 900;
			        white-space: nowrap;
			        overflow: hidden;
			        text-overflow: ellipsis;
			        max-width: 160px;
			        text-align: right;
			    }
			
			    .avatar {
			        position: relative;
			        width: 62px;
			        height: 62px;
			        border-radius: 50%;
			        display: flex;
			        align-items: center;
			        justify-content: center;
			        color: #F4D9A9;
			        font-size: 18px;
			        font-weight: 950;
			        letter-spacing: .05em;
			        background:
			            linear-gradient(
			                145deg,
			                rgba(213,174,119,.14),
			                rgba(255,255,255,.035)
			            );
			        border: 1px solid rgba(213,174,119,.58);
			        box-shadow:
			            0 0 0 5px rgba(213,174,119,.06),
			            inset 0 1px 0 rgba(255,255,255,.10);
			    }
			
			    .avatar:after {
			        content: '';
			        position: absolute;
			        right: 2px;
			        bottom: 5px;
			        width: 9px;
			        height: 9px;
			        border-radius: 50%;
			        background: #21E66D;
			        box-shadow: 0 0 12px rgba(33,230,109,.75);
			        border: 2px solid #10201F;
			    }
			</style>
			"
			
			VAR vHTML =
			    "<div class='diag-title-shell'>"
			        & "<div class='diag-title-grid'>"
			
			            & "<div class='brand-panel'>"
			                & "<div class='logo-card'>"
			                    & "<div class='logo-text'>"
			                        & "<span>GRUPO</span><span class='studio'>STUDIO</span>"
			                    & "</div>"
			                & "</div>"
			            & "</div>"
			
			            & "<div class='center-panel'>"
			                & "<div class='title-kicker'>Grupo Studio · Monitoramento Operacional</div>"
			                & "<div class='main-title'>Diagnóstico <span class='gold'>- Journey</span></div>"
			                & "<div class='subline'>"
			                    & "Etapas, status e oportunidades | "
			                    & vPeriodo
			                & "</div>"
			            & "</div>"
			
			            & "<div class='right-panel'>"
			                & "<div class='doc-title-button'>Documentação</div>"
			                & "<div class='update-box'>"
			                    & "<div class='update-line'>"
			                        & "<span class='update-label'>Atualizado em</span>"
			                        & "<span class='update-value'>" & vDataAtual & "</span>"
			                    & "</div>"
			                    & "<div class='update-line'>"
			                        & "<span class='update-label'>Último movimento</span>"
			                        & "<span class='update-value'>" & vUltimoMovimentoTxt & "</span>"
			                    & "</div>"
			                & "</div>"
			                & "<div class='avatar'>GS</div>"
			            & "</div>"
			
			        & "</div>"
			    & "</div>"
			
			RETURN
			    vCSS & vHTML
			
			```
		displayFolder: 10 | HTML e Visual
		lineageTag: c4874ca8-7357-4c3e-b3e5-6180c4491f86

	/// Documentacao executiva e tecnica atualizada da DRE Gerencial TAX. Reflete a primeira aba atual: 4 cards premium, periodo dinamico, linhas, expansoes, regras oficiais, IRPJ/CSLL informativo e pontos de atencao.
	measure DOCUMENTACAO_DIAGNOSTICO_JOURNEY_HTML_V4_FORMAL_TODO_PERIODO = ```
			VAR vIntFormat = "#,##0"
						VAR vPctFormat = "0.0%"
						VAR vDateFormat = "dd/mm/yyyy"
						VAR vAtualizadoEm = FORMAT ( NOW (), "dd/mm/yyyy HH:mm" )
						
						VAR vBaseJourney = 'JOBS_Produto'
						
						VAR vJobStatusRaw =
						    ADDCOLUMNS (
						        SUMMARIZE ( vBaseJourney, 'JOBS_Produto'[JOB] ),
						        "__OpenRows",
						            VAR vJobKey = 'JOBS_Produto'[JOB]
						            RETURN
						                COUNTROWS (
						                    FILTER (
						                        vBaseJourney,
						                        'JOBS_Produto'[JOB] = vJobKey
						                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) <> "FIM"
						                    )
						                ),
						        "__FimRows",
						            VAR vJobKey = 'JOBS_Produto'[JOB]
						            RETURN
						                COUNTROWS (
						                    FILTER (
						                        vBaseJourney,
						                        'JOBS_Produto'[JOB] = vJobKey
						                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) = "FIM"
						                    )
						                ),
						        "__StageOpen",
						            VAR vJobKey = 'JOBS_Produto'[JOB]
						            RETURN
						                MAXX (
						                    FILTER (
						                        vBaseJourney,
						                        'JOBS_Produto'[JOB] = vJobKey
						                            && UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) ) <> "FIM"
						                    ),
						                    VAR vArea = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
						                    RETURN
						                        SWITCH (
						                            TRUE (),
						                            vArea = "CHECKLIST", 1,
						                            vArea = "OPERAÇÃO", 2,
						                            vArea = "OPERACAO", 2,
						                            vArea = "PROCURAÇÃO ELETRÔNICA", 3,
						                            vArea = "PROCURACAO ELETRONICA", 3,
						                            0
						                        )
						                )
						    )
						
						VAR vJobStatus =
						    ADDCOLUMNS (
						        vJobStatusRaw,
						        "__Stage",
						            IF (
						                [__OpenRows] = 0 && [__FimRows] > 0,
						                4,
						                COALESCE ( [__StageOpen], 0 )
						            ),
						        "__Status",
						            IF (
						                [__OpenRows] = 0 && [__FimRows] > 0,
						                "Finalizado",
						                "Ativo"
						            )
						    )
						
						VAR vRegistros = COUNTROWS ( vBaseJourney )
						VAR vJobs = COUNTROWS ( vJobStatus )
						VAR vJobsAtivos = COUNTROWS ( FILTER ( vJobStatus, [__Status] = "Ativo" ) )
						VAR vJobsFinalizados = COUNTROWS ( FILTER ( vJobStatus, [__Status] = "Finalizado" ) )
						VAR vJobsChecklist = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 1 ) )
						VAR vJobsOperacao = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 2 ) )
						VAR vJobsProcuracao = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 3 ) )
						VAR vJobsFim = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 4 ) )
						VAR vJobsSemEtapa = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 0 ) )
						VAR vJobsPassaram = COUNTROWS ( FILTER ( vJobStatus, [__Stage] >= 2 ) )
						
						VAR vClientes =
						    COUNTROWS (
						        SUMMARIZE (
						            FILTER ( vBaseJourney, NOT ISBLANK ( 'JOBS_Produto'[NOME_CLIENTE] ) ),
						            'JOBS_Produto'[NOME_CLIENTE]
						        )
						    )
						
						VAR vCNPJs =
						    COUNTROWS (
						        SUMMARIZE (
						            FILTER ( vBaseJourney, NOT ISBLANK ( 'JOBS_Produto'[CNPJ_CLIENTE] ) ),
						            'JOBS_Produto'[CNPJ_CLIENTE]
						        )
						    )
						
						VAR vCNPJBlank =
						    COUNTROWS (
						        FILTER ( vBaseJourney, ISBLANK ( 'JOBS_Produto'[CNPJ_CLIENTE] ) )
						    )
						
						VAR vProdutos =
						    COUNTROWS (
						        SUMMARIZE (
						            FILTER ( vBaseJourney, NOT ISBLANK ( 'JOBS_Produto'[NOME_PRODUTO] ) ),
						            'JOBS_Produto'[NOME_PRODUTO]
						        )
						    )
						
						VAR vSubprodutos =
						    COUNTROWS (
						        SUMMARIZE (
						            FILTER ( vBaseJourney, NOT ISBLANK ( 'JOBS_Produto'[NOME_SUBPRODUTO] ) ),
						            'JOBS_Produto'[NOME_SUBPRODUTO]
						        )
						    )
						
						VAR vOportunidadesDisp =
						    COUNTROWS (
						        SUMMARIZE (
						            FILTER ( vBaseJourney, NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] ) ),
						            'JOBS_Produto'[NOME_TRIBUTO]
						        )
						    )
						
						VAR vOportunidadesPass =
						    COUNTROWS (
						        SUMMARIZE (
						            FILTER (
						                vBaseJourney,
						                NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] )
						                    && (
						                        VAR vAreaPass = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
						                        RETURN
						                            vAreaPass IN {
						                                "OPERAÇÃO",
						                                "OPERACAO",
						                                "PROCURAÇÃO ELETRÔNICA",
						                                "PROCURACAO ELETRONICA",
						                                "FIM"
						                            }
						                    )
						            ),
						            'JOBS_Produto'[NOME_TRIBUTO]
						        )
						    )
						
						VAR vPctAtivo = DIVIDE ( vJobsAtivos, vJobs , 0 )
						VAR vPctFinalizado = DIVIDE ( vJobsFinalizados, vJobs , 0 )
						VAR vPctPassaram = DIVIDE ( vJobsPassaram, vJobs , 0 )
						VAR vPctOportPass = DIVIDE ( vOportunidadesPass, vOportunidadesDisp , 0 )
						VAR vPctCNPJBlank = DIVIDE ( vCNPJBlank, vRegistros , 0 )
						VAR vDiasMed = MEDIANX ( vBaseJourney, 'JOBS_Produto'[DIAS] )
						
						VAR vMinCadastro = MINX ( vBaseJourney, 'JOBS_Produto'[DATA_CADASTRO] )
						VAR vMaxCadastro = MAXX ( vBaseJourney, 'JOBS_Produto'[DATA_CADASTRO] )
						VAR vUltimoMovimento =
						    MAXX (
						        vBaseJourney,
						        COALESCE ( 'JOBS_Produto'[TRIBUTO_DATA_ENTRADA], 'JOBS_Produto'[DATA_CADASTRO] )
						    )
						
						VAR vPeriodo =
						    IF (
						        ISBLANK ( vMinCadastro ) || ISBLANK ( vMaxCadastro ),
						        "Todo período",
						        FORMAT ( vMinCadastro, "mmm/yyyy" ) & " a " & FORMAT ( vMaxCadastro, "mmm/yyyy" )
						    )
						
						VAR vUltimoMovimentoTxt =
						    IF (
						        ISBLANK ( vUltimoMovimento ),
						        "Sem registros",
						        FORMAT ( vUltimoMovimento, "dd/MM/yyyy" )
						    )
						
						VAR vStatusExecutivo =
						    SWITCH (
						        TRUE (),
						        vPctPassaram >= 0.70, "Excelente",
						        vPctPassaram >= 0.50, "Bom",
						        vPctPassaram >= 0.30, "Atenção",
						        "Crítico"
						    )
						
						VAR vRiscoTexto =
						    SWITCH (
						        TRUE (),
						        vPctPassaram >= 0.70, "Carteira com alto índice de avanço operacional. Excelente saúde operacional.",
						        vPctPassaram >= 0.50, "Mais da metade dos jobs avançaram para execução. Ritmo adequado.",
						        vPctPassaram >= 0.30, "Necessário acelerar avanço de etapas iniciais (Checklist).",
						        "Gargalo severo identificado nas etapas iniciais. Risco de atraso nas entregas."
						    )
						
						VAR vStageTable =
						    UNION (
						        ROW ( "Ordem", 1, "Etapa", "Checklist", "Qtd", vJobsChecklist, "Pct", DIVIDE ( vJobsChecklist, vJobs, 0 ), "Cor", "warn" ),
						        ROW ( "Ordem", 2, "Etapa", "Operação", "Qtd", vJobsOperacao, "Pct", DIVIDE ( vJobsOperacao, vJobs, 0 ), "Cor", "good" ),
						        ROW ( "Ordem", 3, "Etapa", "Procuração Eletrônica", "Qtd", vJobsProcuracao, "Pct", DIVIDE ( vJobsProcuracao, vJobs, 0 ), "Cor", "info" ),
						        ROW ( "Ordem", 4, "Etapa", "Fim (Finalizados)", "Qtd", vJobsFim, "Pct", DIVIDE ( vJobsFim, vJobs, 0 ), "Cor", "good" ),
						        ROW ( "Ordem", 5, "Etapa", "Sem etapa mapeada", "Qtd", vJobsSemEtapa, "Pct", DIVIDE ( vJobsSemEtapa, vJobs, 0 ), "Cor", "bad" )
						    )
						
						VAR vStageHTML =
						    CONCATENATEX (
						        vStageTable,
						        VAR vBar = MAX ( 2, ROUND ( COALESCE ( [Pct], 0 ) * 100, 0 ) )
						        RETURN
						            "<div class='stage-line " & [Cor] & "'>"
						                & "<div class='stage-name'>" & [Etapa] & "</div>"
						                & "<div class='stage-bar'><span style='width:" & FORMAT ( vBar, "0" ) & "%'></span></div>"
						                & "<div class='stage-qtd'>" & FORMAT ( [Qtd], vIntFormat ) & "</div>"
						                & "<div class='stage-pct'>" & FORMAT ( [Pct], vPctFormat ) & "</div>"
						            & "</div>",
						        "",
						        [Ordem], ASC
						    )
			
						VAR vHonorariosEncontrados =
						    SUMX (
						        SUMMARIZE ( vBaseJourney, 'JOBS_Produto'[JOB] ),
						        CALCULATE ( MAX ( 'JOBS_Produto'[JOB_HONORARIOS_ENCONTRADOS] ) )
						    )
						VAR vHonorariosAgendados =
						    SUMX (
						        SUMMARIZE ( vBaseJourney, 'JOBS_Produto'[JOB] ),
						        CALCULATE ( MAX ( 'JOBS_Produto'[JOB_HONORARIOS_AGENDADOS] ) )
						    )
						VAR vPctHonorariosAgendados =
						    DIVIDE ( vHonorariosAgendados, vHonorariosEncontrados, 0 )
						
						VAR vCSS =
						"
						<style>
						.doc-page{
						    width:1910px;
						    height:1070px;
						    box-sizing:border-box;
						    padding:20px;
						    font-family:'Segoe UI',Arial,sans-serif;
						    background:
						        radial-gradient(circle at 0% 0%,rgba(213,174,119,.18),transparent 32%),
						        radial-gradient(circle at 94% 7%,rgba(139,224,209,.12),transparent 30%),
						        linear-gradient(180deg,#101923 0%,#0B1219 100%);
						    color:#E8EEF5;
						    overflow:hidden;
						}
						.doc-shell{
						    width:100%;
						    height:100%;
						    display:grid;
						    grid-template-columns:390px 1fr;
						    gap:16px;
						}
						.doc-sidebar{
						    height:100%;
						    box-sizing:border-box;
						    border-radius:20px;
						    border:1px solid rgba(213,174,119,.28);
						    background:linear-gradient(180deg,rgba(213,174,119,.15),rgba(255,255,255,.025));
						    box-shadow:0 18px 42px rgba(0,0,0,.34),inset 0 1px 0 rgba(255,255,255,.05);
						    padding:24px 20px 20px;
						    overflow-y:auto;
						    overflow-x:hidden;
						    scrollbar-width:none;
						    position:relative;
						}
						.doc-sidebar::-webkit-scrollbar{display:none}
						.doc-sidebar:before{
						    content:'';
						    position:absolute;
						    left:0;
						    top:0;
						    bottom:0;
						    width:7px;
						    background:linear-gradient(180deg,#F4D9A9,#D5AE77,#8BE0D1);
						}
						.brand-kicker{
						    font-size:12.5px;
						    text-transform:uppercase;
						    letter-spacing:1.7px;
						    color:#8BE0D1;
						    font-weight:950;
						    margin-bottom:10px;
						}
						.brand-title{
						    color:#F4D9A9;
						    font-size:37.5px;
						    line-height:1.02;
						    font-weight:950;
						    letter-spacing:.02em;
						    margin-bottom:10px;
						    text-transform:uppercase;
						    text-shadow:0 8px 18px rgba(0,0,0,.35);
						}
						.brand-sub{
						    font-size:15.6px;
						    line-height:1.48;
						    color:#B7C2CD;
						    margin-bottom:14px;
						}
						.side-card{
						    border:1px solid rgba(255,255,255,.09);
						    background:rgba(255,255,255,.04);
						    border-radius:15px;
						    padding:12px;
						    margin-bottom:10px;
						}
						.side-card.highlight{
						    background:linear-gradient(135deg,rgba(213,174,119,.17),rgba(255,255,255,.035));
						    border-color:rgba(213,174,119,.30);
						}
						.side-label{
						    display:block;
						    font-size:11.9px;
						    color:#8796A5;
						    text-transform:uppercase;
						    letter-spacing:.85px;
						    font-weight:950;
						    margin-bottom:5px;
						}
						.side-value{
						    display:block;
						    font-size:17.5px;
						    color:#F0F5FA;
						    font-weight:900;
						    line-height:1.25;
						}
						.side-value.big{
						    color:#F4D9A9;
						    font-size:27.5px;
						}
						.side-small{
						    color:#AEB8C2;
						    font-size:13.4px;
						    line-height:1.4;
						    margin-top:5px;
						}
						.nav-title{
						    margin-top:14px;
						    margin-bottom:9px;
						    font-size:12.5px;
						    text-transform:uppercase;
						    letter-spacing:.95px;
						    color:#D5AE77;
						    font-weight:950;
						}
						.nav-list{
						    display:flex;
						    flex-direction:column;
						    gap:6px;
						}
						.nav-pill{
						    font-size:13.5px;
						    color:#DCE5EE;
						    border:1px solid rgba(213,174,119,.16);
						    background:rgba(255,255,255,.04);
						    border-radius:999px;
						    padding:7px 10px;
						    font-weight:850;
						    line-height:1;
						}
						.nav-pill.active{
						    color:#8BE0D1;
						    border-color:rgba(139,224,209,.30);
						    background:rgba(139,224,209,.08);
						}
						.doc-main{
						    height:100%;
						    background:linear-gradient(180deg,#121C25 0%,#0D151D 100%);
						    border:1px solid rgba(213,174,119,.20);
						    border-radius:20px;
						    box-shadow:0 18px 42px rgba(0,0,0,.34),inset 0 1px 0 rgba(255,255,255,.05);
						    overflow:hidden;
						    display:flex;
						    flex-direction:column;
						}
						.doc-header{
						    padding:17px 20px 15px;
						    border-bottom:1px solid rgba(213,174,119,.16);
						    display:flex;
						    align-items:flex-start;
						    justify-content:space-between;
						    gap:18px;
						    background:linear-gradient(90deg,rgba(255,255,255,.03),rgba(213,174,119,.035));
						}
						.doc-header h1{
						    margin:0;
						    color:#F4D9A9;
						    font-size:33.8px;
						    line-height:1.08;
						    font-weight:950;
						    letter-spacing:.3px;
						    text-transform:uppercase;
						}
						.doc-header p{
						    margin:7px 0 0;
						    color:#B7C2CD;
						    font-size:16px;
						    line-height:1.4;
						    max-width:1120px;
						}
						.doc-actions{
						    display:flex;
						    flex-direction:column;
						    align-items:flex-end;
						    gap:9px;
						    flex-shrink:0;
						}
						.back-report-fake{
						    display:inline-flex;
						    align-items:center;
						    justify-content:center;
						    gap:8px;
						    min-height:36px;
						    padding:9px 15px;
						    border-radius:999px;
						    background:linear-gradient(135deg,rgba(213,174,119,.18),rgba(139,224,209,.10));
						    border:1px solid rgba(213,174,119,.38);
						    color:#F4D9A9;
						    font-size:13.1px;
						    font-weight:950;
						    letter-spacing:.65px;
						    text-transform:uppercase;
						    white-space:nowrap;
						    box-shadow:0 10px 22px rgba(213,174,119,.10),inset 0 1px 0 rgba(255,255,255,.07);
						}
						.back-report-fake:before{
						    content:'←';
						    width:18px;
						    height:18px;
						    display:inline-flex;
						    align-items:center;
						    justify-content:center;
						    border-radius:50%;
						    background:rgba(213,174,119,.14);
						    border:1px solid rgba(213,174,119,.34);
						    color:#8BE0D1;
						    font-size:15px;
						    font-weight:950;
						    line-height:1;
						}
						.badge-wrap{
						    display:flex;
						    justify-content:flex-end;
						    align-items:center;
						    flex-wrap:wrap;
						    gap:6px;
						}
						.badge{
						    display:inline-flex;
						    border-radius:999px;
						    border:1px solid rgba(213,174,119,.30);
						    background:rgba(213,174,119,.08);
						    color:#F4D9A9;
						    font-size:12.5px;
						    font-weight:950;
						    text-transform:uppercase;
						    letter-spacing:.6px;
						    padding:5px 10px;
						    white-space:nowrap;
						}
						.badge.teal{
						    color:#8BE0D1;
						    border-color:rgba(139,224,209,.34);
						    background:rgba(139,224,209,.08);
						}
						.doc-scroll{
						    flex:1 1 auto;
						    min-height:0;
						    overflow-y:auto;
						    overflow-x:hidden;
						    padding:18px 20px 20px;
						    box-sizing:border-box;
						    scrollbar-width:thin;
						    scrollbar-color:rgba(213,174,119,.60) rgba(8,14,20,.95);
						}
						.doc-scroll::-webkit-scrollbar{width:12px}
						.doc-scroll::-webkit-scrollbar-track{
						    background:rgba(8,14,20,.96);
						    border-left:1px solid rgba(213,174,119,.10);
						}
						.doc-scroll::-webkit-scrollbar-thumb{
						    background:linear-gradient(180deg,rgba(213,174,119,.78),rgba(109,84,51,.86));
						    border:3px solid rgba(8,14,20,.96);
						    border-radius:999px;
						}
						.metric-grid{
						    display:grid;
						    grid-template-columns:repeat(6,1fr);
						    gap:11px;
						    margin-bottom:14px;
						}
						.metric{
						    position:relative;
						    min-height:124px;
						    padding:15px 13px 13px;
						    border-radius:18px;
						    background:linear-gradient(160deg,rgba(18,28,37,.96),rgba(11,18,25,.94));
						    border:1px solid rgba(255,255,255,.10);
						    box-shadow:0 16px 28px rgba(0,0,0,.22),inset 0 1px 0 rgba(255,255,255,.06);
						    overflow:hidden;
						}
						.metric:before{
						    content:'';
						    position:absolute;
						    left:14px;
						    top:0;
						    width:42px;
						    height:4px;
						    border-radius:0 0 10px 10px;
						    background:linear-gradient(90deg,#F4D9A9,#8BE0D1);
						}
						.metric.primary{
						    background:linear-gradient(155deg,rgba(213,174,119,.20),rgba(18,28,37,.96) 36%,rgba(11,18,25,.96));
						    border-color:rgba(213,174,119,.40);
						}
						.metric.attention{
						    background:linear-gradient(155deg,rgba(139,224,209,.08),rgba(18,28,37,.96) 34%,rgba(11,18,25,.96));
						    border-color:rgba(139,224,209,.30);
						}
						.m-label{
						    display:block;
						    color:#AEB9C4;
						    font-size:12.5px;
						    letter-spacing:.08em;
						    text-transform:uppercase;
						    font-weight:950;
						    margin-bottom:8px;
						}
						.m-value{
						    display:block;
						    color:#F4D9A9;
						    font-size:32.5px;
						    font-weight:950;
						    line-height:1.05;
						    white-space:nowrap;
						    overflow:hidden;
						    text-overflow:ellipsis;
						}
						.m-note{
						    display:block;
						    color:#8B98A6;
						    font-size:13.8px;
						    line-height:1.28;
						    margin-top:7px;
						    font-weight:850;
						}
						.insight-strip{
						    display:grid;
						    grid-template-columns:repeat(4,1fr);
						    gap:10px;
						    margin-bottom:14px;
						}
						.insight{
						    border-radius:14px;
						    border:1px solid rgba(255,255,255,.09);
						    background:rgba(255,255,255,.035);
						    padding:11px 12px;
						    border-left:4px solid rgba(174,185,196,.48);
						}
						.insight.good{border-left-color:#8BE0D1}
						.insight.warn{border-left-color:#F4D9A9}
						.insight.bad{border-left-color:#FFB0A8}
						.insight-label{
						    display:block;
						    color:#8796A5;
						    font-size:11.9px;
						    font-weight:950;
						    letter-spacing:.08em;
						    text-transform:uppercase;
						    margin-bottom:5px;
						}
						.insight-text{
						    display:block;
						    color:#DCE5EE;
						    font-size:14.1px;
						    font-weight:850;
						    line-height:1.32;
						}
						.doc-section{
						    border:1px solid rgba(213,174,119,.19);
						    background:rgba(255,255,255,.027);
						    border-radius:17px;
						    margin-bottom:12px;
						    overflow:hidden;
						}
						.doc-section summary{
						    cursor:pointer;
						    list-style:none;
						    display:flex;
						    align-items:center;
						    justify-content:space-between;
						    gap:12px;
						    padding:14px 15px;
						    background:linear-gradient(90deg,rgba(213,174,119,.17),rgba(213,174,119,.035));
						    border-bottom:1px solid rgba(213,174,119,.13);
						}
						.doc-section summary::-webkit-details-marker{display:none}
						.summary-left{
						    display:flex;
						    align-items:center;
						    gap:10px;
						    min-width:0;
						}
						.summary-index{
						    display:inline-flex;
						    align-items:center;
						    justify-content:center;
						    width:28px;
						    height:28px;
						    border-radius:50%;
						    background:rgba(213,174,119,.19);
						    border:1px solid rgba(213,174,119,.30);
						    color:#F4D9A9;
						    font-size:12.5px;
						    font-weight:950;
						}
						.summary-title{
						    color:#F4D9A9;
						    font-size:17.5px;
						    font-weight:950;
						    text-transform:uppercase;
						    letter-spacing:.45px;
						}
						.summary-action{
						    color:#B7C2CD;
						    font-size:12.2px;
						    font-weight:950;
						    text-transform:uppercase;
						    letter-spacing:.5px;
						    border:1px solid rgba(255,255,255,.10);
						    background:rgba(255,255,255,.04);
						    border-radius:999px;
						    padding:5px 9px;
						    white-space:nowrap;
						}
						.section-body{padding:15px}
						.two-col{display:grid;grid-template-columns:1fr 1fr;gap:10px}
						.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
						.doc-table{
						    width:100%;
						    border-collapse:separate;
						    border-spacing:0;
						    table-layout:fixed;
						    overflow:hidden;
						    border-radius:13px;
						    border:1px solid rgba(255,255,255,.08);
						    margin-bottom:10px;
						}
						.doc-table th{
						    background:#111A22;
						    color:#D5AE77;
						    font-size:12.5px;
						    font-weight:950;
						    text-transform:uppercase;
						    letter-spacing:.55px;
						    text-align:left;
						    padding:10px;
						    border-bottom:1px solid rgba(213,174,119,.30);
						}
						.doc-table td{
						    color:#DCE5EE;
						    font-size:14px;
						    line-height:1.45;
						    padding:9px 10px;
						    border-bottom:1px solid rgba(255,255,255,.055);
						    vertical-align:top;
						}
						.doc-table tr:last-child td{border-bottom:none}
						.doc-table td strong{color:#F4D9A9}
						.tag{
						    display:inline-flex;
						    border:1px solid rgba(213,174,119,.26);
						    background:rgba(213,174,119,.07);
						    color:#F4D9A9;
						    border-radius:999px;
						    padding:3px 7px;
						    font-size:11.2px;
						    font-weight:950;
						    text-transform:uppercase;
						    letter-spacing:.35px;
						    white-space:nowrap;
						}
						.tag.good{color:#8BE0D1;border-color:rgba(139,224,209,.35);background:rgba(139,224,209,.09)}
						.tag.info{color:#AEB9C4;border-color:rgba(255,255,255,.14);background:rgba(255,255,255,.05)}
						.tag.warn{color:#F4D9A9;border-color:rgba(213,174,119,.35);background:rgba(213,174,119,.09)}
						.tag.bad{color:#FFB0A8;border-color:rgba(217,93,93,.35);background:rgba(217,93,93,.09)}
						.callout{
						    border-left:4px solid rgba(213,174,119,.82);
						    background:rgba(213,174,119,.06);
						    border-radius:13px;
						    padding:12px 13px;
						    color:#DCE5EE;
						    font-size:14.2px;
						    line-height:1.5;
						    margin:10px 0;
						}
						.callout.tech{
						    border-left-color:#8BE0D1;
						    background:rgba(139,224,209,.055);
						}
						.callout.warn{
						    border-left-color:#F4D9A9;
						    background:rgba(244,217,169,.065);
						}
						.callout.bad{
						    border-left-color:#FFB0A8;
						    background:rgba(217,93,93,.065);
						}
						.stage-box{
						    display:grid;
						    grid-template-columns:1fr;
						    gap:8px;
						}
						.stage-line{
						    display:grid;
						    grid-template-columns:210px minmax(190px,1fr) 86px 86px;
						    gap:10px;
						    align-items:center;
						    padding:8px 9px;
						    border-radius:11px;
						    background:rgba(255,255,255,.035);
						    border:1px solid rgba(255,255,255,.07);
						}
						.stage-name{color:#DCE5EE;font-size:14.1px;font-weight:850}
						.stage-bar{height:9px;border-radius:999px;background:rgba(255,255,255,.07);overflow:hidden}
						.stage-bar span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#D5AE77,#8BE0D1)}
						.stage-qtd,.stage-pct{color:#AEB9C4;font-size:13.8px;font-weight:900;text-align:right}
						.footer-doc{
						    font-size:13.4px;
						    color:#8796A5;
						    line-height:1.38;
						    padding:10px 2px 2px;
						}
						</style>
						"
						
						VAR vHTML =
						"<div class='doc-page'>
						    <div class='doc-shell'>
						        <aside class='doc-sidebar'>
						            <div class='brand-kicker'>Power BI · Documentação</div>
						            <div class='brand-title'>Diagnóstico<br><span style='color:#8BE0D1'>Journey</span></div>
						            <div class='brand-sub'>Documentação oficial alinhada para a Diretoria Executiva (visão de valor, andamento) e para a Equipe Técnica (regras, performance, manutenção e escalabilidade).</div>
						
						            <div class='side-card highlight'>
						                <span class='side-label'>Status executivo</span>
						                <span class='side-value big'>" & vStatusExecutivo & "</span>
						                <div class='side-small'>" & vRiscoTexto & "</div>
						            </div>
			
						            <div class='side-card highlight' style='border-color:rgba(139,224,209,.38); background:linear-gradient(135deg,rgba(139,224,209,.12),rgba(255,255,255,.03));'>
						                <span class='side-label' style='color:#8BE0D1'>Honorários Agendados</span>
						                <span class='side-value big' style='color:#8BE0D1'>R$ " & FORMAT ( vHonorariosAgendados, vIntFormat ) & "</span>
						                <div class='side-small'>Encontrados: R$ " & FORMAT ( vHonorariosEncontrados, vIntFormat ) & " <br> Taxa de agendamento: " & FORMAT ( vPctHonorariosAgendados, vPctFormat ) & " do total.</div>
						            </div>
						
						            <div class='side-card'>
						                <span class='side-label'>Período exibido</span>
						                <span class='side-value'>" & vPeriodo & "</span>
						                <div class='side-small'>Sem filtro fixo de ano. O padrão é todo o período disponível; o usuário escolhe o recorte pelo slicer de data. A regra de base desta documentação foi alinhada à medida principal para evitar divergência de valores.</div>
						            </div>
						
						            <div class='side-card'>
						                <span class='side-label'>Último movimento</span>
						                <span class='side-value'>" & vUltimoMovimentoTxt & "</span>
						                <div class='side-small'>Baseado em TRIBUTO_DATA_ENTRADA, com fallback em DATA_CADASTRO quando necessário.</div>
						            </div>
						
						            <div class='side-card'>
						                <span class='side-label'>Atualização</span>
						                <span class='side-value'>" & vAtualizadoEm & "</span>
						                <div class='side-small'>Atualizado automaticamente pela medida HTML no refresh/abertura do relatório.</div>
						            </div>
						
						            <div class='nav-title'>Guia executivo e técnico</div>
						            <div class='nav-list'>
						                <div class='nav-pill active'>01. O que mudou agora</div>
						                <div class='nav-pill'>02. Como usar</div>
						                <div class='nav-pill'>03. Perguntas respondidas</div>
						                <div class='nav-pill'>04. Layout final</div>
						                <div class='nav-pill'>05. KPIs</div>
						                <div class='nav-pill'>06. Etapas e status</div>
						                <div class='nav-pill'>07. Slicers</div>
						                <div class='nav-pill'>08. Calendário</div>
						                <div class='nav-pill'>09. Aba Detalhamento</div>
						                <div class='nav-pill'>10. Dados</div>
						                <div class='nav-pill'>11. Manutenção</div>
						                <div class='nav-pill'>12. QA</div>
						                <div class='nav-pill'>13. Performance</div>
						                <div class='nav-pill'>14. Roadmap</div>
						            </div>
						        </aside>
						
						        <main class='doc-main'>
						            <div class='doc-header'>
						                <div>
						                    <h1>Documentação · Diagnóstico - Journey</h1>
						                    <p>Versão executiva e técnica integrada. Detalhamento completo das regras operacionais, visão financeira com honorários agendados, regras de performance de carregamento e arquitetura de medidas.</p>
						                </div>
						                <div class='doc-actions'>
						                    <div class='back-report-fake'>Voltar ao relatório</div>
						                    <div class='badge-wrap'>
						                        <span class='badge'>Diretoria</span>
						                        <span class='badge'>Técnico</span>
						                        <span class='badge teal'>Journey</span>
						                        <span class='badge'>Todo período</span>
						                    </div>
						                </div>
						            </div>
						
						            <div class='doc-scroll'>
						
						                <div class='metric-grid'>
						                    <div class='metric primary'><span class='m-label'>Jobs listados</span><span class='m-value'>" & FORMAT ( vJobs, vIntFormat ) & "</span><span class='m-note'>Jobs no período</span></div>
						                    <div class='metric'><span class='m-label'>Ativos</span><span class='m-value'>" & FORMAT ( vJobsAtivos, vIntFormat ) & "</span><span class='m-note'>" & FORMAT ( vPctAtivo, vPctFormat ) & " da carteira</span></div>
						                    <div class='metric'><span class='m-label'>Finalizados</span><span class='m-value'>" & FORMAT ( vJobsFinalizados, vIntFormat ) & "</span><span class='m-note'>" & FORMAT ( vPctFinalizado, vPctFormat ) & " em FIM</span></div>
						                    <div class='metric attention'><span class='m-label'>Passaram etapa</span><span class='m-value'>" & FORMAT ( vJobsPassaram, vIntFormat ) & "</span><span class='m-note'>" & FORMAT ( vPctPassaram, vPctFormat ) & " em Operação/Proc/FIM</span></div>
						                    <div class='metric'><span class='m-label'>Oportunidades</span><span class='m-value'>" & FORMAT ( vOportunidadesDisp, vIntFormat ) & "</span><span class='m-note'>" & FORMAT ( vOportunidadesPass, vIntFormat ) & " com passagem</span></div>
						                    <div class='metric'><span class='m-label'>Dias mediano</span><span class='m-value'>" & FORMAT ( vDiasMed, "#,##0" ) & "</span><span class='m-note'>Tempo operacional mediano</span></div>
						                </div>
			
						                <div class='metric-grid' style='grid-template-columns: repeat(3, 1fr); margin-bottom: 14px;'>
						                    <div class='metric' style='border-color:rgba(213,174,119,.3);'><span class='m-label' style='color:#D5AE77'>Honorários Encontrados</span><span class='m-value' style='color:#D5AE77'>R$ " & FORMAT ( vHonorariosEncontrados, vIntFormat ) & "</span><span class='m-note'>Soma distinta máxima por JOB</span></div>
						                    <div class='metric' style='border-color:rgba(139,224,209,.3);'><span class='m-label' style='color:#8BE0D1'>Honorários Agendados</span><span class='m-value' style='color:#8BE0D1'>R$ " & FORMAT ( vHonorariosAgendados, vIntFormat ) & "</span><span class='m-note'>Planejado operacionalmente</span></div>
						                    <div class='metric' style='border-color:rgba(139,224,209,.3);'><span class='m-label' style='color:#8BE0D1'>Eficiência de Agendamento</span><span class='m-value' style='color:#8BE0D1'>" & FORMAT ( vPctHonorariosAgendados, vPctFormat ) & "</span><span class='m-note'>Agendados sobre Encontrados</span></div>
						                </div>
						
						                <div class='insight-strip'>
						                    <div class='insight " & IF ( vPctPassaram >= 0.40, "good", "warn" ) & "'><span class='insight-label'>Andamento</span><span class='insight-text'>" & vStatusExecutivo & " no recorte atual.</span></div>
						                    <div class='insight " & IF ( vPctAtivo >= 0.80, "warn", "good" ) & "'><span class='insight-label'>Carteira</span><span class='insight-text'>" & FORMAT ( vPctAtivo, vPctFormat ) & " dos jobs permanecem ativos.</span></div>
						                    <div class='insight " & IF ( vPctOportPass >= 0.50, "good", "warn" ) & "'><span class='insight-label'>Oportunidades</span><span class='insight-text'>" & FORMAT ( vPctOportPass, vPctFormat ) & " das oportunidades tiveram passagem.</span></div>
						                    <div class='insight " & IF ( vPctCNPJBlank > 0, "warn", "good" ) & "'><span class='insight-label'>Chave futura</span><span class='insight-text'>" & FORMAT ( vCNPJBlank, vIntFormat ) & " linhas sem CNPJ no recorte.</span></div>
						                </div>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>01</span><span class='summary-title'>O que mudou na versão atual</span></div><span class='summary-action'>Atualização</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Mudança</th><th>Antes</th><th>Agora</th><th>Impacto</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Escopo de Produtos</strong></td><td>Apenas produtos diagnósticos (`IsDiagnostico = TRUE`).</td><td><strong>Todos os produtos da base</strong> (filtro `IsDiagnostico` removido de todas as medidas).</td><td>Permite analisar qualquer produto (ex: Revisão Previdenciária) sem cards ficarem vazios.</td></tr>
						                                <tr><td><strong>Expansão de Produto</strong></td><td>Lista job por job ocupando muito espaço e gerando lentidão.</td><td><strong>Tabela widescreen comparativa</strong> com os totais macros da base.</td><td>Compara de forma clara e limpa o produto com a média geral da empresa.</td></tr>
						                                <tr><td><strong>Alinhamento do Detalhamento</strong></td><td>Cards operacionais e rodapé travados em `750` listados.</td><td><strong>Contagem dinâmica e real</strong> (`_totalJobs` ex: 2.074 em abril/2026).</td><td>Os cards mostram o total real do período e o rodapé mostra `750 de 2.074 no período`.</td></tr>
						                                <tr><td><strong>Recorte de Período</strong></td><td>Filtro fixo de ano na medida.</td><td>Totalmente dinâmico pelo slicer.</td><td>Liberdade para navegar de forma retroativa ou futura conforme a dCalendar.</td></tr>
						                                <tr><td><strong>Valores com Honorários</strong></td><td>Não integrados na documentação e cards operacionais.</td><td><strong>Medidas exclusivas de Honorários</strong> integradas à barra executiva.</td><td>Soma distinta do máximo de honorários por JOB no período para Encontrados e Agendados.</td></tr>
						                                <tr><td><strong>Bolhas de Status</strong></td><td>Exibia status poluídos na principal.</td><td>Removidas.</td><td>Foco nas métricas de representatividade de forma limpa.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>02</span><span class='summary-title'>Como usar o dashboard no dia a dia</span></div><span class='summary-action'>Usuário</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Passo</th><th>O que fazer</th><th>Resultado esperado</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>1</strong></td><td>Abra a aba principal.</td><td>Veja o panorama macro da carteira de Jobs Journey e a visão financeira de honorários.</td></tr>
						                                <tr><td><strong>2</strong></td><td>Selecione um período no slicer de data.</td><td>Todos os cards (inclusive Detalhamento e Documentação) passam a respeitar o recorte de período.</td></tr>
						                                <tr><td><strong>3</strong></td><td>Use os filtros de Produto, Cliente e Etapa.</td><td>Analise carteiras específicas de forma focada para reuniões ou comitês.</td></tr>
						                                <tr><td><strong>4</strong></td><td>Clique para expandir um produto na tabela.</td><td>Veja a comparação widescreen do produto com o total da empresa de forma limpa.</td></tr>
						                                <tr><td><strong>5</strong></td><td>Navegue para a aba Detalhamento.</td><td>Consulte o job por job, busque na barra global ou colunas e copie a tabela para o Excel.</td></tr>
						                                <tr><td><strong>6</strong></td><td>Acesse a aba Documentação.</td><td>Entenda as regras operacionais, de cálculo e detalhes de manutenção técnica.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>03</span><span class='summary-title'>Perguntas que o dashboard responde</span></div><span class='summary-action'>Diretoria</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Pergunta</th><th>Onde olhar</th><th>Como interpretar</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Qual o tamanho da carteira de jobs no período?</strong></td><td>Card ""Jobs listados"".</td><td>Volume total de diagnósticos/jobs Journey ativos ou finalizados.</td></tr>
						                                <tr><td><strong>Quantos jobs ainda demandam gestão operacional?</strong></td><td>Card ""Ativos"" ou coluna ""Ativos"".</td><td>Total de jobs que possuem pelo menos uma linha fora da etapa FIM.</td></tr>
						                                <tr><td><strong>Qual o volume de honorários identificados no período?</strong></td><td>Card ""Honorários Encontrados"".</td><td>Volume total bruto de honorários identificados nos jobs mapeados.</td></tr>
						                                <tr><td><strong>Qual o valor financeiro já planejado/agendado?</strong></td><td>Card ""Honorários Agendados"".</td><td>Soma distinta por job dos valores com status de agendamento.</td></tr>
						                                <tr><td><strong>Como o produto X performa comparado com a média geral?</strong></td><td>Tabela principal (clique de expansão).</td><td>Mapeia eficiência em %, mediana de dias e volumetria comparativa direta.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>04</span><span class='summary-title'>Layout final das páginas</span></div><span class='summary-action'>Layout</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Página</th><th>Conteúdo</th><th>Finalidade</th><th>Botão</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>JOBS - PRODUTOS (Principal)</strong></td><td>Visão executiva macro, cards principais de volume/financeiro, tabela por produto com expansão widescreen comparativa.</td><td>Apresentação executiva e tomada de decisão estratégica.</td><td>Detalhamento (no topo da tabela) e Documentação (no título).</td></tr>
						                                <tr><td><strong>DETALHAMENTO</strong></td><td>Tabela detalhada job por job com busca global, filtros por coluna e botão de copiar para Excel (DOM limitado a 750 linhas).</td><td>Análise operacional de pendências e exportação de relatórios rápidos.</td><td>Voltar (ao lado do título).</td></tr>
						                                <tr><td><strong>DOCUMENTAÇÃO</strong></td><td>Esta página, com a documentação unificada executiva e técnica, glossário de KPIs e guia de performance.</td><td>Rastreabilidade técnica, auditoria de regras e onboarding de novos usuários.</td><td>Voltar ao relatório (ao lado do título).</td></tr>
						                            </tbody>
						                        </table>
						                        <div class='callout tech'>
						                            Os botões desenhados em HTML são visuais. A navegação real deve ser feita com botões nativos transparentes do Power BI posicionados por cima.
						                        </div>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>05</span><span class='summary-title'>KPIs e definição de cada card</span></div><span class='summary-action'>KPIs</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Card</th><th>Regra de cálculo</th><th>Como ler</th><th>Cuidado</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Jobs listados</strong></td><td>Distinct count de JOB no recorte Journey.</td><td>Total de jobs Journey no período selecionado.</td><td>Respeita dinamicamente os slicers e o período de data.</td></tr>
						                                <tr><td><strong>Ativos</strong></td><td>Job com pelo menos uma linha diferente de FIM.</td><td>Diagnósticos operacionais que ainda requerem acompanhamento.</td><td>Um único subproduto fora de FIM mantém o job ativo.</td></tr>
						                                <tr><td><strong>Finalizados</strong></td><td>Job com todas as sub-linhas na etapa FIM.</td><td>Carteira de jobs operacionalmente encerrados.</td><td>Depende de todas as linhas do JOB estarem com NOME_AREA = ""FIM"".</td></tr>
						                                <tr><td><strong>Honorários Encontrados</strong></td><td>Soma distinta do valor máximo de JOB_HONORARIOS_ENCONTRADOS por JOB.</td><td>Volume total financeiro mapeado de honorários brutos no período.</td><td>Distinct count por JOB evita duplicidades causadas por subprodutos.</td></tr>
						                                <tr><td><strong>Honorários Agendados</strong></td><td>Soma distinta do valor máximo de JOB_HONORARIOS_AGENDADOS por JOB.</td><td>Volume total financeiro com agendamento concluído.</td><td>Distinct count por JOB protege contra duplicidades operacionais.</td></tr>
						                                <tr><td><strong>Dias mediano</strong></td><td>Mediana do campo DIAS na base.</td><td>Tempo médio típico que um job consome no fluxo.</td><td>A mediana é usada no lugar da média para neutralizar outliers extremos.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>06</span><span class='summary-title'>Regras de etapa, status e ação sugerida</span></div><span class='summary-action'>Regra</span></summary>
						                    <div class='section-body'>
						                        <div class='three-col'>
						                            <div class='callout'><strong>Ativo:</strong> existe pelo menos uma linha do job fora de FIM.</div>
						                            <div class='callout'><strong>Finalizado:</strong> todas as linhas do job estão em FIM.</div>
						                            <div class='callout'><strong>Passou:</strong> o job chegou em Operação, Procuração Eletrônica ou FIM (Stage >= 2).</div>
						                        </div>
						                        <div class='stage-box'>" & vStageHTML & "</div>
						                        <table class='doc-table' style='margin-top:10px'>
						                            <thead><tr><th>Etapa</th><th>Significado operacional</th><th>Ação sugerida na aba Detalhamento</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Checklist</strong></td><td>Fase inicial de documentação, triagem e verificação preliminar.</td><td>Priorizar avanço.</td></tr>
						                                <tr><td><strong>Operação</strong></td><td>Execução técnica e operacional dos trabalhos de auditoria.</td><td>Acompanhar operação.</td></tr>
						                                <tr><td><strong>Procuração Eletrônica</strong></td><td>Aguardando liberação de procuração fiscal ou assinatura digital.</td><td>Acompanhar procuração.</td></tr>
						                                <tr><td><strong>Fim</strong></td><td>Finalizado, auditoria encerrada operacionalmente.</td><td>Finalizado.</td></tr>
						                                <tr><td><strong>Sem etapa mapeada</strong></td><td>Registros vazios ou fora do padrão em NOME_AREA.</td><td>Verificar base.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>07</span><span class='summary-title'>Slicers e interatividade</span></div><span class='summary-action'>Interação</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Slicer</th><th>Campo Técnico</th><th>Sincronização (syncGroup)</th><th>Função</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Período</strong></td><td>`dCalendar[YearMonthName]`</td><td>`YearMonthName` (Completo)</td><td>Controla a janela temporal ativa das análises macros e detalhadas.</td></tr>
						                                <tr><td><strong>Área / Etapa</strong></td><td>`JOBS_Produto[NOME_AREA]`</td><td>`NOME_AREA` (Completo)</td><td>Filtra o relatório por etapas operacionais gargalos.</td></tr>
						                                <tr><td><strong>Cliente</strong></td><td>`JOBS_Produto[NOME_CLIENTE]`</td><td>`NOME_CLIENTE` (Completo)</td><td>Permite análise individualizada de contas operacionais.</td></tr>
							                                <tr><td><strong>Produto</strong></td><td>`DIM_PRODUTOS_IMAGEM_TAX[ProdutoImagem]`</td><td>Lista TAX da imagem</td><td>Filtra a visão principal para os produtos governados da imagem.</td></tr>
						                                <tr><td><strong>Usuário Responsável</strong></td><td>`JOBS_Produto[usunome]`</td><td>`usunome` (Completo)</td><td>Filtra a carteira por responsável direto do job.</td></tr>
						                            </tbody>
						                        </table>
						                        <div class='callout warn'>
						                            <strong>Nota sobre Camadas:</strong> No painel de Seleção do Power BI Desktop, garanta que os Slicers transparentes fiquem na camada mais alta. Se a medida HTML sobrepor um slicer, o clique nele será bloqueado.
						                        </div>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>08</span><span class='summary-title'>Calendário e relacionamentos</span></div><span class='summary-action'>Modelo</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Item</th><th>Configuração recomendada</th><th>Por quê</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Tabela dCalendar</strong></td><td>Gerada dinamicamente entre o menor e maior `DATA_CADASTRO` da base.</td><td>Assegura consistência de período temporal.</td></tr>
						                                <tr><td><strong>Relacionamento Ativo</strong></td><td>`dCalendar[Date] (1) → JOBS_Produto[DATA_CADASTRO] (*)`</td><td>Data de criação do job é a âncora principal de recorte de safra.</td></tr>
						                                <tr><td><strong>Cardinalidade & Direção</strong></td><td>Um para muitos (1:*) / Única (dCalendar filtra JOBS_Produto).</td><td>Mantém integridade transacional de modelagem em estrela (Star Schema).</td></tr>
						                            </tbody>
						                        </table>
						                        <div class='callout tech'>
						                            <strong>Aviso Técnico:</strong> Caso surja a necessidade de analisar safras operacionais por `TRIBUTO_DATA_ENTRADA`, crie relacionamentos inativos e invoque-os nas medidas específicas usando a função `USERELATIONSHIP`. Nunca altere o relacionamento ativo principal.
						                        </div>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>09</span><span class='summary-title'>Aba Detalhamento & Limite de Performance</span></div><span class='summary-action'>Operação</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Elemento</th><th>O que faz</th><th>Como interpretar / Usar</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Jobs listados (Card)</strong></td><td>Exibe o total real filtrado (`_totalJobs` ex: 2.074).</td><td>Alinhado 100% com a tela principal, respeitando slicers e períodos.</td></tr>
						                                <tr><td><strong>Tabela física (DOM)</strong></td><td>Carrega no máximo as **750 linhas mais recentes**.</td><td>Controle de segurança técnico (`vLimiteLinhas = 750`) para evitar lentidão e travamentos no Power BI.</td></tr>
						                                <tr><td><strong>Nota de Truncamento</strong></td><td>`TOTAL VISÍVEL APÓS FILTROS: 750 DE 2.074 NO PERÍODO`</td><td>Significa que 2.074 jobs atendem aos seus filtros, e os 750 mais relevantes estão carregados no navegador. Use slicers para afunilar a busca se precisar exportar dados específicos.</td></tr>
						                                <tr><td><strong>Busca Global & Colunas</strong></td><td>Pesquisa e filtra dinamicamente as linhas carregadas no visual.</td><td>Filtro instantâneo rodando via JavaScript no navegador (super rápido).</td></tr>
						                                <tr><td><strong>Copiar tabela</strong></td><td>Copia todas as linhas filtradas (visíveis) em formato tabulado.</td><td>Pronto para colar diretamente no Microsoft Excel (`Ctrl + V`).</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>10</span><span class='summary-title'>Dados, campos e qualidade da base</span></div><span class='summary-action'>Dados</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Campo Original</th><th>Tipo / Regra</th><th>Uso / Importância Técnica</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>JOB</strong></td><td>Inteiro / ID do Job</td><td>Chave primária de agrupamento de diagnósticos. Linhas sem ID são excluídas.</td></tr>
						                                <tr><td><strong>DATA_CADASTRO</strong></td><td>Date / Anchored</td><td>Âncora de safra ativa ligada à dCalendar.</td></tr>
						                                <tr><td><strong>TRIBUTO_DATA_ENTRADA</strong></td><td>Date / Fallback</td><td>Usado para identificar a data do último movimento operacional.</td></tr>
						                                <tr><td><strong>JOB_HONORARIOS_ENCONTRADOS</strong></td><td>Currency</td><td>Valor bruto mapeado (soma distinta do máximo por JOB).</td></tr>
						                                <tr><td><strong>JOB_HONORARIOS_AGENDADOS</strong></td><td>Currency</td><td>Valor planejado operacionalmente (soma distinta do máximo por JOB).</td></tr>
						                                <tr><td><strong>CNPJ_CLIENTE / CNPJ_KEY</strong></td><td>Text</td><td>Cruzamento futuro com faturamento. No recorte atual existem " & FORMAT ( vCNPJBlank, vIntFormat ) & " registros sem CNPJ.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>11</span><span class='summary-title'>Medidas e objetos técnicos</span></div><span class='summary-action'>Técnico</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Medida DAX (medidas_html)</th><th>Função Principal</th><th>Recomendações de Manutenção</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>'HTML Diagnóstico Journey | Visual Principal'</strong></td><td>Gera o painel principal executivo, cards de KPI e a tabela por produto com expansão widescreen comparativa.</td><td>Alterar se precisar modificar o layout da grid principal, regras de comparação ou os cards de topo.</td></tr>
						                                <tr><td><strong>HTML_DETALHAMENTO_DIAGNOSTICO_JOURNEY_SEM_ESPACO_OCIOSO</strong></td><td>Gera o painel operacional de detalhamento com barra de busca JavaScript, filtros por coluna e limite de 750 linhas.</td><td>Alterar se precisar mudar campos visíveis na tabela job por job, alterar o script de busca ou regras de ação.</td></tr>
						                                <tr><td><strong>DOCUMENTACAO_DIAGNOSTICO_JOURNEY_HTML_V4_FORMAL_TODO_PERIODO</strong></td><td>Esta medida. Gera a página completa de documentação executiva e técnica.</td><td>Manter atualizada sempre que houver alteração de regras de negócio, tabelas ou novas features de escala.</td></tr>
						                                <tr><td><strong>Diagnóstico | Honorários Encontrados / Agendados</strong></td><td>Medidas base em DAX que realizam a soma distinta máxima por JOB no contexto atual.</td><td>Garantir que usem `MAX` por JOB encapsulado em `SUMX(SUMMARIZE(...))` para evitar duplicidades de subprodutos.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>12</span><span class='summary-title'>Checklist de validação técnica (QA)</span></div><span class='summary-action'>QA</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Validação</th><th>O que testar</th><th>Procedimento</th><th>Severidade</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Sincronização de Slicers</strong></td><td>Mudança de filtro na principal se reflete na detalhada.</td><td>Mude o mês na tela principal para abril/2026. Navegue para detalhamento e confirme o total de 2.074.</td><td><span class='tag bad'>Alto</span></td></tr>
						                                <tr><td><strong>Suporte a Produtos Gerais</strong></td><td>Selecionar produto não-diagnóstico.</td><td>Filtre por Revisão Previdenciária. Confirme que os cards calculam normalmente e não ficam em branco.</td><td><span class='tag bad'>Alto</span></td></tr>
						                                <tr><td><strong>Soma distinta de Honorários</strong></td><td>Duplicidade por subproduto.</td><td>Valide se jobs com múltiplos subprodutos não duplicam a soma dos honorários encontrados.</td><td><span class='tag bad'>Alto</span></td></tr>
						                                <tr><td><strong>Desempenho de Renderização</strong></td><td>Consumo excessivo de RAM no navegador.</td><td>Valide se a tabela detalhada carrega instantaneamente. O limite de 750 linhas assegura isso.</td><td><span class='tag warn'>Médio</span></td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>13</span><span class='summary-title'>Performance e limites do HTML Content</span></div><span class='summary-action'>Performance</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Risco / Limite</th><th>Motivo Técnico</th><th>Estratégia de Mitigação Atual</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Consumo excessivo de DOM</strong></td><td>O visual HTML renderiza todas as tags passadas via DAX. Milhares de elementos expansíveis travam o navegador.</td><td>Mover a listagem detalhada para uma página própria com paginação/limite de 750 registros mais relevantes.</td></tr>
						                                <tr><td><strong>Sobreposição de Camadas</strong></td><td>O visual HTML captura cliques do mouse em toda a sua área retangular.</td><td>Slicers nativos transparentes são colocados na camada mais alta (`Trazer para frente` no painel de Seleção).</td></tr>
						                                <tr><td><strong>Estouro de Buffer no DAX</strong></td><td>Medidas HTML com concatenações gigantes podem estourar a memória do Analysis Services.</td><td>A tabela widescreen da principal agrupa produtos por linha, e a detalhada limita a base física de rows para 750.</td></tr>
						                            </tbody>
						                        </table>
						                    </div>
						                </details>
						
						                <details class='doc-section' open>
						                    <summary><div class='summary-left'><span class='summary-index'>14</span><span class='summary-title'>Roadmap recomendado de escalabilidade</span></div><span class='summary-action'>Roadmap</span></summary>
						                    <div class='section-body'>
						                        <table class='doc-table'>
						                            <thead><tr><th>Prioridade</th><th>Ação Recomendada</th><th>Justificativa / Benefício</th></tr></thead>
						                            <tbody>
						                                <tr><td><strong>Alta</strong></td><td>Padronizar CNPJ de Clientes</td><td>Ajustar a fonte de dados para garantir que a chave do CNPJ tenha exatamente 14 dígitos (evitando inconsistências de cruzamento).</td></tr>
						                                <tr><td><strong>Média</strong></td><td>Centralizar Variáveis de Status</td><td>Criar uma tabela calculada centralizando as chaves e status de Jobs para reduzir o overhead de repetição de variáveis em DAX.</td></tr>
						                                <tr><td><strong>Média</strong></td><td>Implementar Drillthrough de CNPJ</td><td>Criar uma tela de detalhamento individual por CNPJ/Cliente, permitindo auditorias financeiras e operacionais focadas.</td></tr>
						                                <tr><td><strong>Baixa</strong></td><td>Exportação Direta Automatizada</td><td>Desenvolver fluxo automatizado por Power Automate para baixar toda a base consolidada sem a barreira de performance de 750 linhas.</td></tr>
						                            </tbody>
						                        </table>
						                        <div class='footer-doc'>
						                            Recorte atual: " & vPeriodo & ". Registros base: " & FORMAT ( vRegistros, vIntFormat ) & ". Jobs identificados: " & FORMAT ( vJobs, vIntFormat ) & ". Ativos: " & FORMAT ( vJobsAtivos, vIntFormat ) & ". Finalizados: " & FORMAT ( vJobsFinalizados, vIntFormat ) & ". Clientes distintos: " & FORMAT ( vClientes, vIntFormat ) & ". CNPJs válidos: " & FORMAT ( vCNPJs, vIntFormat ) & ". Produtos: " & FORMAT ( vProdutos, vIntFormat ) & ". Subprodutos: " & FORMAT ( vSubprodutos, vIntFormat ) & ". Oportunidades: " & FORMAT ( vOportunidadesDisp, vIntFormat ) & ". Atualizado em " & vAtualizadoEm & ".
						                        </div>
						                    </div>
						                </details>
						
						            </div>
						        </main>
						    </div>
