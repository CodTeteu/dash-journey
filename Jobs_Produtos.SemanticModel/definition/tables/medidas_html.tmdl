				.kpi{min-height:106px;padding:18px 16px 16px!important;border-radius:24px;background:linear-gradient(145deg,rgba(26,39,52,.98),rgba(6,12,18,.98) 62%,rgba(2,7,12,.99));border:1px solid rgba(244,217,169,.38);box-shadow:0 24px 54px rgba(0,0,0,.42),0 0 0 1px rgba(139,224,209,.08),inset 0 1px 0 rgba(255,255,255,.10);overflow:hidden}.kpi:before{left:16px;top:0;width:62px;height:5px;border-radius:0 0 14px 14px;background:linear-gradient(90deg,#F4D9A9 0%,#D5AE77 48%,#8BE0D1 100%);box-shadow:0 0 20px rgba(244,217,169,.34)}.kpi:after{content:'';position:absolute;inset:1px;border-radius:23px;background:radial-gradient(circle at 82% 18%,rgba(139,224,209,.18),transparent 30%),linear-gradient(135deg,rgba(255,255,255,.10),transparent 44%);pointer-events:none;z-index:-1}.kpi-content{position:relative;z-index:1;padding-top:4px}.kpi-content:after{content:'';position:absolute;right:-8px;bottom:-14px;width:72px;height:72px;border-radius:50%;background:radial-gradient(circle,rgba(244,217,169,.10),transparent 68%);pointer-events:none}.kpi-label{font-size:11.5px!important;color:#F8E6C8!important;letter-spacing:.105em!important;text-shadow:0 2px 10px rgba(244,217,169,.20)}.kpi-value{font-size:34px!important;color:#FFFFFF!important;letter-spacing:-.035em;text-shadow:0 3px 22px rgba(244,217,169,.30),0 0 22px rgba(139,224,209,.12)}.primary .kpi-value{font-size:36px!important}.money .kpi-value{font-size:26px!important;letter-spacing:-.045em;color:#F4D9A9!important}.kpi.primary{background:radial-gradient(circle at 14% 0%,rgba(244,217,169,.26),transparent 36%),linear-gradient(145deg,rgba(31,40,48,.99),rgba(6,12,18,.98) 64%)}.kpi.attention{border-color:rgba(139,224,209,.36);background:radial-gradient(circle at 84% 0%,rgba(139,224,209,.22),transparent 34%),linear-gradient(145deg,rgba(18,34,43,.99),rgba(5,11,17,.98) 64%)}.kpi.money{border-color:rgba(244,217,169,.42);background:radial-gradient(circle at 76% 0%,rgba(244,217,169,.20),transparent 32%),radial-gradient(circle at 12% 100%,rgba(139,224,209,.12),transparent 34%),linear-gradient(145deg,rgba(24,28,34,.99),rgba(4,9,14,.98) 64%)}.kpi:hover{transform:translateY(-4px);border-color:rgba(244,217,169,.58);box-shadow:0 30px 66px rgba(0,0,0,.50),0 0 0 1px rgba(139,224,209,.16),0 0 28px rgba(244,217,169,.10),inset 0 1px 0 rgba(255,255,255,.13)}
				.kpis{grid-template-columns:repeat(6,minmax(0,1fr));gap:12px}.kpi{min-height:96px;padding:16px 15px 15px!important;border-radius:20px;background:linear-gradient(180deg,rgba(18,29,39,.98),rgba(7,13,20,.99));border:1px solid rgba(244,217,169,.24);box-shadow:0 14px 28px rgba(0,0,0,.34),inset 0 1px 0 rgba(255,255,255,.055);overflow:hidden}.kpi:before{left:16px;top:0;width:46px;height:4px;border-radius:0 0 10px 10px;background:#D5AE77;box-shadow:none}.kpi:after,.kpi-content:after{display:none!important}.kpi-content{padding-top:2px}.kpi-label{font-size:11px!important;color:#CDB58F!important;letter-spacing:.09em!important;text-shadow:none!important}.kpi-value{font-size:32px!important;color:#F5F7FA!important;letter-spacing:-.03em;text-shadow:none!important}.primary .kpi-value{font-size:33px!important}.money .kpi-value{font-size:24px!important;color:#F1D8AE!important}.kpi.primary{background:linear-gradient(180deg,rgba(25,31,37,.99),rgba(8,14,20,.99));border-color:rgba(213,174,119,.30)}.kpi.attention{background:linear-gradient(180deg,rgba(17,31,39,.99),rgba(7,13,20,.99));border-color:rgba(139,224,209,.24)}.kpi.attention:before{background:#8BE0D1}.kpi.money{background:linear-gradient(180deg,rgba(26,28,31,.99),rgba(7,13,20,.99));border-color:rgba(213,174,119,.28)}.kpi:hover{transform:translateY(-2px);border-color:rgba(244,217,169,.40);box-shadow:0 18px 34px rgba(0,0,0,.40),inset 0 1px 0 rgba(255,255,255,.075)}.table-head div{font-size:14px!important}.kpi-label{font-size:12px!important}.card-title{font-size:20px!important}
				</style>
				<script>
				(function(){
				    var tipId = 'float-tip-main';
				    var existing = document.getElementById(tipId);
				    if(existing) existing.remove();
				    document.querySelectorAll('.float-tip').forEach(function(el){
				        if(el.id === tipId || !el.id) el.remove();
				    });
				    var container = document.querySelector('.diag-wrap') || document.body;
				    var tip;
				    function ensure(){
				        var el = document.getElementById(tipId);
				        if(el) return el;
				        el = document.createElement('div');
				        el.id = tipId;
				        el.className = 'float-tip';
				        document.body.appendChild(el);
				        return el;
				    }
				    function place(e){
				        var t = ensure();
				        var pad=18, w=t.offsetWidth||360, h=t.offsetHeight||120, x=e.clientX+pad, y=e.clientY+pad;
				        if(x+w > window.innerWidth-8) x = e.clientX-w-pad;
				        if(y+h > window.innerHeight-8) y = e.clientY-h-pad;
				        t.style.left = Math.max(8, x)+'px';
				        t.style.top = Math.max(8, y)+'px';
				    }
				    container.addEventListener('mouseover', function(e){
				        var target = e.target.closest('[data-tip]');
				        if(target){
				            var t = ensure();
				            t.innerHTML = target.getAttribute('data-tip')||'';
				            t.classList.add('on');
				            place(e);
				        }
				    });
				    container.addEventListener('mousemove', function(e){
				        var target = e.target.closest('[data-tip]');
				        if(target){
				            place(e);
				        } else {
				            var t = document.getElementById(tipId);
				            if(t) t.classList.remove('on');
				        }
				    });
				    container.addEventListener('mouseleave', function(){
				        var t = document.getElementById(tipId);
				        if(t) t.classList.remove('on');
				    });
				})();
				</script>
				"
				VAR vTipJourneys = "<b>JOURNEYS PAI</b><br/>O que mostra: total de journeys pai no recorte da página principal.<br/><br/><b>Como calcula:</b> conta <code>vw_powerbi_journeys</code> no período selecionado e aplica filtros de produto, job e etapa por DAX.<br/><b>Origem:</b> <code>JOB</code>, <code>DATA_CADASTRO</code>, <code>FIM</code>.<br/><b>Como interpretar:</b> tamanho da carteira principal analisada no painel.<br/><b>Atenção:</b> sem relacionamento físico; o vínculo com jobs usa prefixo de <code>JOB</code>."
				VAR vTipJourneysAtivos = "<b>JOURNEYS ATIVOS</b><br/>O que mostra: journeys pai vigentes no recorte atual.<br/><br/><b>Como calcula:</b> aplica <code>FIM = 1</code> sobre os journeys pai filtrados.<br/><b>Origem:</b> <code>vw_powerbi_journeys[FIM]</code>.<br/><b>Como interpretar:</b> contratos ou contas principais ainda ativos.<br/><b>Atenção:</b> <code>FIM = 1</code> significa ativo e não deve ser reinterpretado."
				VAR vTipJobs = "<b>JOBS FILHOS</b><br/>O que mostra: total de jobs filhos vinculados aos journeys filtrados.<br/><br/><b>Como calcula:</b> conta linhas de <code>vw_powerbi_journeys_filhos_novos</code> após período, produto e vínculo com journey pai.<br/><b>Origem:</b> <code>CODIGO</code>, <code>JOB</code>, <code>CODIGO_PRODUTO</code>, <code>GppNome</code>.<br/><b>Como interpretar:</b> carga operacional total de serviços.<br/><b>Atenção:</b> um journey pode gerar vários jobs."
				VAR vTipJobsAtivos = "<b>JOBS ATIVOS</b><br/>O que mostra: jobs filhos ativos no recorte atual.<br/><br/><b>Como calcula:</b> filtra os jobs filhos por <code>FIM = 1</code> depois dos filtros de período e produto.<br/><b>Origem:</b> <code>vw_powerbi_journeys_filhos_novos[FIM]</code>.<br/><b>Como interpretar:</b> serviços em andamento que demandam gestão.<br/><b>Atenção:</b> a distribuição por etapa usa essa base ativa."
				VAR vTipCreditos = "<b>TOTAL CRÉDITOS PROJECT</b><br/>O que mostra: soma dos créditos PROJECT no recorte atual.<br/><br/><b>Como calcula:</b> soma <code>CREDITOS</code> dos jobs filtrados.<br/><b>Origem:</b> <code>vw_powerbi_journeys_filhos_novos[CREDITOS]</code>.<br/><b>Como interpretar:</b> potencial financeiro PROJECT do recorte.<br/><b>Atenção:</b> PJ360 fica separado na matriz expandida; <code>RF_VALOR</code> não é usado."
				VAR vTipHonorarios = "<b>TOTAL HONORÁRIOS PROJECT</b><br/>O que mostra: soma dos honorários PROJECT líquidos no recorte atual.<br/><br/><b>Como calcula:</b> aplica <code>Honorarios * (1 - PERCENTUAL / 100)</code> por job e soma o resultado.<br/><b>Origem:</b> <code>Honorarios</code> e <code>PERCENTUAL</code> em <code>vw_powerbi_journeys_filhos_novos</code>.<br/><b>Como interpretar:</b> honorário PROJECT esperado após desconto percentual.<br/><b>Atenção:</b> PJ360 usa colunas <code>SIMULACAO_*</code> e fica separado no expandido."
				VAR vTipHeaderProd = "<b>PRODUTO</b><br/>O que mostra: agrupamento dos jobs por produto.<br/><br/><b>Origem:</b> <code>vw_powerbi_journeys_filhos_novos[GppNome]</code>.<br/><b>Como interpretar:</b> cada linha consolida indicadores de uma solução tributária.<br/><b>Atenção:</b> clique na linha para abrir o detalhamento expandido."
				VAR vTipHeaderJobs = "<b>JOBS</b><br/>O que mostra: total de jobs no produto e, em menor destaque, quantos estão ativos.<br/><br/><b>Como calcula:</b> conta jobs filhos do produto; ativos usam <code>FIM = 1</code>.<br/><b>Origem:</b> <code>vw_powerbi_journeys_filhos_novos</code>.<br/><b>Como interpretar:</b> volume operacional por produto."
				VAR vTipHeaderEmpresas = "<b>EMPRESAS</b><br/>O que mostra: CNPJs únicos vinculados ao produto e CNPJs únicos em jobs ativos.<br/><br/><b>Como calcula:</b> contagem distinta de <code>ParCNPJ</code> por produto.<br/><b>Origem:</b> <code>vw_powerbi_journeys_filhos_novos[ParCNPJ]</code>.<br/><b>Como interpretar:</b> quantidade de empresas únicas, não quantidade de journeys."
				VAR vTipHeaderOnboarding = "<b>ONBOARDING</b><br/>O que mostra: jobs ativos em etapas iniciais do fluxo.<br/><br/><b>Como calcula:</b> agrupa <code>CADASTRO</code> e <code>PROCURAÇÃO ELETRÔNICA</code> em <code>ParNome</code>.<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos[ParNome]</code>.<br/><b>Como interpretar:</b> entrada e preparação documental dos serviços."
				VAR vTipHeaderCheck = "<b>CHECKLIST</b><br/>O que mostra: jobs ativos na etapa Checklist.<br/><br/><b>Como calcula:</b> conta jobs ativos com <code>ParNome</code> igual a <code>CHECKLIST</code>.<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos</code>.<br/><b>Como interpretar:</b> volume aguardando ou executando conferência de documentação."
				VAR vTipHeaderOper = "<b>OPERAÇÃO</b><br/>O que mostra: jobs ativos na etapa Operação.<br/><br/><b>Como calcula:</b> conta jobs ativos com <code>ParNome</code> igual a <code>OPERAÇÃO</code>.<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos</code>.<br/><b>Como interpretar:</b> carga técnica em execução operacional."
				VAR vTipHeaderNeg = "<b>NEGOCIAÇÃO</b><br/>O que mostra: jobs ativos na etapa Negociação.<br/><br/><b>Como calcula:</b> conta jobs ativos com <code>ParNome</code> igual a <code>NEGOCIAÇÃO</code>.<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos[ParNome]</code>.<br/><b>Como interpretar:</b> oportunidades em tratativa comercial ou aceite."
				VAR vTipHeaderImp = "<b>IMPLANTAÇÃO</b><br/>O que mostra: jobs ativos cuja etapa indica implantação.<br/><br/><b>Como calcula:</b> considera <code>IMP</code>, <code>IMPLANTAÇÃO</code>, <code>IMPLANTACAO</code> ou valores iniciados por <code>IMP</code>.<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos[ParNome]</code>.<br/><b>Atenção:</b> <code>IMP</code> é etapa válida e mapeia para implantação."
				VAR vTipHeaderFim = "<b>FIM</b><br/>O que mostra: jobs ativos que estão na etapa Fim.<br/><br/><b>Como calcula:</b> conta jobs ativos com <code>ParNome</code> igual a <code>FIM</code>.<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos[ParNome]</code>.<br/><b>Como interpretar:</b> serviços finalizados dentro da etapa operacional."
				VAR vTipHeaderCreditos = "<b>CRÉDITOS PROJECT</b><br/>O que mostra: total PROJECT de créditos por produto.<br/><br/><b>Como calcula:</b> soma <code>CREDITOS</code> nos jobs do produto.<br/><b>Atenção:</b> PJ360 usa <code>SIMULACAO_CREDITO</code> e aparece no expandido."
				VAR vTipHeaderHonorarios = "<b>HONORÁRIOS PROJECT</b><br/>O que mostra: honorários PROJECT líquidos por produto.<br/><br/><b>Como calcula:</b> soma <code>Honorarios * (1 - PERCENTUAL / 100)</code>.<br/><b>Atenção:</b> PJ360 usa <code>SIMULACAO_HONORARIO</code> e aparece no expandido."
				VAR vTipAbrirDetalhamento = "<b>ABRIR DETALHAMENTO</b><br/>Navega para a página de detalhe operacional.<br/><br/><b>Como usar:</b> clique para ver a lista granular de jobs por produto, journey, status e etapa.<br/><b>Atenção:</b> os slicers sincronizados continuam respeitando o recorte atual."
				VAR vCards =
				    "<div class='kpis'>"
				        & "<div class='kpi primary' data-tip='" & vTipJourneys & "'><div class='kpi-content'><div class='kpi-label'>Journeys</div><div class='kpi-value'>" & FORMAT ( vJourneys, vIntFormat ) & "</div></div></div>"
				        & "<div class='kpi attention' data-tip='" & vTipJourneysAtivos & "'><div class='kpi-content'><div class='kpi-label'>Journey Ativos</div><div class='kpi-value'>" & FORMAT ( vJourneysAtivos, vIntFormat ) & "</div></div></div>"
				        & "<div class='kpi primary' data-tip='" & vTipJobs & "'><div class='kpi-content'><div class='kpi-label'>Jobs</div><div class='kpi-value'>" & FORMAT ( vJobsTotais, vIntFormat ) & "</div></div></div>"
				        & "<div class='kpi attention' data-tip='" & vTipJobsAtivos & "'><div class='kpi-content'><div class='kpi-label'>Jobs Ativos</div><div class='kpi-value'>" & FORMAT ( vJobsAtivos, vIntFormat ) & "</div></div></div>"
				        & "<div class='kpi money' data-tip='" & vTipCreditos & "'><div class='kpi-content'><div class='kpi-label'>Total Créditos</div><div class='kpi-value'>" & vTotalCreditosFmt & "</div></div></div>"
				        & "<div class='kpi money' data-tip='" & vTipHonorarios & "'><div class='kpi-content'><div class='kpi-label'>Total Honorários</div><div class='kpi-value'>" & vTotalHonorariosFmt & "</div></div></div>"
				    & "</div>"
				VAR vHead =
				    "<div class='table-head'>"
				        & "<div data-tip='" & vTipHeaderProd & "'>Produto</div>"
				        & "<div data-tip='" & vTipHeaderJobs & "'>Jobs</div>"
				        & "<div data-tip='" & vTipHeaderEmpresas & "'>Empresas</div>"
				        & "<div data-tip='" & vTipHeaderOnboarding & "'>Onboarding</div>"
				        & "<div data-tip='" & vTipHeaderCheck & "'>Checklist</div>"
				        & "<div data-tip='" & vTipHeaderOper & "'>Operação</div>"
				        & "<div data-tip='" & vTipHeaderNeg & "'>Negociação</div>"
				        & "<div data-tip='" & vTipHeaderImp & "'>IMPLANTAÇÃO</div>"
				        & "<div data-tip='" & vTipHeaderFim & "'>Fim</div>"
				        & "<div data-tip='" & vTipHeaderCreditos & "'>Créditos</div>"
				        & "<div data-tip='" & vTipHeaderHonorarios & "'>Honorários</div>"
				    & "</div>"
				VAR vRows =
				    CONCATENATEX (
				        vProductTop,
				        VAR p = [__Produto]
				        VAR pTip = SUBSTITUTE ( p, "'", "&#39;" )
				        VAR pc = [__ProdutoCodigo]
				        VAR vJobs = [__Jobs]
				        VAR vAtivos = [__Ativos]
				        VAR vEmpresas = COALESCE ( [__Empresas], 0 )
				        VAR vEmpresasAtivas = COALESCE ( [__EmpresasAtivas], 0 )
				        VAR vOnboarding = COALESCE ( [__Onboarding], 0 )
				        VAR vCheck = COALESCE ( [__Checklist], 0 )
				        VAR vOper = COALESCE ( [__Operacao], 0 )
				        VAR vNeg = COALESCE ( [__Negociacao], 0 )
				        VAR vImp = COALESCE ( [__Implantacao], 0 )
				        VAR vFim = COALESCE ( [__Fim], 0 )
				        VAR vCreditos = [__ProjectCredito]
				        VAR vHonorarios = [__ProjectHonorario]
				        VAR vPJ360Credito = [__PJ360Credito]
				        VAR vPJ360CreditoQtd = [__PJ360CreditoQtd]
				        VAR vPJ360Honorario = [__PJ360Honorario]
				        VAR vPJ360HonorarioQtd = [__PJ360HonorarioQtd]
				        VAR vProjectCredito = [__ProjectCredito]
				        VAR vProjectCreditoQtd = [__ProjectCreditoQtd]
				        VAR vProjectHonorario = [__ProjectHonorario]
				        VAR vProjectHonorarioQtd = [__ProjectHonorarioQtd]
				        VAR vCreditosFmt = IF ( ISBLANK ( vCreditos ), "R$ -", FORMAT ( vCreditos, vMoneyFormat ) )
				        VAR vHonorariosFmt = IF ( ISBLANK ( vHonorarios ), "R$ -", FORMAT ( vHonorarios, vMoneyFormat ) )
				        VAR vPJ360CreditoFmt = IF ( ISBLANK ( vPJ360Credito ), "R$ -", FORMAT ( vPJ360Credito, vMoneyFormat ) )
				        VAR vPJ360HonorarioFmt = IF ( ISBLANK ( vPJ360Honorario ), "R$ -", FORMAT ( vPJ360Honorario, vMoneyFormat ) )
				        VAR vProjectCreditoFmt = IF ( ISBLANK ( vProjectCredito ), "R$ -", FORMAT ( vProjectCredito, vMoneyFormat ) )
				        VAR vProjectHonorarioFmt = IF ( ISBLANK ( vProjectHonorario ), "R$ -", FORMAT ( vProjectHonorario, vMoneyFormat ) )
				        VAR vPctAtivos = DIVIDE ( vAtivos, vJobs, 0 )
				        VAR vPctEmpresasAtivas = DIVIDE ( vEmpresasAtivas, vEmpresas, 0 )
				        VAR vTotalEtapas = vOnboarding + vCheck + vOper + vNeg + vImp + vFim
				        VAR vJobsAtivosProduto = SELECTCOLUMNS ( FILTER ( vJobsBase, [__ProdutoCodigo] = pc && [__Fim] = 1 ), "__PmvJob", [__Codigo] )
				        VAR vStageTable =
				            UNION (
				                ROW ( "Ordem", 1, "Etapa", "Onboarding", "Qtd", vOnboarding, "Class", "cad" ),
				                ROW ( "Ordem", 2, "Etapa", "Checklist", "Qtd", vCheck, "Class", "check" ),
				                ROW ( "Ordem", 3, "Etapa", "Operação", "Qtd", vOper, "Class", "oper" ),
				                ROW ( "Ordem", 4, "Etapa", "Negociação", "Qtd", vNeg, "Class", "reu" ),
				                ROW ( "Ordem", 5, "Etapa", "IMPLANTAÇÃO", "Qtd", vImp, "Class", "proc" ),
				                ROW ( "Ordem", 6, "Etapa", "Fim", "Qtd", vFim, "Class", "fim" )
				            )
				        VAR vStageCells =
					            "<div class='metric active' data-tip='<b>JOBS DO PRODUTO</b><br/>O que mostra: total de jobs do produto e quantos estão ativos.<br/><br/><b>Total:</b> " & FORMAT ( vJobs, vIntFormat ) & "<br/><b>Ativos:</b> " & FORMAT ( vAtivos, vIntFormat ) & "<br/><b>% ativos:</b> " & FORMAT ( vPctAtivos, vPctFormat ) & "<br/><b>Regra:</b> ativo quando <code>FIM = 1</code>.'><b>" & FORMAT ( vJobs, vIntFormat ) & "</b><small>" & FORMAT ( vAtivos, vIntFormat ) & " ativos</small></div>"
					                & "<div class='metric active' data-tip='<b>EMPRESAS DO PRODUTO</b><br/>O que mostra: CNPJs únicos vinculados ao produto.<br/><br/><b>Total:</b> " & FORMAT ( vEmpresas, vIntFormat ) & "<br/><b>Ativas:</b> " & FORMAT ( vEmpresasAtivas, vIntFormat ) & "<br/><b>% ativas:</b> " & FORMAT ( vPctEmpresasAtivas, vPctFormat ) & "<br/><b>Origem:</b> <code>ParCNPJ</code> em jobs filhos.'><b>" & FORMAT ( vEmpresas, vIntFormat ) & "</b><small>" & FORMAT ( vEmpresasAtivas, vIntFormat ) & " ativas</small></div>"
				                & CONCATENATEX (
				                    vStageTable,
				                    VAR q = [Qtd]
				                    VAR pct = DIVIDE ( q, vTotalEtapas, 0 )
					                    VAR cellTip = "<b>ETAPA: " & [Etapa] & "</b><br/>O que mostra: jobs ativos do produto agrupados nesta etapa.<br/><br/><b>Quantidade:</b> " & FORMAT ( q, vIntFormat ) & "<br/><b>Participação no produto:</b> " & FORMAT ( pct, vPctFormat ) & "<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos[ParNome]</code><br/><b>Vínculo:</b> <code>PmvJob</code> = <code>CODIGO</code> do job filho.<br/><b>Atenção:</b> esta coluna é agrupada; abra a linha para ver as etapas detalhadas."
				                    RETURN "<div class='metric " & [Class] & "' data-tip='" & cellTip & "'><b>" & IF ( q = 0, "0", FORMAT ( q, vIntFormat ) ) & "</b><small>" & FORMAT ( pct, vPctFormat ) & "</small></div>",
				                    "",
				                    [Ordem], ASC
				                )
					                & "<div class='metric money' data-tip='<b>CRÉDITOS PROJECT</b><br/>O que mostra: soma de créditos PROJECT para este produto.<br/><br/><b>Valor:</b> " & vProjectCreditoFmt & "<br/><b>Origem:</b> <code>CREDITOS</code>.<br/><b>Atenção:</b> valores PJ360 ficam separados na matriz expandida.'><b>" & vCreditosFmt & "</b></div>"
					                & "<div class='metric money' data-tip='<b>HONORÁRIOS PROJECT</b><br/>O que mostra: honorários PROJECT líquidos para este produto.<br/><br/><b>Valor:</b> " & vProjectHonorarioFmt & "<br/><b>Regra:</b> <code>Honorarios * (1 - PERCENTUAL / 100)</code>.<br/><b>Atenção:</b> valores PJ360 ficam separados na matriz expandida.'><b>" & vHonorariosFmt & "</b></div>"
				        VAR vStageDetailRaw = FILTER ( vAreas, [__PmvJob] IN vJobsAtivosProduto )
				        VAR vStageDetailNames =
				            DISTINCT (
				                UNION (
				                    SELECTCOLUMNS ( vStageDetailRaw, "Etapa", [__Etapa] ),
				                    DATATABLE ( "Etapa", STRING, { { "CADASTRO" }, { "PROCURAÇÃO ELETRÔNICA" }, { "CHECKLIST" }, { "OPERAÇÃO" }, { "REUNIÃO TÉCNICA" }, { "REVISÃO" }, { "RETIFICAÇÃO" }, { "NEGOCIAÇÃO" }, { "QUALIDADE" }, { "COMPENSAÇÃO" }, { "FIM" } } )
				                )
				            )
				        VAR vStageDetailTable =
				            ADDCOLUMNS (
				                vStageDetailNames,
				                "Ordem", SWITCH ( [Etapa], "CADASTRO", 1, "PROCURAÇÃO ELETRÔNICA", 2, "CHECKLIST", 3, "OPERAÇÃO", 4, "REUNIÃO TÉCNICA", 5, "REVISÃO", 6, "RETIFICAÇÃO", 7, "NEGOCIAÇÃO", 8, "QUALIDADE", 9, "COMPENSAÇÃO", 10, "FIM", 99, 90 ),
				                "Qtd", VAR e = [Etapa] RETURN COALESCE ( COUNTROWS ( FILTER ( vStageDetailRaw, [__Etapa] = e ) ), 0 )
				            )
				        VAR vTotalEtapasDetalhe = SUMX ( vStageDetailTable, [Qtd] )
				        VAR vStageLines =
				            CONCATENATEX (
				                vStageDetailTable,
				                VAR q = COALESCE ( [Qtd], 0 )
				                VAR pct = DIVIDE ( q, vTotalEtapasDetalhe, 0 )
				                VAR barWidth = IF ( q = 0, 0, ROUND ( pct * 100, 0 ) )
					                VAR lineTip = "<b>ETAPA DETALHADA: " & [Etapa] & "</b><br/>O que mostra: quantidade de jobs ativos nesta etapa real de <code>ParNome</code>.<br/><br/><b>Quantidade:</b> " & FORMAT ( q, vIntFormat ) & "<br/><b>Participação:</b> " & FORMAT ( pct, vPctFormat ) & "<br/><b>Origem:</b> <code>vw_powerbi_journeys_menor_area_novos[ParNome]</code>.<br/><b>Como interpretar:</b> granularidade completa da etapa, sem o agrupamento da linha principal."
				                RETURN "<div class='stage-line' data-tip='" & lineTip & "'><div>" & [Etapa] & "</div><div class='bar'><span style='width:" & FORMAT ( barWidth, "0" ) & "%'></span></div><div class='num'>" & FORMAT ( q, vIntFormat ) & "</div><div class='pcttxt'>" & FORMAT ( pct, vPctFormat ) & "</div></div>",
				                "",
				                [Ordem], ASC
				            )
				        VAR vFinanceMatrix =
				            "<div class='finance-grid'>"
					                & "<div class='finance-cell group' data-tip='<b>INDICADOR</b><br/>Mostra se a linha compara créditos ou honorários.<br/><br/><b>Como interpretar:</b> leia cada indicador separando origem PJ360 e PROJECT.' style='background:rgba(244,217,169,.08);color:#F4D9A9'>Indicador</div><div class='finance-cell group' data-tip='<b>PJ360</b><br/>Usa apenas colunas com prefixo <code>SIMULACAO</code>.<br/><br/><b>Crédito:</b> <code>SIMULACAO_CREDITO</code><br/><b>Honorário:</b> <code>SIMULACAO_HONORARIO</code>.' style='grid-column:span 2'>PJ360</div><div class='finance-cell group' data-tip='<b>PROJECT</b><br/>Usa colunas sem prefixo <code>SIMULACAO</code>.<br/><br/><b>Crédito:</b> <code>CREDITOS</code><br/><b>Honorário líquido:</b> <code>Honorarios * (1 - PERCENTUAL / 100)</code>.' style='grid-column:span 2'>PROJECT</div>"
					                & "<div class='finance-cell sub' data-tip='<b>TIPO</b><br/>Categoria financeira exibida na linha.'>Tipo</div><div class='finance-cell sub' data-tip='<b>VALOR PJ360</b><br/>Soma do valor PJ360 para o indicador selecionado.'>VALOR</div><div class='finance-cell sub' data-tip='<b>QTD PJ360</b><br/>Conta jobs com valor PJ360 preenchido e maior que zero.'>QTD</div><div class='finance-cell sub' data-tip='<b>VALOR PROJECT</b><br/>Soma do valor PROJECT para o indicador selecionado.'>VALOR</div><div class='finance-cell sub' data-tip='<b>QTD PROJECT</b><br/>Conta jobs com valor PROJECT preenchido e maior que zero.'>QTD</div>"
					                & "<div class='finance-cell row-label' data-tip='<b>CRÉDITO</b><br/>Compara créditos PJ360 e PROJECT do produto.'>Crédito</div><div class='finance-cell placeholder' data-tip='<b>PJ360 CRÉDITO - VALOR</b><br/>Soma de <code>SIMULACAO_CREDITO</code> no produto.<br/><br/><b>Valor:</b> " & vPJ360CreditoFmt & "'>" & vPJ360CreditoFmt & "</div><div class='finance-cell placeholder' data-tip='<b>PJ360 CRÉDITO - QTD</b><br/>Jobs com <code>SIMULACAO_CREDITO</code> maior que zero.<br/><br/><b>Quantidade:</b> " & FORMAT ( vPJ360CreditoQtd, vIntFormat ) & "'>" & FORMAT ( vPJ360CreditoQtd, vIntFormat ) & "</div><div class='finance-cell placeholder' data-tip='<b>PROJECT CRÉDITO - VALOR</b><br/>Soma de <code>CREDITOS</code> no produto.<br/><br/><b>Valor:</b> " & vProjectCreditoFmt & "'>" & vProjectCreditoFmt & "</div><div class='finance-cell placeholder' data-tip='<b>PROJECT CRÉDITO - QTD</b><br/>Jobs com <code>CREDITOS</code> maior que zero.<br/><br/><b>Quantidade:</b> " & FORMAT ( vProjectCreditoQtd, vIntFormat ) & "'>" & FORMAT ( vProjectCreditoQtd, vIntFormat ) & "</div>"
					                & "<div class='finance-cell row-label' data-tip='<b>HONORÁRIOS</b><br/>Compara honorários PJ360 e PROJECT do produto.'>Honorários</div><div class='finance-cell placeholder' data-tip='<b>PJ360 HONORÁRIOS - VALOR</b><br/>Soma de <code>SIMULACAO_HONORARIO</code> no produto.<br/><br/><b>Valor:</b> " & vPJ360HonorarioFmt & "'>" & vPJ360HonorarioFmt & "</div><div class='finance-cell placeholder' data-tip='<b>PJ360 HONORÁRIOS - QTD</b><br/>Jobs com <code>SIMULACAO_HONORARIO</code> maior que zero.<br/><br/><b>Quantidade:</b> " & FORMAT ( vPJ360HonorarioQtd, vIntFormat ) & "'>" & FORMAT ( vPJ360HonorarioQtd, vIntFormat ) & "</div><div class='finance-cell placeholder' data-tip='<b>PROJECT HONORÁRIOS - VALOR</b><br/>Soma de <code>Honorarios * (1 - PERCENTUAL / 100)</code> no produto.<br/><br/><b>Valor:</b> " & vProjectHonorarioFmt & "'>" & vProjectHonorarioFmt & "</div><div class='finance-cell placeholder' data-tip='<b>PROJECT HONORÁRIOS - QTD</b><br/>Jobs com <code>Honorarios</code> maior que zero.<br/><br/><b>Quantidade:</b> " & FORMAT ( vProjectHonorarioQtd, vIntFormat ) & "'>" & FORMAT ( vProjectHonorarioQtd, vIntFormat ) & "</div>"
					            & "</div><div class='finance-note' data-tip='<b>REGRA FINANCEIRA</b><br/>PJ360 usa <code>SIMULACAO_CREDITO</code> e <code>SIMULACAO_HONORARIO</code>.<br/>PROJECT usa <code>CREDITOS</code> e <code>Honorarios</code> líquido após desconto de <code>PERCENTUAL</code>.<br/><br/><b>QTD:</b> contagem de jobs com valor maior que zero.<br/><b>Atenção:</b> <code>RF_VALOR</code> existe no modelo, mas não é usado.'><b>Regra:</b> PJ360 usa colunas <code>SIMULACAO_*</code>. PROJECT usa <code>CREDITOS</code> e <code>Honorarios</code> líquido após desconto de <code>PERCENTUAL</code>. QTD é contagem de jobs com valor maior que zero. <code>RF_VALOR</code> não é usado.</div>"
				        RETURN
				            "<details class='diag-row'><summary><div class='row-grid'>"
					                & "<div class='prod-cell' data-tip='<b>PRODUTO:</b> " & pTip & "<br/><br/><b>O que mostra:</b> linha consolidada do produto.<br/><b>Total Jobs:</b> " & FORMAT ( vJobs, vIntFormat ) & "<br/><b>Jobs Ativos:</b> " & FORMAT ( vAtivos, vIntFormat ) & "<br/><b>Percentual Ativo:</b> " & FORMAT ( vPctAtivos, vPctFormat ) & "<br/><b>Origem:</b> <code>vw_powerbi_journeys_filhos_novos[GppNome]</code>.<br/><b>Como usar:</b> clique para expandir etapas detalhadas e matriz financeira.'><div class='prod-title'>" & p & "</div><div class='prod-sub'>Clique para expandir detalhes</div><div class='prod-progress'><span style='width:" & FORMAT ( ROUND ( vPctAtivos * 100, 0 ), "0" ) & "%'></span></div></div>"
				                & vStageCells
				            & "</div></summary><div class='details'>"
				                & "<div class='card'><div class='card-title'><span>Distribuição por etapa</span><span class='card-sub'>Total e % dos jobs ativos</span></div>" & vStageLines & "</div>"
					                & "<div class='card finance-card'><div class='card-title' data-tip='<b>CRÉDITOS E HONORÁRIOS</b><br/>Matriz comparativa por produto separando PJ360 e PROJECT.<br/><br/><b>Como ler:</b> VALOR mostra soma financeira; QTD mostra jobs com valor maior que zero.<br/><b>Atenção:</b> PROJECT Honorários aplica desconto de <code>PERCENTUAL</code>; <code>RF_VALOR</code> não participa.'><span>Créditos e Honorários</span><span class='card-sub'>PJ360 x PROJECT</span></div>" & vFinanceMatrix & "</div>"
				            & "</div></details>",
				        "",
				        [__Jobs], DESC,
				        [__Produto], ASC
				    )
				VAR vNota = "Período: " & vPeriodo & ". Ativo nas novas views = FIM 1."
				RETURN
				    vCSS
				        & "<div class='diag-wrap'>"
				        & "<div class='sticky'><div class='diag-head'><div class='slicer-space'><div class='detailbar'><div class='detail-pill' data-tip='" & vTipAbrirDetalhamento & "'>Abrir detalhamento <span>›</span></div></div></div>" & vCards & "</div></div>"
				        & vHead
				        & "<div class='rows'>" & IF ( ISBLANK ( vRows ), "<div class='empty'>Nenhum produto encontrado para os filtros atuais.</div>", vRows ) & "</div>"
				        & "<div class='foot'>" & vNota & "</div>"
				        & "</div>"
			```
		displayFolder: HTML
		lineageTag: b0000702-d1ag-ba5e-b010-ba5e00000702

	column Column
		formatString: 0
		lineageTag: 2ec931fb-c2e0-4926-ad68-5e513c5ba130
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition medidas_html = calculated
		mode: import
		source = Row("Column", BLANK())

