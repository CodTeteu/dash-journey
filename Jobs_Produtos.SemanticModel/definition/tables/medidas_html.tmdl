				                            vArea = "OPERACAO", 2,
				                            vArea = "PROCURAÇÃO ELETRÔNICA", 3,
				                            vArea = "PROCURACAO ELETRONICA", 3,
				                            0
				                        )
				                )
				    )
				VAR vJobStatus =
				    ADDCOLUMNS (
				        vJobStatusRaw,
				        "__Stage",
				            IF (
				                [__OpenRows] = 0 && [__FimRows] > 0,
				                4,
				                COALESCE ( [__StageOpen], 0 )
				            )
				    )
				RETURN
				    COUNTROWS ( FILTER ( vJobStatus, [__Stage] >= 2 ) )
			```
		displayFolder: 02 Status Jobs
		lineageTag: b0000207-d1ag-ba5e-b010-ba5e00000207

	/// Percentual de jobs ativos em relacao ao total.
	measure 'Diagnóstico | % Ativos' = ```
				DIVIDE ( [Diagnóstico | Jobs Ativos], [Diagnóstico | Jobs] , 0 )
			```
		formatString: 0.0%
		displayFolder: 02 Status Jobs
		lineageTag: b0000208-d1ag-ba5e-b010-ba5e00000208
		dataCategory: Percentage

	/// Percentual de jobs que passaram de etapa (etapa >= 2) em relacao ao total.
	measure 'Diagnóstico | % Passaram Etapa' = ```
				DIVIDE ( [Diagnóstico | Jobs Passaram Etapa], [Diagnóstico | Jobs] , 0 )
			```
		formatString: 0.0%
		displayFolder: 02 Status Jobs
		lineageTag: b0000209-d1ag-ba5e-b010-ba5e00000209
		dataCategory: Percentage

	/// 03 OPORTUNIDADES - Medidas de oportunidades (tributos)
	/// Oportunidades disponibilizadas: contagem distinta de NOME_TRIBUTO na base.
	measure 'Diagnóstico | Oportunidades Disponibilizadas' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS (
				        SUMMARIZE (
				            FILTER ( vBaseDiag, NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] ) ),
				            'JOBS_Produto'[NOME_TRIBUTO]
				        )
				    )
			```
		displayFolder: 03 Oportunidades
		lineageTag: b0000301-d1ag-ba5e-b010-ba5e00000301

	/// Oportunidades que passaram: tributos cujas linhas estao em Operacao, Procuracao ou Fim.
	measure 'Diagnóstico | Oportunidades Passaram' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS (
				        SUMMARIZE (
				            FILTER (
				                vBaseDiag,
				                NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] )
				                    && (
				                        VAR vArea = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
				                        RETURN
				                            vArea IN {
				                                "OPERAÇÃO",
				                                "OPERACAO",
				                                "PROCURAÇÃO ELETRÔNICA",
				                                "PROCURACAO ELETRONICA",
				                                "FIM"
				                            }
				                    )
				            ),
				            'JOBS_Produto'[NOME_TRIBUTO]
				        )
				    )
			```
		displayFolder: 03 Oportunidades
		lineageTag: b0000302-d1ag-ba5e-b010-ba5e00000302

	/// Percentual de oportunidades que passaram em relacao as disponibilizadas.
	measure 'Diagnóstico | % Oportunidades Passaram' = ```
				DIVIDE ( [Diagnóstico | Oportunidades Passaram], [Diagnóstico | Oportunidades Disponibilizadas] , 0 )
			```
		formatString: 0.0%
		displayFolder: 03 Oportunidades
		lineageTag: b0000303-d1ag-ba5e-b010-ba5e00000303
		dataCategory: Percentage

	/// 04 CARDS - HTML dos 3 cards KPI principais conforme lógica PROJECT_QBERT_JOBS/QBERT. Jobs e Ativos usam MAP_PRODUTOS_ESTEIRA_TAX.
	measure 'HTML Bloco | Cards' =
			VAR vFmt = "#,##0"
			VAR vJourney = [Journey QBERT | Total Journey]
			VAR vJobs = [Journey QBERT | Total Jobs]
			VAR vAtivos = [Journey QBERT | Jobs Ativos]
			VAR vJourneyCard =
			    "<div class='kpi-card primary' data-tip='Total de Journey: PROJECT_QBERT_JOBS com CODIGO_PRODUTO = 360, FIM = 1 e DATA_CADASTRO no período selecionado.'>"
			        & "<span class='tip-arrow'></span>"
			        & "<div class='kpi-label'>Total Journey</div>"
			        & "<div class='kpi-value'>" & FORMAT ( vJourney, vFmt ) & "</div>"
			        & "<div class='kpi-caption'>Produto 360 finalizado</div>"
			    & "</div>"
			VAR vJobsCard =
			    "<div class='kpi-card primary' data-tip='Total de Jobs: filhos cujo PAI está nos Journey 360 finalizados do período e cujo CODIGO_PRODUTO está no mapa da esteira TAX.'>"
			        & "<span class='tip-arrow'></span>"
			        & "<div class='kpi-label'>Total Jobs</div>"
			        & "<div class='kpi-value'>" & FORMAT ( vJobs, vFmt ) & "</div>"
			        & "<div class='kpi-caption'>Filhos da esteira TAX</div>"
			    & "</div>"
			VAR vAtivosCard =
			    "<div class='kpi-card attention' data-tip='Jobs ativos: filhos dos Journey 360 do período, restritos à esteira TAX, com FIM diferente de 1.'>"
			        & "<span class='tip-arrow'></span>"
			        & "<div class='kpi-label'>Ativos</div>"
			        & "<div class='kpi-value'>" & FORMAT ( vAtivos, vFmt ) & "</div>"
			        & "<div class='kpi-caption'>Esteira TAX sem FIM = 1</div>"
			    & "</div>"
			RETURN
			    "<div class='diag-kpis qbert-kpis'>"
			        & vJourneyCard
			        & vJobsCard
			        & vAtivosCard
			    & "</div>"
		displayFolder: 04 Cards
		lineageTag: b0000410-d1ag-ba5e-b010-ba5e00000410

	/// 05 TABELA PRINCIPAL - HTML da tabela e linhas de produtos
	/// Cabecalho fixo da tabela principal com as 9 colunas.
	measure 'HTML Tabela | Cabeçalho' = ```
				    "<div class='table-head'>"
				        & "<div>Produto</div>"
				        & "<div>Diag.</div>"
				        & "<div>Ativos</div>"
				        & "<div>Checklist</div>"
				        & "<div>Operacao</div>"
				        & "<div>Procur.</div>"
				        & "<div>Fim</div>"
				        & "<div>Passaram</div>"
				        & "<div>Dias</div>"
				    & "</div>"
			```
		displayFolder: 05 Tabela Principal
		lineageTag: b0000501-d1ag-ba5e-b010-ba5e00000501

	/// Linhas da tabela: uma linha expansivel por produto diagnostico com etapas e resumo macro.
	/// Esta medida contem a logica principal de agrupamento por produto e geracao HTML.
	measure 'HTML Tabela | Linhas Produtos' = ```
					VAR vIntFormat = "#,##0"
					VAR vPctFormat = "0.0%"
					VAR vTopProdutos = 35
					VAR vTopDetalhes = 12
					VAR vProdutoSelecionado =
					    HASONEVALUE ( 'DIM_PRODUTOS_IMAGEM_TAX'[ProdutoImagem] )
					VAR vProdutosSelecionados =
					    VALUES ( 'DIM_PRODUTOS_IMAGEM_TAX'[ProdutoImagem] )
			
					-- Base governada: somente produtos da imagem da esteira TAX.
					VAR vBaseDiag =
					    CALCULATETABLE (
					        FILTER ( 'JOBS_Produto', NOT ISBLANK ( 'JOBS_Produto'[ProdutoImagemTax] ) ),
					        TREATAS ( vProdutosSelecionados, 'JOBS_Produto'[ProdutoImagemTax] )
					    )
			
					-- Job stage: single FILTER per job (was 3 separate scans = 67% reduction)
					VAR vJobStageCalc =
					    ADDCOLUMNS (
					        SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[JOB] ),
					        "__Stage",
					            VAR vJobKey = 'JOBS_Produto'[JOB]
					            VAR vJobRows =
					                SELECTCOLUMNS (
					                    FILTER ( vBaseDiag, 'JOBS_Produto'[JOB] = vJobKey ),
					                    "@S",
					                        VAR vArea = UPPER ( COALESCE ( 'JOBS_Produto'[NOME_AREA], "" ) )
					                        RETURN
					                            SWITCH (
					                                TRUE (),
					                                vArea = "CHECKLIST", 1,
					                                vArea = "OPERAÇÃO", 2,
					                                vArea = "OPERACAO", 2,
					                                vArea = "PROCURAÇÃO ELETRÔNICA", 3,
					                                vArea = "PROCURACAO ELETRONICA", 3,
					                                vArea = "FIM", 4,
					                                0
					                            )
					                )
					            VAR vMaxAll = MAXX ( vJobRows, [@S] )
					            VAR vMaxOpen = MAXX ( FILTER ( vJobRows, [@S] < 4 ), [@S] )
					            RETURN
					                IF ( vMaxAll = 4 && ISBLANK ( vMaxOpen ), 4, COALESCE ( vMaxOpen, 0 ) )
					    )
			
					-- Derive status without re-scanning vBaseDiag
					VAR vJobStatus =
					    ADDCOLUMNS (
					        vJobStageCalc,
					        "__Status", IF ( [__Stage] = 4, "Finalizado", "Ativo" )
					    )
			
					VAR vJobs = COUNTROWS ( vJobStatus )
			
					-- Totais gerais para comparativo na expansao
					VAR vTotalAtivos     = COUNTROWS ( FILTER ( vJobStatus, [__Status] = "Ativo" ) )
					VAR vTotalChecklist  = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 1 ) )
					VAR vTotalOperacao   = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 2 ) )
					VAR vTotalProcuracao = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 3 ) )
					VAR vTotalFim        = COUNTROWS ( FILTER ( vJobStatus, [__Stage] = 4 ) )
					VAR vTotalPassaram   = COUNTROWS ( FILTER ( vJobStatus, [__Stage] >= 2 ) )
					VAR vTotalReg        = COUNTROWS ( vBaseDiag )
					VAR vTotalOport      = COUNTROWS ( SUMMARIZE ( FILTER ( vBaseDiag, NOT ISBLANK ( 'JOBS_Produto'[NOME_TRIBUTO] ) ), 'JOBS_Produto'[NOME_TRIBUTO] ) )
					VAR vTotalDiasMed    = MEDIANX ( vBaseDiag, 'JOBS_Produto'[DIAS] )
			
					-- Product aggregates: single FILTER per product (was 3 separate ADDCOLUMNS + vProdutoBase = 83% reduction)
					VAR vAllProdutos = SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[ProdutoImagemTax] )
			
					VAR vProdutoValidos =
					    FILTER (
					        ADDCOLUMNS (
					            vAllProdutos,
					            "__Registros",
					                VAR vP = 'JOBS_Produto'[ProdutoImagemTax]
					                VAR vPRows = FILTER ( vBaseDiag, 'JOBS_Produto'[ProdutoImagemTax] = vP )
					                RETURN
					                    COUNTROWS ( vPRows ),
					            "__Jobs",
					                VAR vP = 'JOBS_Produto'[ProdutoImagemTax]
					                VAR vPRows = FILTER ( vBaseDiag, 'JOBS_Produto'[ProdutoImagemTax] = vP )
					                RETURN
					                    COUNTROWS ( SUMMARIZE ( vPRows, 'JOBS_Produto'[JOB] ) ),
					            "__OportDisp",
					                VAR vP = 'JOBS_Produto'[ProdutoImagemTax]
					                VAR vPRows = FILTER ( vBaseDiag, 'JOBS_Produto'[ProdutoImagemTax] = vP )
					                RETURN
					                    COUNTROWS ( SUMMARIZE ( vPRows, 'JOBS_Produto'[NOME_TRIBUTO] ) ),
					            "__DiasMed",
					                VAR vP = 'JOBS_Produto'[ProdutoImagemTax]
					                VAR vPRows = FILTER ( vBaseDiag, 'JOBS_Produto'[ProdutoImagemTax] = vP )
					                RETURN
					                    MEDIANX ( vPRows, 'JOBS_Produto'[DIAS] )
					        ),
					        [__Jobs] > 0
					    )
			
					VAR vProdutoTop =
					    TOPN (
					        vTopProdutos,
					        vProdutoValidos,
					        [__Jobs], DESC,
					        [__Registros], DESC,
					        'JOBS_Produto'[ProdutoImagemTax], ASC
					    )
			
					VAR vMaxJobsProduto =
					    MAXX ( vProdutoTop, [__Jobs] )
			
					-- Job-to-product mapping
					VAR vJobProduto =
					    SUMMARIZE (
					        vBaseDiag,
					        'JOBS_Produto'[JOB],
					        'JOBS_Produto'[ProdutoImagemTax]
					    )
			
					-- Pre-compute subproduto stats
					VAR vSubprodutoJobs =
					    ADDCOLUMNS (
					        SUMMARIZE (
					            vBaseDiag,
					            'JOBS_Produto'[ProdutoImagemTax],
					            'JOBS_Produto'[NOME_SUBPRODUTO]
					        ),
					        "__Jobs",
					            VAR vP = 'JOBS_Produto'[ProdutoImagemTax]
					            VAR vS = 'JOBS_Produto'[NOME_SUBPRODUTO]
					            RETURN
					                COUNTROWS (
					                    SUMMARIZE (
					                    FILTER (
					                        vBaseDiag,
					                        'JOBS_Produto'[ProdutoImagemTax] = vP
					                            && 'JOBS_Produto'[NOME_SUBPRODUTO] = vS
					                        ),
					                        'JOBS_Produto'[JOB]
					                    )
					                )
					    )
			
					VAR vRowsHTML =
					    CONCATENATEX (
					        vProdutoTop,
					        VAR vProdutoKey = 'JOBS_Produto'[ProdutoImagemTax]
					        VAR vProduto = COALESCE ( vProdutoKey, "Sem produto" )
			
					        -- Pre-computed values from row context
					        VAR vReg = [__Registros]
					        VAR vOportDisp = [__OportDisp]
					        VAR vDiasProduto = [__DiasMed]
			
					        -- Filter job status by product via mapping table
					        VAR vGroupStatus =
					            FILTER (
					                vJobStatus,
					                'JOBS_Produto'[JOB]
					                        IN SELECTCOLUMNS (
					                            FILTER ( vJobProduto, 'JOBS_Produto'[ProdutoImagemTax] = vProdutoKey ),
					                            "@job",
					                        'JOBS_Produto'[JOB]
					                    )
					            )
			
					        VAR vJob = COUNTROWS ( vGroupStatus )
					        VAR vAtivo = COUNTROWS ( FILTER ( vGroupStatus, [__Status] = "Ativo" ) )
					        VAR vFim = COUNTROWS ( FILTER ( vGroupStatus, [__Stage] = 4 ) )
					        VAR vChecklist = COUNTROWS ( FILTER ( vGroupStatus, [__Stage] = 1 ) )
					        VAR vOperacao = COUNTROWS ( FILTER ( vGroupStatus, [__Stage] = 2 ) )
					        VAR vProcuracao = COUNTROWS ( FILTER ( vGroupStatus, [__Stage] = 3 ) )
					        VAR vPassaram = COUNTROWS ( FILTER ( vGroupStatus, [__Stage] >= 2 ) )
					        VAR vShare = DIVIDE ( vJob, vJobs , 0 )
					        VAR vBar = MAX ( 4, ROUND ( DIVIDE ( vJob, vMaxJobsProduto , 0 ) * 100, 0 ) )
					        VAR vPassouPct = DIVIDE ( vPassaram, vJob , 0 )
			
					        VAR vStageTable =
					            UNION (
					                ROW ( "Etapa", "Checklist", "Qtd", vChecklist, "Pct", DIVIDE ( vChecklist, vJob , 0 ), "Ordem", 1 ),
					                ROW ( "Etapa", "Operacao", "Qtd", vOperacao, "Pct", DIVIDE ( vOperacao, vJob , 0 ), "Ordem", 2 ),
					                ROW ( "Etapa", "Procuracao Eletronica", "Qtd", vProcuracao, "Pct", DIVIDE ( vProcuracao, vJob , 0 ), "Ordem", 3 ),
					                ROW ( "Etapa", "Fim", "Qtd", vFim, "Pct", DIVIDE ( vFim, vJob , 0 ), "Ordem", 4 )
					            )
			
					        VAR vStageHTML =
					            CONCATENATEX (
					                vStageTable,
					                VAR vPct = [Pct]
					                VAR vPctBar = MAX ( 2, ROUND ( COALESCE ( vPct, 0 ) * 100, 0 ) )
					                RETURN
					                    "<div class='detail-line'>"
					                        & "<div class='detail-name'>" & [Etapa] & "</div>"
					                        & "<div class='detail-bar'><span style='width:" & FORMAT ( vPctBar, "0" ) & "%'></span></div>"
					                        & "<div class='detail-num'>" & FORMAT ( [Qtd], vIntFormat ) & "</div>"
					                        & "<div class='detail-pct'>" & FORMAT ( vPct, vPctFormat ) & "</div>"
					                    & "</div>",
					                "",
					                [Ordem], ASC
					            )
			
					        -- Subproduto table
					        VAR vSubprodutoTable =
					            TOPN (
					                vTopDetalhes,
					                FILTER (
					                    vSubprodutoJobs,
					                    COALESCE ( 'JOBS_Produto'[ProdutoImagemTax], "" ) = COALESCE ( vProdutoKey, "" )
					                ),
					                [__Jobs], DESC,
					                'JOBS_Produto'[NOME_SUBPRODUTO], ASC
					            )
			
					        VAR vSubprodutoHTML =
					            CONCATENATEX (
					                vSubprodutoTable,
					                "<span class='pill'>"
					                    & COALESCE ( 'JOBS_Produto'[NOME_SUBPRODUTO], "Sem subproduto" )
					                    & " · "
					                    & FORMAT ( [__Jobs], vIntFormat )
					                    & " jobs"
					                & "</span>",
					                "",
					                [__Jobs], DESC
					            )
			
					        RETURN
					            "<details class='diag-row'>"
					                & "<summary>"
					                    & "<div class='row-grid'>"
					                        & "<div class='main-cell'>"
					                            & "<div class='title-line'>"
					                                & "<span class='row-title'>" & vProduto & "</span>"
					                            & "</div>"
					                            & "<div class='row-sub'>"
					                                & FORMAT ( vReg, vIntFormat ) & " linhas · "
					                                & FORMAT ( vOportDisp, vIntFormat ) & " oportunidades disponibilizadas · "
					                                & FORMAT ( vShare, vPctFormat ) & " dos diagnosticos"
					                            & "</div>"
					                            & "<div class='progress'><span style='width:" & FORMAT ( vBar, "0" ) & "%'></span></div>"
					                        & "</div>"
					                        & "<div class='metric'><b>" & FORMAT ( vJob, vIntFormat ) & "</b><small>diagnosticos</small></div>"
					                        & "<div class='metric'><b>" & FORMAT ( vAtivo, vIntFormat ) & "</b><small>ativos</small></div>"
					                        & "<div class='metric'><b>" & FORMAT ( vChecklist, vIntFormat ) & "</b><small>checklist</small></div>"
					                        & "<div class='metric'><b>" & FORMAT ( vOperacao, vIntFormat ) & "</b><small>operacao</small></div>"
					                        & "<div class='metric'><b>" & FORMAT ( vProcuracao, vIntFormat ) & "</b><small>procuracao</small></div>"
					                        & "<div class='metric'><b>" & FORMAT ( vFim, vIntFormat ) & "</b><small>fim</small></div>"
					                        & "<div class='metric highlight'><b>" & FORMAT ( vPassouPct, vPctFormat ) & "</b><small>passaram</small></div>"
					                        & "<div class='metric'><b>" & FORMAT ( vDiasProduto, "#,##0" ) & "</b><small>dias med.</small></div>"
					                    & "</div>"
					                & "</summary>"
					                & "<div class='detail-box'>"
					                    & "<div class='detail-card wide'>"
					                        & "<div class='detail-title'>Comparativo: produto vs total do periodo</div>"
					                        & "<div class='cmp-head'>"
					                            & "<div>Metrica</div><div>Produto</div><div>Total</div><div>% do Total</div><div></div>"
					                        & "</div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Jobs</div><div class='cmp-val'>" & FORMAT ( vJob, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vJobs, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vJob, vJobs, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vJob, vJobs, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Ativos</div><div class='cmp-val'>" & FORMAT ( vAtivo, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalAtivos, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vAtivo, vTotalAtivos, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vAtivo, vTotalAtivos, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Checklist</div><div class='cmp-val'>" & FORMAT ( vChecklist, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalChecklist, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vChecklist, vTotalChecklist, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vChecklist, vTotalChecklist, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Operacao</div><div class='cmp-val'>" & FORMAT ( vOperacao, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalOperacao, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vOperacao, vTotalOperacao, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vOperacao, vTotalOperacao, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Procuracao</div><div class='cmp-val'>" & FORMAT ( vProcuracao, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalProcuracao, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vProcuracao, vTotalProcuracao, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vProcuracao, vTotalProcuracao, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Fim</div><div class='cmp-val'>" & FORMAT ( vFim, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalFim, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vFim, vTotalFim, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vFim, vTotalFim, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Passaram etapa</div><div class='cmp-val'>" & FORMAT ( vPassaram, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalPassaram, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vPassaram, vTotalPassaram, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vPassaram, vTotalPassaram, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Registros (linhas)</div><div class='cmp-val'>" & FORMAT ( vReg, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalReg, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vReg, vTotalReg, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vReg, vTotalReg, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Oportunidades</div><div class='cmp-val'>" & FORMAT ( vOportDisp, vIntFormat ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalOport, vIntFormat ) & "</div><div class='cmp-pct'>" & FORMAT ( DIVIDE ( vOportDisp, vTotalOport, 0 ), vPctFormat ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MAX ( 2, ROUND ( DIVIDE ( vOportDisp, vTotalOport, 0 ) * 100, 0 ) ), "0" ) & "%'></span></div></div>"
					                        & "<div class='cmp-row'><div class='cmp-name'>Dias mediana</div><div class='cmp-val'>" & FORMAT ( vDiasProduto, "#,##0" ) & "</div><div class='cmp-val'>" & FORMAT ( vTotalDiasMed, "#,##0" ) & "</div><div class='cmp-pct cmp-neutral'>" & IF ( vDiasProduto <= vTotalDiasMed, "≤ geral", "> geral" ) & "</div><div class='cmp-bar'><span style='width:" & FORMAT ( MIN ( 100, MAX ( 2, ROUND ( DIVIDE ( vDiasProduto, MAX ( vTotalDiasMed, 1 ), 0 ) * 100, 0 ) ) ), "0" ) & "%'></span></div></div>"
					                    & "</div>"
					                    & "<div class='detail-card wide'>"
					                        & "<div class='detail-title'>Subprodutos</div>"
					                        & "<div class='pill-wrap'>"
					                            & vSubprodutoHTML
					                        & "</div>"
					                        & "<div class='pill-wrap' style='margin-top:12px'>"
					                            & "<span class='pill pass'>Para ver job, cliente, CNPJ, oportunidades e datas linha a linha, use a aba Detalhamento.</span>"
					                        & "</div>"
					                    & "</div>"
					                & "</div>"
					            & "</details>",
					        "",
					        [__Jobs], DESC
					    )
			
					RETURN
					    vRowsHTML
			```
		displayFolder: 05 Tabela Principal
		lineageTag: b0000502-d1ag-ba5e-b010-ba5e00000502

	/// 06 ESTILO HTML - CSS completo do visual
	/// CSS completo do dashboard Diagnostico Journey com fundo escuro, paleta dourado/teal, scroll customizado, cards, tabela, tooltips e responsivo.
	measure 'HTML CSS | Completo' = ```
					"<style>
			.diag-wrap{
			    font-family:'Segoe UI',Arial,sans-serif;
			    width:100%;
			    height:calc(100vh - 2px);
			    box-sizing:border-box;
			    color:#E8EEF5;
			    background:radial-gradient(circle at top left,rgba(213,174,119,.18),transparent 32%),linear-gradient(135deg,#101923 0%,#0B1219 100%);
			    border:1px solid rgba(213,174,119,.28);
			    border-radius:18px;
			    overflow:auto;
			    box-shadow:0 18px 48px rgba(0,0,0,.34);
			}
			
			.diag-wrap{
			    scrollbar-width:thin;
			    scrollbar-color:rgba(213,174,119,.48) rgba(6,11,16,.96);
			}
			.diag-wrap::-webkit-scrollbar{
			    width:13px;
			    height:10px;
			}
			.diag-wrap::-webkit-scrollbar-track{
			    background:linear-gradient(180deg,#060B10 0%,#0B1219 100%);
			    border-left:1px solid rgba(213,174,119,.10);
			    border-radius:999px;
			}
			.diag-wrap::-webkit-scrollbar-thumb{
			    background:
			        linear-gradient(180deg,rgba(213,174,119,.58),rgba(17,28,35,.96));
			    border:3px solid #060B10;
			    border-radius:999px;
			    box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
			}
			.diag-wrap::-webkit-scrollbar-thumb:hover{
			    background:
			        linear-gradient(180deg,rgba(244,217,169,.70),rgba(213,174,119,.40));
			}
			.diag-wrap::-webkit-scrollbar-corner{
			    background:#060B10;
			}
			
			.sticky{position:sticky;top:0;z-index:60;background:rgba(11,18,25,.98);border-bottom:1px solid rgba(213,174,119,.18);box-shadow:0 16px 30px rgba(0,0,0,.36);overflow:visible}
			.diag-head{padding:20px 24px 28px;overflow:visible}
			.slicer-space{height:64px;width:100%;margin-bottom:8px;display:flex;align-items:flex-start;justify-content:flex-end;padding-top:2px}
			.doc-button{position:relative;display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:12px 20px 12px 18px;border-radius:14px;color:#081018;border:1px solid rgba(244,217,169,.72);background:linear-gradient(135deg,#F4D9A9 0%,#D5AE77 48%,#8BE0D1 100%);box-shadow:0 14px 28px rgba(213,174,119,.24),0 0 0 1px rgba(255,255,255,.08) inset,0 0 22px rgba(139,224,209,.18);font-size:13px;font-weight:950;letter-spacing:.10em;text-transform:uppercase;white-space:nowrap;overflow:hidden}
			.doc-button:before{content:'\25A6';display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;margin-right:9px;border-radius:8px;background:rgba(8,16,24,.18);border:1px solid rgba(8,16,24,.22);font-size:12px;line-height:1;color:#081018;font-weight:950}
			.doc-button:after{content:'';position:absolute;inset:-1px;border-radius:14px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.45),transparent);transform:translateX(-120%);animation:shineDetalhe 3.6s ease-in-out infinite}
			@keyframes shineDetalhe{0%{transform:translateX(-120%)}48%{transform:translateX(-120%)}72%{transform:translateX(120%)}100%{transform:translateX(120%)}}
			.diag-kpis{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:18px;margin-top:0;position:relative;z-index:90;overflow:visible}
			.kpi-card{position:relative;min-width:0;padding:21px 18px 18px;border-radius:20px;background:linear-gradient(160deg,rgba(18,28,37,.96),rgba(11,18,25,.94));border:1px solid rgba(255,255,255,.10);overflow:visible;box-shadow:0 18px 32px rgba(0,0,0,.24),inset 0 1px 0 rgba(255,255,255,.06);transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
			.kpi-card.primary{background:linear-gradient(155deg,rgba(213,174,119,.18),rgba(18,28,37,.96) 36%,rgba(11,18,25,.96));border-color:rgba(213,174,119,.42)}
			.kpi-card.attention{background:linear-gradient(155deg,rgba(139,224,209,.08),rgba(18,28,37,.96) 34%,rgba(11,18,25,.96));border-color:rgba(139,224,209,.30)}
			.kpi-card:before{content:'';position:absolute;left:16px;top:0;width:46px;height:4px;border-radius:0 0 10px 10px;background:linear-gradient(90deg,#F4D9A9,#8BE0D1);opacity:.92}
			.kpi-card:hover{transform:translateY(-2px);border-color:rgba(213,174,119,.34);box-shadow:0 22px 40px rgba(0,0,0,.28),0 0 0 1px rgba(213,174,119,.08),inset 0 1px 0 rgba(255,255,255,.08)}
			.kpi-card[data-tip]:hover:after{content:attr(data-tip);position:absolute;left:14px;right:14px;top:calc(100% + 12px);padding:11px 12px;border-radius:12px;background:linear-gradient(160deg,rgba(7,13,18,.98),rgba(12,22,29,.98));border:1px solid rgba(213,174,119,.34);color:#E8EEF5;font-size:11.5px;font-weight:820;line-height:1.35;box-shadow:0 16px 32px rgba(0,0,0,.34);z-index:999;white-space:normal;pointer-events:none}
			.kpi-card[data-tip]:hover:before{opacity:1}
			.kpi-card[data-tip]:hover .tip-arrow{position:absolute;left:28px;top:calc(100% + 5px);width:14px;height:14px;background:linear-gradient(160deg,rgba(7,13,18,.98),rgba(12,22,29,.98));border-left:1px solid rgba(213,174,119,.34);border-top:1px solid rgba(213,174,119,.34);transform:rotate(45deg);opacity:0;z-index:998;pointer-events:none}
			.tip-arrow{position:absolute;left:28px;bottom:calc(100% + 4px);width:14px;height:14px;background:linear-gradient(160deg,rgba(7,13,18,.98),rgba(12,22,29,.98));border-left:1px solid rgba(213,174,119,.34);border-top:1px solid rgba(213,174,119,.34);transform:rotate(45deg);opacity:0;z-index:29;pointer-events:none}
			.kpi-label{color:#AEB9C4;font-size:12px;font-weight:950;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
			.kpi-value{margin-top:10px;color:#F4D9A9;font-size:32px;font-weight:950;line-height:1.05;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
			.kpi-caption{margin-top:9px;color:#8B98A6;font-size:13px;font-weight:850;line-height:1.25}
			.kpi-total{color:#8B98A6;font-size:22px;font-weight:850}
			.exec-strip{display:none}
			.exec-alert{display:inline-flex;align-items:center;min-height:34px;padding:8px 13px;border-radius:11px;font-size:12px;font-weight:950;letter-spacing:.04em;text-transform:uppercase;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.045);color:#C7D0DA}
			.exec-alert.good{color:#8BE0D1;border-color:rgba(139,224,209,.30);background:rgba(139,224,209,.08)}
			.exec-alert.attention{color:#F4D9A9;border-color:rgba(213,174,119,.32);background:rgba(213,174,119,.09)}
			.exec-alert.danger{color:#FFB0A8;border-color:rgba(217,93,93,.34);background:rgba(217,93,93,.10)}
			.exec-alert.neutral{color:#AEB9C4;border-color:rgba(255,255,255,.12);background:rgba(255,255,255,.04)}
			.table-head{display:grid;grid-template-columns:minmax(520px,1.95fr) repeat(8,minmax(112px,.56fr));min-width:1520px;background:#121C25;border-bottom:1px solid rgba(213,174,119,.20)}
			.table-head div{padding:16px 12px;color:#D5AE77;font-size:13px;font-weight:950;text-transform:uppercase;letter-spacing:.07em;text-align:center}
			.table-head div:first-child{text-align:left;padding-left:20px}
			.rows{min-width:1520px}
			.diag-row{border-bottom:1px solid rgba(255,255,255,.055)}
			.diag-row summary{list-style:none;cursor:pointer}
			.diag-row summary::-webkit-details-marker{display:none}
			.row-grid{display:grid;grid-template-columns:minmax(520px,1.95fr) repeat(8,minmax(112px,.56fr));align-items:stretch;transition:all .18s ease}
			.row-grid:hover{background:rgba(213,174,119,.08)}
			.main-cell{padding:18px 18px;border-right:1px solid rgba(255,255,255,.05)}
			.title-line{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
			.row-title{color:#F8EFE1;font-size:18px;font-weight:950;line-height:1.2}
			.row-sub{margin-top:8px;color:#9FAAB5;font-size:14px;font-weight:820}
			.progress{margin-top:12px;height:9px;border-radius:999px;background:rgba(255,255,255,.07);overflow:hidden}
			.progress span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#D5AE77,#8BE0D1)}
			.metric{display:flex;flex-direction:column;justify-content:center;align-items:center;gap:6px;min-height:96px;padding:12px 8px;text-align:center;border-left:1px solid rgba(255,255,255,.05)}
			.metric b{color:#E8EEF5;font-size:21px;font-weight:950}
			.metric small{color:#8B98A6;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.05em}
			.metric.highlight b{color:#F4D9A9}
			.badge{display:inline-flex;align-items:center;padding:6px 10px;border-radius:999px;font-size:11px;font-weight:950;text-transform:uppercase;letter-spacing:.04em;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.055)}
			.badge.good{color:#8BE0D1;border-color:rgba(139,224,209,.30);background:rgba(139,224,209,.08)}
			.badge.attention{color:#F4D9A9;border-color:rgba(213,174,119,.34);background:rgba(213,174,119,.10)}
			.badge.danger{color:#FFB0A8;border-color:rgba(217,93,93,.34);background:rgba(217,93,93,.10)}
			.badge.neutral{color:#AEB9C4}
			.detail-box{display:grid;grid-template-columns:1fr;gap:24px;padding:28px 32px 32px 40px;background:rgba(4,9,14,.38);border-top:1px solid rgba(213,174,119,.08)}
			.detail-card{min-width:0;padding:28px;border-radius:18px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.08)}
			.detail-card.wide{grid-column:span 2}
			.detail-title{color:#F4D9A9;font-size:16px;font-weight:950;letter-spacing:.08em;text-transform:uppercase;margin-bottom:18px}
			.detail-line{display:grid;grid-template-columns:minmax(190px,1fr) minmax(200px,1fr) 90px 72px;align-items:center;gap:10px;margin-bottom:8px}
			.detail-name{color:#DCE5EE;font-size:14px;font-weight:850}
			.detail-bar{height:10px;border-radius:999px;overflow:hidden;background:rgba(255,255,255,.07)}
			.detail-bar span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#D5AE77,#F4D9A9)}
			.detail-num,.detail-pct{color:#AEB9C4;font-size:13px;font-weight:900;text-align:right}
			.pill-wrap{display:flex;flex-wrap:wrap;gap:12px}
			.pill{display:inline-flex;align-items:center;padding:12px 16px;border-radius:999px;color:#DCE5EE;background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.10);font-size:16px;font-weight:850}
			.pill.disp{border-color:rgba(213,174,119,.24);background:rgba(213,174,119,.07)}
			.pill.pass{border-color:rgba(139,224,209,.26);background:rgba(139,224,209,.07);color:#DFFCF7}
			.pill.empty{color:#AEB9C4}
			.client-wrap{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
			.client-line{display:grid;grid-template-columns:minmax(0,1fr) 138px 76px;gap:8px;align-items:center;padding:8px 9px;border-radius:11px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.07)}
			.client-name{min-width:0;color:#DCE5EE;font-size:13px;font-weight:850;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
			.client-cnpj,.client-qtd{color:#9FAAB5;font-size:12px;font-weight:850;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-align:right}
			.diag-note{display:none}
			.cmp-head,.cmp-row{display:grid;grid-template-columns:minmax(220px,1.6fr) 130px 130px 110px minmax(300px,2.5fr);align-items:center;gap:16px;padding:8px 10px}
			.cmp-head{border-bottom:2px solid rgba(213,174,119,.22);margin-bottom:6px}
			.cmp-head div{color:#D5AE77;font-size:14px;font-weight:950;text-transform:uppercase;letter-spacing:.06em}
			.cmp-name{color:#DCE5EE;font-size:18px;font-weight:850}
			.cmp-val{color:#AEB9C4;font-size:18px;font-weight:900;text-align:right}
			.cmp-pct{color:#F4D9A9;font-size:18px;font-weight:950;text-align:right}
			.cmp-pct.cmp-neutral{color:#8B98A6;font-size:15px;font-weight:850}
			.cmp-bar{height:14px;border-radius:999px;background:rgba(255,255,255,.07);overflow:hidden}
			.cmp-bar span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#D5AE77,#8BE0D1)}
			.cmp-row:hover{background:rgba(213,174,119,.06);border-radius:10px}
			@media(max-width:900px){.diag-kpis{grid-template-columns:repeat(6,minmax(210px,1fr));overflow-x:auto}.detail-box{grid-template-columns:1fr}.detail-card.wide{grid-column:span 1}.client-wrap{grid-template-columns:1fr}}
			</style>"
			```
		displayFolder: 06 Estilo HTML
		lineageTag: b0000601-d1ag-ba5e-b010-ba5e00000601

	/// 07 LAYOUT FINAL - Medida principal que monta o visual completo
	/// Topo com espaco para slicers e botao Detalhamento.
	measure 'HTML Layout | Topo Slicers' = ```
				    "<div class='slicer-space'><div class='doc-button'>Detalhamento</div></div>"
			```
		displayFolder: 07 Layout Final
		lineageTag: b0000701-d1ag-ba5e-b010-ba5e00000701

	/// Visual principal refatorado que monta CSS + Cards + Tabela com logica modular.
	/// Esta e a nova medida final que substitui a medida original monolítica.
	measure 'HTML Diagnóstico Journey | Visual Principal' =
			VAR vCSS = [HTML CSS | Completo]
				VAR vCards = [HTML Bloco | Cards]
				VAR vTabelaHead = [HTML Tabela | Cabeçalho]
				VAR vLinhas = [HTML Tabela | Linhas Produtos]
				VAR vTopo = [HTML Layout | Topo Slicers]
				RETURN
				    vCSS
				        & "<div class='diag-wrap'>"
				        &     "<div class='sticky'>"
				        &         "<div class='diag-head'>"
				        &             vTopo
				        &             vCards
				        &         "</div>"
				        &         vTabelaHead
				        &     "</div>"
				        &     "<div class='rows'>" & vLinhas & "</div>"
				        & "</div>"
		displayFolder: 07 Layout Final
		lineageTag: b0000702-d1ag-ba5e-b010-ba5e00000702

	/// 08 DEBUG E VALIDACAO - Medidas para conferencia entre versao antiga e nova
	/// Debug: Contagem total de registros na base de diagnostico.
	measure 'Diagnóstico Debug | Total Base' = ```
				[Diagnóstico | Registros]
			```
		displayFolder: 08 Debug e Validação
		lineageTag: b0000801-d1ag-ba5e-b010-ba5e00000801

	/// Debug: Total de produtos distintos na base de diagnostico.
	measure 'Diagnóstico Debug | Total Produtos' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    COUNTROWS (
				        SUMMARIZE (
				            FILTER ( vBaseDiag, NOT ISBLANK ( 'JOBS_Produto'[NOME_PRODUTO] ) ),
				            'JOBS_Produto'[NOME_PRODUTO]
				        )
				    )
			```
		displayFolder: 08 Debug e Validação
		lineageTag: b0000802-d1ag-ba5e-b010-ba5e00000802

	/// Debug: Confere contagem de empresas (NOME_CLIENTE distintos).
	measure 'Diagnóstico Debug | Conferência Empresas' = ```
				[Diagnóstico | Empresas]
			```
		displayFolder: 08 Debug e Validação
		lineageTag: b0000803-d1ag-ba5e-b010-ba5e00000803

	/// Debug: Confere contagem de jobs.
	measure 'Diagnóstico Debug | Conferência Jobs' = ```
				[Diagnóstico | Jobs]
			```
		displayFolder: 08 Debug e Validação
		lineageTag: b0000804-d1ag-ba5e-b010-ba5e00000804

	/// Debug: Confere contagem de oportunidades disponibilizadas.
	measure 'Diagnóstico Debug | Conferência Oportunidades' = ```
				[Diagnóstico | Oportunidades Disponibilizadas]
			```
		displayFolder: 08 Debug e Validação
		lineageTag: b0000805-d1ag-ba5e-b010-ba5e00000805

	/// 03B HONORARIOS - Medidas de honorários por job
	/// Honorarios encontrados: soma distinta por JOB para evitar duplicidade.
	measure 'Diagnóstico | Honorários Encontrados' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    SUMX (
				        SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[JOB] ),
				        CALCULATE ( MAX ( 'JOBS_Produto'[JOB_HONORARIOS_ENCONTRADOS] ) )
				    )
			```
		formatString: R$ #,##0
		displayFolder: 03B Honorarios
		lineageTag: b0000311-d1ag-ba5e-b010-ba5e00000311

	/// Honorarios agendados: soma distinta por JOB.
	measure 'Diagnóstico | Honorários Agendados' = ```
				VAR vBaseDiag = 'JOBS_Produto'
				RETURN
				    SUMX (
				        SUMMARIZE ( vBaseDiag, 'JOBS_Produto'[JOB] ),
				        CALCULATE ( MAX ( 'JOBS_Produto'[JOB_HONORARIOS_AGENDADOS] ) )
				    )
			```
		formatString: R$ #,##0
		displayFolder: 03B Honorarios
		lineageTag: b0000312-d1ag-ba5e-b010-ba5e00000312

	/// Percentual de honorarios agendados sobre encontrados.
	measure 'Diagnóstico | % Honorários Agendados' = ```
				DIVIDE ( [Diagnóstico | Honorários Agendados], [Diagnóstico | Honorários Encontrados], 0 )
			```
		formatString: 0.0%
		displayFolder: 03B Honorarios
		lineageTag: b0000313-d1ag-ba5e-b010-ba5e00000313
		dataCategory: Percentage

	/// Total de Journey: COUNT(CODIGO) em PROJECT_QBERT_JOBS/QBERT para CODIGO_PRODUTO=360, FIM=1 e período selecionado.
	measure 'Journey QBERT | Total Journey' =
			VAR vMesesSelecionados =
			    VALUES ( 'dCalendar'[YearMonth] )
			RETURN
			    COUNTROWS (
			        FILTER (
			            ALL ( 'QBERT_JOBS_JOURNEY' ),
			            'QBERT_JOBS_JOURNEY'[CODIGO_PRODUTO] = 360
			                && 'QBERT_JOBS_JOURNEY'[FIM] = 1
			                && CONTAINS (
			                    vMesesSelecionados,
			                    'dCalendar'[YearMonth],
			                    YEAR ( 'QBERT_JOBS_JOURNEY'[DATA_CADASTRO] ) * 100
			                        + MONTH ( 'QBERT_JOBS_JOURNEY'[DATA_CADASTRO] )
			                )
			        )
			    )
		formatString: #,##0
		displayFolder: 04 Cards | QBERT
		lineageTag: 142b60b8-a65b-43f9-b8ba-e00e3955028b

	/// Total de Jobs: COUNT(CODIGO) dos filhos cujo PAI está nos Journey 360 finalizados do período selecionado e CODIGO_PRODUTO está no mapa governado MAP_PRODUTOS_ESTEIRA_TAX.
	measure 'Journey QBERT | Total Jobs' =
			VAR vMesesSelecionados =
			    VALUES ( 'dCalendar'[YearMonth] )
			VAR vProdutosEsteiraTax =
			    SELECTCOLUMNS (
			        FILTER (
			            ALL ( 'MAP_PRODUTOS_ESTEIRA_TAX' ),
			            'MAP_PRODUTOS_ESTEIRA_TAX'[AtivoFiltro]
			                && NOT ISBLANK ( 'MAP_PRODUTOS_ESTEIRA_TAX'[CodigoProduto] )
			        ),
			        "@CodigoProduto", 'MAP_PRODUTOS_ESTEIRA_TAX'[CodigoProduto]
			    )
			VAR vPaisJourney =
			    SELECTCOLUMNS (
			        FILTER (
			            ALL ( 'QBERT_JOBS_JOURNEY' ),
			            'QBERT_JOBS_JOURNEY'[CODIGO_PRODUTO] = 360
			                && 'QBERT_JOBS_JOURNEY'[FIM] = 1
			                && CONTAINS (
			                    vMesesSelecionados,
			                    'dCalendar'[YearMonth],
			                    YEAR ( 'QBERT_JOBS_JOURNEY'[DATA_CADASTRO] ) * 100
			                        + MONTH ( 'QBERT_JOBS_JOURNEY'[DATA_CADASTRO] )
			                )
			        ),
			        "@CodigoPai", 'QBERT_JOBS_JOURNEY'[CODIGO]
			    )
			RETURN
			    COUNTROWS (
			        FILTER (
			            ALL ( 'QBERT_JOBS_JOURNEY' ),
			            NOT ISBLANK ( 'QBERT_JOBS_JOURNEY'[CODIGO] )
			                && 'QBERT_JOBS_JOURNEY'[PAI] IN vPaisJourney
			                && 'QBERT_JOBS_JOURNEY'[CODIGO_PRODUTO] IN vProdutosEsteiraTax
			        )
			    )
		formatString: #,##0
		displayFolder: 04 Cards | QBERT
		lineageTag: 3e0d1714-b681-4c61-b78c-863f7916c025

	/// Jobs ativos: filhos dos Journey 360 finalizados do período selecionado, restritos ao mapa governado MAP_PRODUTOS_ESTEIRA_TAX, com FIM diferente de 1.
	measure 'Journey QBERT | Jobs Ativos' =
			VAR vMesesSelecionados =
			    VALUES ( 'dCalendar'[YearMonth] )
			VAR vProdutosEsteiraTax =
			    SELECTCOLUMNS (
			        FILTER (
			            ALL ( 'MAP_PRODUTOS_ESTEIRA_TAX' ),
			            'MAP_PRODUTOS_ESTEIRA_TAX'[AtivoFiltro]
			                && NOT ISBLANK ( 'MAP_PRODUTOS_ESTEIRA_TAX'[CodigoProduto] )
			        ),
			        "@CodigoProduto", 'MAP_PRODUTOS_ESTEIRA_TAX'[CodigoProduto]
			    )
			VAR vPaisJourney =
			    SELECTCOLUMNS (
			        FILTER (
			            ALL ( 'QBERT_JOBS_JOURNEY' ),
			            'QBERT_JOBS_JOURNEY'[CODIGO_PRODUTO] = 360
			                && 'QBERT_JOBS_JOURNEY'[FIM] = 1
			                && CONTAINS (
			                    vMesesSelecionados,
			                    'dCalendar'[YearMonth],
			                    YEAR ( 'QBERT_JOBS_JOURNEY'[DATA_CADASTRO] ) * 100
			                        + MONTH ( 'QBERT_JOBS_JOURNEY'[DATA_CADASTRO] )
			                )
			        ),
			        "@CodigoPai", 'QBERT_JOBS_JOURNEY'[CODIGO]
			    )
			RETURN
			    COUNTROWS (
			        FILTER (
			            ALL ( 'QBERT_JOBS_JOURNEY' ),
			            NOT ISBLANK ( 'QBERT_JOBS_JOURNEY'[CODIGO] )
			                && 'QBERT_JOBS_JOURNEY'[PAI] IN vPaisJourney
			                && 'QBERT_JOBS_JOURNEY'[CODIGO_PRODUTO] IN vProdutosEsteiraTax
			                && COALESCE ( 'QBERT_JOBS_JOURNEY'[FIM], 0 ) <> 1
			        )
			    )
		formatString: #,##0
		displayFolder: 04 Cards | QBERT
		lineageTag: 1bdef7ff-7b2c-4f9b-bf88-d8af9ff2ebf7

	column Column
		formatString: 0
		lineageTag: 2ec931fb-c2e0-4926-ad68-5e513c5ba130
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition medidas_html = calculated
		mode: import
		source = Row("Column", BLANK())

	annotation PBI_Id = 1fcf0b6930bb4e10a61b1c725afbbaf7

	annotation 436ba87b-9c83-4389-a31b-ebd06a36be98 = {"Expression":""}

