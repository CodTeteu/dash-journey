	column CNPJ_JOIN =
			VAR c0 = "" & JOBS_PRODUTO_AREA[CNPJ_CLIENTE]
			VAR c1 =
			    SUBSTITUTE (
			        SUBSTITUTE (
			            SUBSTITUTE (
			                SUBSTITUTE (
			                    SUBSTITUTE ( TRIM ( c0 ), ".", "" ),
			                    "/",
			                    ""
			                ),
			                "-",
			                ""
			            ),
			            " ",
			            ""
			        ),
			        UNICHAR ( 160 ),
			        ""
			    )
			RETURN
			    RIGHT ( "00000000000000" & c1, 14 )
		dataType: string
		lineageTag: c0b972e2-3534-49dc-a6e3-4080943e927a
		summarizeBy: none

	partition JOBS_PRODUTO_AREA = m
		mode: import
		source =
				let
				    Fonte = Sql.Databases("192.168.2.34"),
				    STUDIO_FISCAL = Fonte{[Name="STUDIO_FISCAL"]}[Data],
				    dbo_vw_powerbi_jobs_produto_area = STUDIO_FISCAL{[Schema="dbo",Item="vw_powerbi_jobs_produto_area"]}[Data]
				in
				    dbo_vw_powerbi_jobs_produto_area

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

